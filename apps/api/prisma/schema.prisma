  readAt           DateTime?
  claimedAt        DateTime?
  expiresAt        DateTime?
  /// userId của admin đã gửi (null cho hệ thống / script).
  createdByAdminId String?
  createdAt        DateTime  @default(now())

  @@index([recipientId, createdAt])
  @@index([recipientId, claimedAt])
  @@index([recipientId, readAt])
  @@index([expiresAt])
