  equippedSlot EquipSlot?
  /// Phase 11.4.B Gem MVP — danh sách gemKey đã khảm theo thứ tự slot.
  /// Capacity tối đa = `socketCapacityForQuality(item.quality)` (PHAM=0,
  /// LINH=1, HUYEN=2, TIEN=3, THAN=4) enforce ở `GemService.socketGem`
  /// server-authoritative. Item non-equipment / chưa khảm giữ `[]`.
  sockets      String[]   @default([])
  /// Phase 11.5.B Refine MVP — cấp luyện khí 0..15 (`REFINE_MAX_LEVEL`).
  /// Stat multiplier = `getRefineStatMultiplier(refineLevel)` áp dụng lên
