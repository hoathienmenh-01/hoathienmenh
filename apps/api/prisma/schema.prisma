// Xuân Tôi — schema rút gọn (file 04 §3). Sẽ mở rộng theo từng phase.

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  PLAYER
  MOD
  ADMIN
}

enum Quality {
  PHAM
  LINH
  HUYEN
  TIEN
  THAN
}

enum ItemType {
  WEAPON
  ARMOR
  BELT
  BOOTS
  HAT
  TRAM
  PILL
  HERB
  ORE
  KEY
  ARTIFACT
  MISC
}

enum EquipSlot {
  WEAPON
  ARMOR
  BELT
  BOOTS
  HAT
  TRAM
  ARTIFACT_1
  ARTIFACT_2
  ARTIFACT_3
}

enum Difficulty {
  THUONG
  KHO
  AC_MONG
  BAO_TAU
}

enum TopupStatus {
  PENDING
  APPROVED
  REJECTED
}

model TopupOrder {
  id             String      @id @default(cuid())
  userId         String
  user           User        @relation("TopupOrderUser", fields: [userId], references: [id], onDelete: Cascade)
  packageKey     String
  tienNgocAmount Int
  priceVND       Int
  /// Mã chuyển khoản hiển thị cho user khi quét QR (ví dụ TOPUP-<short>).
  transferCode   String      @unique
  status         TopupStatus @default(PENDING)
  note           String      @default("")
  approvedById   String?
  approvedBy     User?       @relation("TopupOrderApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  approvedAt     DateTime?
  createdAt      DateTime    @default(now())

  @@index([userId, status, createdAt])
  @@index([status, createdAt])
}

model AdminAuditLog {
  id          String   @id @default(cuid())
  actorUserId String
  actor       User     @relation("AdminAuditActor", fields: [actorUserId], references: [id], onDelete: Cascade)
  action      String
  /// JSON describing the action target (e.g. user id, amount, reason).
  meta        Json     @default("{}")
  createdAt   DateTime @default(now())

  @@index([actorUserId, createdAt])
  @@index([action, createdAt])
}

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  passwordHash    String
  passwordVersion Int       @default(1)
  role            Role      @default(PLAYER)
  banned          Boolean   @default(false)
  createdAt       DateTime  @default(now())
  lastLoginAt     DateTime?

  character                     Character?
  topupOrders                   TopupOrder[]            @relation("TopupOrderUser")
  topupApprovals                TopupOrder[]            @relation("TopupOrderApprover")
  auditLogs                     AdminAuditLog[]         @relation("AdminAuditActor")
  refreshTokens                 RefreshToken[]
  /// Phase 18.2 — UserSession family (login device/browser group).
  userSessions                  UserSession[]
  passwordResetTokens           PasswordResetToken[]
  /// Phase 15.1–15.2 — LiveOps Event Scheduler audit (admin tạo event).
  /// SET NULL khi User bị xoá — event row vẫn giữ history.
  liveOpsScheduledEventsCreated LiveOpsScheduledEvent[] @relation("LiveOpsScheduledEventCreatedBy")
  /// Phase 15.3.B — LiveOps Announcement audit (admin tạo announcement).
  /// SET NULL khi User bị xoá — announcement row vẫn giữ history.
  liveOpsAnnouncementsCreated   LiveOpsAnnouncement[]   @relation("LiveOpsAnnouncementCreatedBy")
  /// Phase 15.4 — FeatureFlag audit (admin gần nhất bật/tắt flag).
  /// SET NULL khi admin bị xoá — flag row giữ updatedAt + value.
  featureFlagsUpdated           FeatureFlag[]           @relation("FeatureFlagUpdatedBy")
  /// Phase 45.0 — RemoteConfig audit (admin gần nhất chỉnh config).
  /// SET NULL khi admin bị xoá — config row giữ updatedAt + value.
  remoteConfigsUpdated          RemoteConfig[]          @relation("RemoteConfigUpdatedBy")
  /// Phase 15.5 — MaintenanceWindow audit (admin tạo bảo trì).
  /// SET NULL khi admin bị xoá — window row vẫn giữ history.
  maintenanceWindowsCreated     MaintenanceWindow[]     @relation("MaintenanceWindowCreatedBy")
  /// Phase 15.6 — ConfigVersion / ConfigRollbackRun audit. SET NULL khi
  /// admin bị xoá — version + rollback rows giữ history.
  configVersionsChanged         ConfigVersion[]         @relation("ConfigVersionChangedBy")
  configRollbacksRun            ConfigRollbackRun[]     @relation("ConfigRollbackPerformedBy")
  /// Phase 27.6 — Admin Control Center V2 audit. SET NULL khi admin bị
  /// xoá — config row vẫn giữ history.
  rewardProfilesUpdated         RewardProfile[]         @relation("RewardProfileUpdatedBy")
  dropProfilesUpdated           DropProfile[]           @relation("DropProfileUpdatedBy")
  contentStatusesUpdated        ContentStatus[]         @relation("ContentStatusUpdatedBy")
  /// Phase 28.0 — Event Builder audit (admin tạo / cập nhật event definition).
  /// SET NULL khi admin bị xoá — event row giữ lịch sử.
  eventDefsCreated              EventDef[]              @relation("EventDefCreatedBy")
  eventDefsUpdated              EventDef[]              @relation("EventDefUpdatedBy")
  eventBalancePoliciesUpdated   EventBalancePolicy[]    @relation("EventBalancePolicyUpdatedBy")
  /// Phase PWA-1 — Web Push subscriptions per user (one per device /
  /// browser endpoint). Cascade khi user bị xoá để không leak push
  /// gateway endpoint.
  webPushSubscriptions          WebPushSubscription[]
  /// Phase PWA-1 — Per-user push notification preferences (1-1, lazy
  /// upsert).
  webPushPreferences            UserPushPreferences?
}

/// Token đặt lại mật khẩu (forgot/reset-password flow).
/// Token plaintext không bao giờ lưu trong DB; chỉ lưu argon2id hash.
/// Token TTL ngắn (mặc định 30 phút). One-shot consume.
model PasswordResetToken {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// argon2id hash của reset token plaintext.
  hashedToken String
  expiresAt   DateTime
  consumedAt  DateTime?
  createdAt   DateTime  @default(now())

  @@index([userId, consumedAt])
  @@index([expiresAt])
}

model RefreshToken {
  id              String       @id @default(cuid())
  jti             String       @unique
  userId          String
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// argon2id hash của refresh JWT (không lưu plaintext).
  hashedToken     String
  passwordVersion Int
  expiresAt       DateTime
  revokedAt       DateTime?
  rotatedFromId   String?
  createdAt       DateTime     @default(now())
  /// Phase 18.2 — link với `UserSession`. NULL cho row issued trước
  /// migration; row mới luôn có sessionId. KHÔNG cascade khi session
  /// bị xoá (set null) để giữ history token.
  sessionId       String?
  session         UserSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([userId, revokedAt])
  @@index([expiresAt])
  @@index([sessionId, revokedAt])
}

/// Phase 18.2 — UserSession: 1 row đại diện 1 phiên đăng nhập (1
/// thiết bị / browser tab gọi login). 1 `UserSession` group nhiều
/// `RefreshToken` theo chain rotation: refresh token cũ → token mới
/// vẫn cùng `sessionId`. Khi detect refresh-token-reuse, revoke cả
/// session → mọi child RefreshToken cũng bị revoke (defensive).
///
/// Privacy:
///   - `ipHash` = sha256(salt || raw IP). KHÔNG bao giờ persist raw IP.
///   - `userAgent` được sanitize (strip control char + trim + truncate
///     256 chars) trước khi persist. Source: shared `sanitizeUserAgent`.
///
/// Lifecycle:
///   - Tạo khi login/register thành công.
///   - Update `lastSeenAt` mỗi lần refresh thành công (rotate).
///   - Mark `revokedAt` khi: user logout / user revoke session /
///     admin revoke / change-password / detect refresh-token-reuse /
///     `expiresAt` qua (mark lazily khi list).
///   - `revokedReason` lưu literal `SessionRevokeReason` (xem
///     `packages/shared/src/auth-session.ts`).
model UserSession {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// sha256(salt || ip). Null khi request không có IP (vd test).
  ipHash        String?
  /// Sanitized UA, truncate 256 chars. Null khi không gửi header.
  userAgent     String?
  createdAt     DateTime  @default(now())
  lastSeenAt    DateTime  @default(now())
  expiresAt     DateTime
  revokedAt     DateTime?
  /// Literal `SessionRevokeReason`:
  ///   USER_LOGOUT / ADMIN_REVOKE / REFRESH_REUSED /
  ///   PASSWORD_CHANGED / EXPIRED / SUSPICIOUS
  revokedReason String?
  /// userId của admin/user thực hiện revoke. Null nếu hết hạn tự
  /// nhiên. KHÔNG FK để giảm rủi ro CASCADE ngược khi xoá admin.
  revokedById   String?
  /// Phase 18.2 — reserve flag cho heuristic phase sau (vd login
  /// đột ngột đổi UA/IP). KHÔNG enforce ở Phase 18.2; chỉ ghi.
  suspicious    Boolean   @default(false)

  refreshTokens RefreshToken[]

  @@index([userId, revokedAt])
  @@index([userId, lastSeenAt(sort: Desc)])
  @@index([expiresAt, revokedAt])
  @@index([revokedAt, createdAt(sort: Desc)])
}

model LoginAttempt {
  id        String   @id @default(cuid())
  email     String
  ip        String
  success   Boolean
  createdAt DateTime @default(now())

  @@index([email, ip, createdAt])
  @@index([createdAt])
}

model Character {
  id         String  @id @default(cuid())
  userId     String  @unique
  user       User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String  @unique
  realmKey   String
  realmStage Int     @default(1)
  title      String?
  exp        BigInt  @default(0)
  level      Int     @default(1)

  hp         Int @default(100)
  hpMax      Int @default(100)
  mp         Int @default(50)
  mpMax      Int @default(50)
  stamina    Int @default(100)
  staminaMax Int @default(100)
  power      Int @default(10)
  spirit     Int @default(10)
  speed      Int @default(10)
  luck       Int @default(5)
  daoVan     Int @default(0)

  linhThach        BigInt @default(0)
  tienNgoc         Int    @default(0)
  tienNgocKhoa     Int    @default(0)
  tienTe           Int    @default(0)
  nguyenThach      Int    @default(0)
  congHien         Int    @default(0)
  congDuc          Int    @default(0)
  chienCongTongMon Int    @default(0)
  /// Phase 27.0 — Wallet currency (Đăng Tiên Tháp / Linh Khí Tháp / Huyết
  /// Thể Tháp). Earn từ trial tower clear; spend qua trial-tower shop.
  trialPoint       Int    @default(0)
  /// Phase 27.0 — Event token (hoạt động mùa, event pass). Earn từ event;
  /// spend qua event shop.
  eventToken       Int    @default(0)

  /// Phase 13.1.B — Sect contribution balance (currency cho Sect Shop).
  /// `sectContribBalance` = spendable, mutate qua `SectContributionLedger`
  /// transactional pattern. Earn từ `SECT_MISSION_CLAIM`, optional admin grant.
  /// Spend qua `SECT_SHOP_BUY` (negative delta) — atomic CAS guard
  /// `gte` đảm bảo non-negative race-safe (mirror linhThach pattern).
  /// `sectContribLifetime` = tổng đã earn (audit only, không trừ khi spend).
  /// Phân biệt với `congHien` (legacy "đóng góp tu vi" treasury — KHÔNG đổi).
  sectContribBalance  Int @default(0)
  sectContribLifetime Int @default(0)

  settings    Json    @default("{}")
  cultivating Boolean @default(false)

  /// Phase 26.0 — Luyện Thể progression song song Luyện Khí.
  /// EXP/cảnh giới riêng, tick riêng, breakthrough thủ công qua
  /// BodyCultivationService. Không vượt quá realmKey.order + 1.
  bodyRealmKey          String    @default("pham_than")
  bodyStage             Int       @default(1)
  bodyExp               BigInt    @default(0)
  bodyCultivating       Boolean   @default(false)
  bodyInjuryUntil       DateTime?
  physiqueKey           String?
  bodyBreakthroughCount Int       @default(0)

  /// Phase 11.3.A — Linh căn / Spiritual Root server-authoritative.
  /// `spiritualRootGrade` ∈ {'pham','linh','huyen','tien','than'} (5-tier).
  /// `primaryElement` ∈ Ngũ Hành {'kim','moc','thuy','hoa','tho'}.
  /// `secondaryElements` String[] = subset Ngũ Hành (size match grade tier).
  /// `rootPurity` 0-100 — tinh khiết linh căn, future Phase 11.3.B sẽ wire vào refine/reroll cost.
  /// `rootRerollCount` int counter — anti-spam reroll, idempotency key cho future reroll service.
  /// Nullable cho legacy character pre-Phase 11.3 (auto-roll lazy on first read).
  spiritualRootGrade String?
  primaryElement     String?
  secondaryElements  String[] @default([])
  rootPurity         Int      @default(100)
  rootRerollCount    Int      @default(0)

  /// Phase 11.1.B — Cultivation Method server-authoritative.
  /// `equippedCultivationMethodKey` = method đang trang bị (compose `expMultiplier`
  /// vào `CultivationProcessor.process()`). Nullable cho legacy character pre-11.1.B
  /// (multiplier fallback 1.0). Onboard phase 11.1.B sẽ auto-grant + auto-equip
  /// `khai_thien_quyet` starter.
  equippedCultivationMethodKey String?

  /// Phase 11.6.B Tribulation MVP — server-authoritative deterministic kiếp.
  /// `tribulationCooldownAt` set khi attempt FAIL → block retry tới khi
  /// `now >= tribulationCooldownAt`. Cleared khi SUCCESS (realm advance).
  /// `taoMaUntil` set khi FAIL + RNG roll dưới `taoMaDebuffChance` →
  /// Tâm Ma debuff active. Future Phase 11.8 (Buff runtime) sẽ áp dụng
  /// modifier vào combat. MVP chỉ persist + audit.
  tribulationCooldownAt DateTime?
  taoMaUntil            DateTime?

  /// Phase 11.11.B Alchemy MVP — cấp lò luyện đan của character.
  /// Default = 1 (mở recipe PHAM tier). Phase 11.11.C sẽ thêm upgrade
  /// cost (linhThach + nguyên liệu cao cấp) cho L2..L9.
  alchemyFurnaceLevel Int    @default(1)
  alchemyLevel        Int    @default(1)
  alchemyExp          BigInt @default(0)
  alchemyMastery      Int    @default(0)

  /// Admin seed harness Phase 11.X — bonus talent point budget cộng dồn
  /// trên `computeTalentPointBudget(realmOrder)` (3 realm = 1 điểm gốc).
  /// Use-case: QA seed cho positive-path talent flow / Phase 11.X UI E2E
  /// `talent learn → cast → cooldown` không cần advance realm. Default = 0
  /// (không ảnh hưởng player thường). Mutate qua `POST /admin/users/:id/grant-talent-point`
  /// (admin endpoint) — KHÔNG cho player tự cộng (anti-FE-self-grant).
  bonusTalentPoints Int @default(0)

  /// Phase 12 Story PR-2 — server-authoritative story chapter cursor.
  /// Tăng monotonic khi player complete main storyline gate quest
  /// (`phamnhan_main_01` → `luyenkhi_main_01` → `truc_co_main_01` → …).
  /// Default 0 = chưa bắt đầu Hoa Thiên Tuyển Đồ. Mutate ONLY qua
  /// `QuestService` (KHÔNG admin endpoint, KHÔNG FE self-grant). Phase 12
  /// PR-5 sẽ wire main storyline UI gate dựa trên field này.
  storyChapter Int @default(0)

  /// Phase 12 Story Dialogue Foundation — set các `StoryDialogueNodeDef.id` đã
  /// thấy. Lưu Json array of string id. Idempotent — `mark_seen` effect đẩy id
  /// vào set, dedupe via `Set([...prev, id])`. Phục vụ:
  ///   - condition `seen`/`not_seen` filter visibility node tiếp theo;
  ///   - FE highlight choice đã chọn (PR-tiếp).
  /// Mutate ONLY qua `StoryDialogueService.applyChoice` (server-authoritative).
  storyDialogueSeen Json @default("[]")

  /// Phase 12 Story Dialogue Foundation — flag map cho story branching.
  /// `Record<string, string | number | boolean>` — flagKey → primitive value.
  /// Effect `set_flag` ghi đè (last-write-wins); Phase 12.9 effect `clear_flag`
  /// xoá entry. Phục vụ:
  ///   - condition `flag_equals`/`flag_set`/`flag_unset` rẽ nhánh hội thoại;
  ///   - PR sau: gating reward / sect / faction.
  /// Mutate ONLY qua `StoryDialogueService.applyChoice`.
  storyFlags Json @default("{}")

  /// Phase 12.9 Story Dialogue Branch Advanced — map nodeId → choiceKey
  /// (last-write-wins per node) cho condition `choice_made`. Cho phép NPC
  /// "nhớ" lựa chọn cũ + render multi-step branching tree khác nhau theo
  /// path player đã đi. Mutate ONLY qua `StoryDialogueService.applyChoice`.
  storyDialogueChoices Json @default("{}")

  sectId String?
  sect   Sect?   @relation(fields: [sectId], references: [id])

  inventory                 InventoryItem[]
  sectMembers               SectMember[]
  sectBossParticipants      SectBossParticipant[]
  ledger                    CurrencyLedger[]
  itemLedger                ItemLedger[]
  missionProgress           MissionProgress[]
  questProgress             QuestProgress[]
  mails                     Mail[]
  dailyLoginClaims          DailyLoginClaim[]
  spiritualRootRollLogs     SpiritualRootRollLog[]
  cultivationMethods        CharacterCultivationMethod[]
  methodUpgradeLogs         MethodUpgradeLog[]
  artifactsV2               CharacterArtifactV2[]
  artifactCraftLogs         ArtifactCraftAttemptLog[]
  artifactUpgradeLogsV2     ArtifactUpgradeLogV2[]
  characterSkills           CharacterSkill[]
  tribulationAttemptLogs    TribulationAttemptLog[]
  bodyBreakthroughLogs      BodyBreakthroughAttemptLog[]
  alchemyAttemptLogs        AlchemyAttemptLog[]
  tribulationEncounters     TribulationEncounter[]
  tribulationMiniBattles    TribulationMiniBattle[]
  breakthroughAttemptLogs   BreakthroughAttemptLog[]
  buffs                     CharacterBuff[]
  talents                   CharacterTalent[]
  titleUnlocks              CharacterTitleUnlock[]
  achievements              CharacterAchievement[]
  reputation                CharacterReputation[]
  longTermGoals             CharacterLongTermGoal[]
  sectMissionClaims         SectMissionClaim[]
  sectShopPurchases         SectShopPurchase[]
  sectContributionLedger    SectContributionLedger[]
  sectSeasonClaims          SectSeasonClaim[]
  npcAffinities             CharacterNpcAffinity[]
  npcGiftLogs               CharacterNpcGiftLog[]
  dailyRewardBuckets        CharacterDailyRewardBucket[]
  rewardCapEvents           RewardCapEvent[]
  dailyMaterialCaps         DailyMaterialCap[]
  weeklyMaterialCaps        WeeklyMaterialCap[]
  arenaProfile              ArenaProfile?
  arenaMatchesAttacker      ArenaMatch[]                 @relation("ArenaMatchAttacker")
  arenaMatchesDefender      ArenaMatch[]                 @relation("ArenaMatchDefender")
  arenaStandings            ArenaStanding[]
  arenaSeasonRewardGrants   ArenaSeasonRewardGrant[]
  /// Phase 15.0.A — Equipment Reforge / Enchant Foundation.
  /// Audit history per attempt; FK Cascade khi xoá character.
  equipmentReforgeHistory   EquipmentReforgeHistory[]
  equipmentEnchantHistory   EquipmentEnchantHistory[]
  /// Phase 15.1–15.2 — LiveOps Event Scheduler reward claim (one-time per event).
  liveOpsEventRewardClaims  LiveOpsEventRewardClaim[]
  battlePassProgress        BattlePassProgress[]
  monthlyCardSubscription   MonthlyCardSubscription[]
  vipProfile                VipProfile?
  shopPackPurchases         ShopPackPurchase[]
  /// Phase 27.0 — Monetization Foundation backrefs.
  premiumEntitlements       PremiumEntitlement[]
  monetizationShopPurchases MonetizationShopPurchase[]
  paidLimitPurchases        PaidLimitPurchase[]
  sweepTicketLogs           SweepTicketLog[]
  growthFundStates          GrowthFundState[]
  /// Phase 27.1–27.5 — Monetization Systems V1 backrefs.
  battlePassMissions        BattlePassMissionProgress[]
  limitedShopPurchases      LimitedShopPurchase[]
  /// Phase 25.3 — Code-only Cosmetic Effects. Cosmetics never carry power /
  /// stat bonuses; they only drive CSS rendering on aura / title / frame /
  /// chat badge / profile decoration / element aura surfaces.
  cosmeticOwnerships        CosmeticOwnership[]
  cosmeticLoadout           CosmeticLoadout?

  /// Phase 26.5 — World Content V2 backrefs.
  farmSessions          FarmSession[]
  farmEncounters        FarmEncounter[]
  dailyContentCaps      DailyContentCap[]
  weeklyContentCaps     WeeklyContentCap[]
  trialTowerProgress    TrialTowerProgress[]
  trialTowerAttemptLogs TrialTowerAttemptLog[]
  sectBossAttemptLogs   SectBossAttemptLog[]

  /// Phase 28.0 — Event Builder backrefs.
  eventMissionProgresses EventMissionProgress[]
  eventShopPurchases     EventShopPurchase[]
  eventTokenWallets      EventTokenWallet[]
  eventRankingEntries    EventRankingEntry[]
  personalEventProgress  PersonalEventProgress[]

  /// Phase 29.0 — PvP Foundation backrefs.
  pvpBattlesAttacker PvpBattle[]        @relation("PvpBattleAttacker")
  pvpBattlesDefender PvpBattle[]        @relation("PvpBattleDefender")
  pvpDefenseProfile  PvpDefenseProfile?
  pvpAnomalyLogs     PvpAnomalyLog[]

  /// Phase 30.0 — Market V2 / Auction House.
  marketAuctionsAsSeller  MarketAuction[]          @relation("MarketAuctionSeller")
  marketAuctionsAsBidder  MarketAuction[]          @relation("MarketAuctionBidder")
  marketBids              MarketBid[]
  marketClaimBoxEntries   MarketClaimBoxEntry[]
  personalStall           PersonalStall?
  sectInternalAuctionBids SectInternalAuctionBid[]
  /// Phase 32.0 — Codex progress.
  codexProgress           CharacterCodexProgress[]

  /// Phase 41.0 — Player Experience QoL backrefs.
  playerSettingsRow      PlayerSettings?
  playerFeedbackReports  PlayerFeedback[] @relation("PlayerFeedbackReporter")
  playerFeedbackTargeted PlayerFeedback[] @relation("PlayerFeedbackTarget")
  playerReportsAuthored  PlayerReport[]   @relation("PlayerReportReporter")
  playerReportsTargeted  PlayerReport[]   @relation("PlayerReportTarget")

  /// Phase 33.1 — Story V2 (Phase 33 catalog) runtime backrefs.
  storyV2Chapters     CharacterStoryV2ChapterProgress[]
  storyV2Quests       CharacterStoryV2QuestProgress[]
  storyV2RewardClaims CharacterStoryV2RewardClaim[]

  /// Phase 34.0 — 7-Day Onboarding Questline backrefs.
  onboardingDays  CharacterOnboardingProgress[]
  onboardingTasks CharacterOnboardingTaskProgress[]

  /// Phase 34.1 — Daily Random Encounter backrefs.
  dailyEncounters CharacterDailyEncounter[]

  /// Phase 34.2 — Secret Realm Run backrefs.
  secretRealmRuns          CharacterSecretRealmRun[]
  /// Phase 38.0 — Roguelike Bí Cảnh backrefs.
  roguelikeRuns            RoguelikeRun[]
  roguelikeLeaderboard     RoguelikeLeaderboard?
  /// Phase 39.0 — Seasonal Server Progression backrefs.
  seasonProgress           SeasonProgress[]
  seasonLeaderboardEntries SeasonLeaderboardEntry[]
  seasonRewardClaims       SeasonRewardClaim[]

  /// Phase QOL-2 — Loadout Preset PvE/PvP/Boss backref.
  loadoutPresets CharacterLoadoutPreset[]

  /// Phase 35.0 — Pet / Linh Thú backrefs.
  pets           CharacterPet[]
  petShards      CharacterPetShard[]
  petBoxPity     CharacterPetBoxPityCounter[]
  petBoxOpenLogs PetBoxOpenLog[]

  /// Phase 36.0 — Động Phủ cá nhân + Linh Điền / Dược Viên runtime.
  homestead Homestead?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Phase 36.0 — Động Phủ cá nhân.
///
/// 1-1 với Character, lazy-create khi player gọi `GET /homestead`.
/// `spiritualEnergy` là năng lượng vận hành nội bộ của động phủ, regen
/// server-authoritative theo catalog và bị cap offline-hours để không tạo
/// nguồn tài nguyên vô hạn.
model Homestead {
  id                       String    @id @default(cuid())
  characterId              String    @unique
  character                Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  level                    Int       @default(1)
  spiritualEnergy          Int       @default(40)
  spiritualEnergyUpdatedAt DateTime  @default(now())
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  fields HomesteadField[]
  garden HomesteadGardenPlot[]

  @@index([characterId, level])
}

/// Phase 36.0 — Linh Điền plot.
///
/// Mỗi slot chỉ có tối đa 1 crop active/harvested record tại một thời điểm.
/// Thu hoạch dùng CAS `harvestedAt IS NULL AND readyAt <= now` để chống spam
/// song song; reward grant qua `InventoryService.grantTx`.
model HomesteadField {
  id            String    @id @default(cuid())
  homesteadId   String
  homestead     Homestead @relation(fields: [homesteadId], references: [id], onDelete: Cascade)
  slotIndex     Int
  cropKey       String
  outputItemKey String
  expectedYield Int
  plantedAt     DateTime  @default(now())
  readyAt       DateTime
  harvestedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([homesteadId, slotIndex])
  @@index([homesteadId, harvestedAt])
  @@index([readyAt])
}

/// Phase 36.0 — Dược Viên production plot.
///
/// Tương tự Linh Điền nhưng sản xuất nguyên liệu phụ luyện đan với daily cap
/// riêng và yield nhỏ hơn để tránh lạm phát nguyên liệu hiếm.
model HomesteadGardenPlot {
  id            String    @id @default(cuid())
  homesteadId   String
  homestead     Homestead @relation(fields: [homesteadId], references: [id], onDelete: Cascade)
  slotIndex     Int
  productionKey String
  outputItemKey String
  expectedYield Int
  startedAt     DateTime  @default(now())
  readyAt       DateTime
  claimedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([homesteadId, slotIndex])
  @@index([homesteadId, claimedAt])
  @@index([readyAt])
}

/// Phase 14.1.B — Async Arena Foundation profile.
///
/// 1-1 với Character (lazy-create khi GET /arena/profile lần đầu hoặc khi
/// player được chọn làm defender). Phase 14.1.B chưa có season/ELO phức tạp:
///   - `rating` start ở 1000 (xem `ARENA_RATING_DEFAULT` trong shared).
///   - `wins` / `losses` / `draws` đếm tổng trận attacker side.
///   - `attacksToday` + `lastAttackDayBucket` áp daily limit; reset khi sang
///     ngày mới (server tz Asia/Ho_Chi_Minh).
///   - `defenseSnapshotJson` cache snapshot defender lúc gần nhất (offline
///     defense replay). Phase 14.1.B vẫn rebuild snapshot mỗi lần attack
///     được resolve để tránh stale; field này nullable để Phase 14.1.C
///     wire snapshot caching nếu cần.
///
/// Defer Phase 14.1.C: ELO Glicko, season decay, placement match.
model ArenaProfile {
  id                  String    @id @default(cuid())
  characterId         String    @unique
  character           Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  rating              Int       @default(1000)
  wins                Int       @default(0)
  losses              Int       @default(0)
  draws               Int       @default(0)
  attacksToday        Int       @default(0)
  /// YYYY-MM-DD (Asia/Ho_Chi_Minh). Null khi chưa từng attack.
  lastAttackDayBucket String?
  /// Cached defender snapshot (Phase 14.1.B chưa wire — placeholder cho 14.1.C).
  defenseSnapshotJson Json?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([rating])
  @@index([updatedAt])
}

model BattlePassSeason {
  id        String               @id @default(cuid())
  seasonId  String               @unique
  name      String
  startAt   DateTime
  endAt     DateTime
  active    Boolean              @default(false)
  config    Json                 @default("{}")
  progress  BattlePassProgress[]
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  @@index([active, startAt, endAt])
}

model BattlePassProgress {
  id                   String           @id @default(cuid())
  characterId          String
  character            Character        @relation(fields: [characterId], references: [id], onDelete: Cascade)
  seasonId             String
  season               BattlePassSeason @relation(fields: [seasonId], references: [seasonId], onDelete: Cascade)
  xp                   Int              @default(0)
  level                Int              @default(0)
  premiumUnlocked      Boolean          @default(false)
  claimedFreeLevels    Int[]            @default([])
  claimedPremiumLevels Int[]            @default([])
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  @@unique([characterId, seasonId])
  @@index([seasonId, level])
}

model MonthlyCardSubscription {
  id               String    @id @default(cuid())
  characterId      String
  character        Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  /// Phase 27.0 — Monthly card variant key (vd `tieu_nguyet_tap`,
  /// `dai_nguyet_tap`, `the_luyen_dan`, …). Match `MonthlyCardKey` từ
  /// shared `monetization-foundation`. Default `tieu_nguyet_tap` cho
  /// data legacy pre-Phase 27.0.
  cardKey          String    @default("tieu_nguyet_tap")
  activeUntil      DateTime
  lastClaimAt      DateTime?
  totalClaimedDays Int       @default(0)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@unique([characterId, cardKey])
  @@index([activeUntil])
}

model VipProfile {
  id                  String    @id @default(cuid())
  characterId         String    @unique
  character           Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  vipLevel            Int       @default(0)
  lifetimeTopupAmount Int       @default(0)
  grantedByAdmin      Boolean   @default(false)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([vipLevel])
}

/// Phase 27.0 — Premium entitlement. Quyền lợi mà character đang sở hữu do
/// mua gói / thẻ tháng / pass / unlock tiện ích. Service-layer call
/// `EntitlementService.getActiveEntitlements(characterId)` để check quyền lợi
/// còn hạn (so sánh `expiresAt > now`).
///
/// `entitlementKey` ∈ shared `EntitlementKey` (`MONTHLY_CARD_SMALL/LARGE`,
/// `AUTO_FARM_EXTENDED`, `DAILY_DUNGEON_EXTRA_ATTEMPT`, `SWEEP_TICKET_DAILY`,
/// `ALCHEMY_QUEUE_SLOT`, `BODY_TRIAL_EXTRA_ATTEMPT`, `MARKET_SLOT_BONUS`,
/// `INVENTORY_SLOT_BONUS`).
///
/// `source` ghi nguồn grant — vd `MONTHLY_CARD:tieu_nguyet_tap`,
/// `SHOP:inventory_slot_pack`, `ADMIN_GRANT`, `EVENT`.
/// `valueJson` = giá trị runtime entitlement (vd `{ "minutes": 480 }` cho
/// AUTO_FARM_EXTENDED). Server enforce cap (`ENTITLEMENT_VALUE_CAPS`).
/// `active=false` để soft-disable (admin revoke) thay vì delete.
model PremiumEntitlement {
  id             String    @id @default(cuid())
  characterId    String
  character      Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  entitlementKey String
  source         String
  startsAt       DateTime  @default(now())
  expiresAt      DateTime?
  valueJson      Json      @default("{}")
  active         Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([characterId, entitlementKey])
  @@index([characterId, active, expiresAt])
  @@index([entitlementKey])
}

/// Phase 27.0 — Shop product purchase log + idempotency. UNIQUE
/// `(characterId, productKey, periodKey)` enforce purchase limit theo period
/// (`DAILY` / `WEEKLY` / `MONTHLY` / `LIFETIME`). Mỗi row = 1 lần purchase
/// thành công + reward grant + ledger row.
///
/// `priceCurrency` ∈ `CurrencyKind` (sau Phase 27.0 đã extend đủ 6 currency).
/// `rewardJson` snapshot reward đã grant — debug + audit. `status` =
/// `'COMPLETED'` (foundation phase chỉ có completed flow; future refund flow
/// có thể thêm `'REFUNDED'`).
model MonetizationShopPurchase {
  id            String       @id @default(cuid())
  characterId   String
  character     Character    @relation(fields: [characterId], references: [id], onDelete: Cascade)
  productKey    String
  productType   String
  priceCurrency CurrencyKind
  priceAmount   Int
  rewardJson    Json         @default("{}")
  status        String       @default("COMPLETED")
  /// Period bucket — `'lifetime'` cho LIFETIME/NONE; `'YYYY-MM-DD'` cho DAILY;
  /// `'YYYY-Www'` cho WEEKLY; `'YYYY-MM'` cho MONTHLY.
  periodKey     String
  createdAt     DateTime     @default(now())

  @@index([characterId, productKey, periodKey])
  @@index([characterId, productKey, createdAt])
  @@index([productKey, createdAt])
}

/// Phase 27.0 — Per-day paid limit counter cho mua thêm lượt (`extra
/// attempt`). UNIQUE `(characterId, limitKey, periodKey)` đảm bảo CAS-safe
/// upsert: mỗi day-bucket / character / limitKey chỉ có 1 row, increment
/// `usedCount` qua `updateMany` guard `usedCount < maxCount`.
///
/// `limitKey` ∈ shared `ExtraAttemptLimitKey` (`DAILY_DUNGEON` /
/// `PERSONAL_BOSS` / `FARM_MAP`). `maxCount` snapshot tại thời điểm tạo row;
/// nếu catalog đổi cap thì row cũ vẫn enforce cap snapshot (đỡ migration
/// pain). `periodKey` = `'YYYY-MM-DD'` UTC bucket (đồng bộ với
/// `CurrencyLedger`).
model PaidLimitPurchase {
  id          String    @id @default(cuid())
  characterId String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  limitKey    String
  periodKey   String
  usedCount   Int       @default(0)
  maxCount    Int
  updatedAt   DateTime  @updatedAt
  createdAt   DateTime  @default(now())

  @@unique([characterId, limitKey, periodKey])
  @@index([characterId, limitKey])
}

/// Phase 27.0 — Sweep ticket consumption log. Mỗi row = 1 lần dùng vé quét
/// cho 1 nội dung đã clear. `contentType` ∈ shared `SweepableContentType`
/// (`DUNGEON` / `FARM_MAP` / `SECT_DUNGEON`). `rewardJson` snapshot reward
/// được grant — vẫn tính daily attempt + material cap (Phase 26.2 +
/// Phase 26.5 caps không bị bypass).
model SweepTicketLog {
  id          String    @id @default(cuid())
  characterId String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  ticketKey   String
  contentType String
  contentKey  String
  rewardJson  Json      @default("{}")
  createdAt   DateTime  @default(now())

  @@index([characterId, createdAt])
  @@index([characterId, contentType, contentKey, createdAt])
}

/// Phase 27.0 — Growth Fund state (Quỹ Trưởng Thành). Mua 1 lần per
/// `(characterId, fundKey)`; mỗi milestone (đạt cảnh giới) chỉ claim 1 lần.
/// `claimedMilestonesJson` = `string[]` of `GrowthFundMilestoneDef.key` đã
/// claim — server enforce idempotency qua `updateMany` CAS guard
/// `NOT (key in claimedMilestonesJson)`.
model GrowthFundState {
  id                    String    @id @default(cuid())
  characterId           String
  character             Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  fundKey               String
  purchasedAt           DateTime  @default(now())
  claimedMilestonesJson Json      @default("[]")
  updatedAt             DateTime  @updatedAt

  @@unique([characterId, fundKey])
  @@index([characterId])
}

/// Phase 27.1–27.5 — Battle Pass V2 mission progress. Mỗi row track 1
/// `(characterId, seasonId, missionKey, scopeBucket)`. `scopeBucket` =
/// period key (DAILY = `YYYY-MM-DD`, WEEKLY = `YYYY-Www`, SEASON =
/// `season`). `progress` cộng dồn cho tới `target`; `completed = true`
/// khi đạt → cộng `expReward` vào `BattlePassProgress.xp` (1 lần / row).
/// `claimedAt` = thời điểm convert exp; UNIQUE đảm bảo không double-grant.
model BattlePassMissionProgress {
  id          String    @id @default(cuid())
  characterId String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  seasonId    String
  missionKey  String
  scopeBucket String
  progress    Int       @default(0)
  target      Int
  completed   Boolean   @default(false)
  claimedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([characterId, seasonId, missionKey, scopeBucket])
  @@index([characterId, seasonId])
  @@index([characterId, completed, claimedAt])
}

/// Phase 27.1–27.5 — Limited Periodic Shop purchase ledger. Mỗi row =
/// 1 lần mua thành công cho `(characterId, shopKey, itemKey, periodKey)`.
/// UNIQUE đảm bảo tổng số `quantity` mua trong period ≤
/// `LimitedShopItemDef.purchaseLimitCount`.
///
/// `shopKey` ∈ `LimitedShopKey` (`DAILY_SHOP`/`WEEKLY_SHOP`/`MONTHLY_SHOP`).
/// `periodKey` đồng bộ với `periodKey(now, period)` từ shared.
/// `rewardJson` snapshot reward đã grant — audit + debug.
model LimitedShopPurchase {
  id            String    @id @default(cuid())
  characterId   String
  character     Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  shopKey       String
  itemKey       String
  periodKey     String
  quantity      Int       @default(0)
  priceCurrency String
  priceAmount   Int
  rewardJson    Json      @default("{}")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([characterId, shopKey, itemKey, periodKey])
  @@index([characterId, shopKey, periodKey])
}

/// Phase 25.2 — Limited Resource Shop Pack purchase history.
/// Tracks purchase + idempotency + limit accounting per window.
/// UNIQUE on (characterId, packId, purchaseWindowKey) prevents
/// duplicate purchases in the same window. Optional idempotencyKey
/// for client-side dedup on retry.
model ShopPackPurchase {
  id                String    @id @default(cuid())
  characterId       String
  character         Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  packId            String
  quantity          Int       @default(1)
  purchaseWindowKey String
  priceCurrency     String
  priceAmount       Int
  rewardsJson       Json      @default("[]")
  idempotencyKey    String?
  paymentRef        String?
  createdAt         DateTime  @default(now())

  @@unique([characterId, packId, purchaseWindowKey])
  @@unique([idempotencyKey])
  @@index([characterId, packId, createdAt])
}

/// Phase 25.3 — Code-only Cosmetic Effects ownership.
///
/// Tracks per-character ownership of a cosmetic catalog entry (`cosmeticId`
/// resolves to `COSMETICS_CATALOG` in `packages/shared/src/cosmetics.ts`).
/// UNIQUE on (characterId, cosmeticId) so duplicate grants are idempotent.
/// `expiresAt` nullable for permanent ownership; events / battle pass keys
/// optionally set a future timestamp to enforce time-bound cosmetics.
///
/// `source` mirrors `CosmeticSource` shared union (`FREE | BATTLE_PASS |
/// SHOP | VIP | EVENT | ADMIN`). Stored as String to stay schema-light
/// (no enum migration needed when a new source channel ships).
model CosmeticOwnership {
  id          String    @id @default(cuid())
  characterId String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  cosmeticId  String
  source      String
  ownedAt     DateTime  @default(now())
  expiresAt   DateTime?
  grantReason String?
  grantRefId  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([characterId, cosmeticId])
  @@index([characterId, expiresAt])
  @@index([cosmeticId])
}

/// Phase 25.3 — Code-only Cosmetic Effects loadout.
///
/// One row per character with six nullable slot ids (one per `CosmeticType`).
/// Server enforces that each slot only holds a cosmeticId of the matching
/// type AND that the character owns a non-expired `CosmeticOwnership` for
/// that id. Cosmetic loadout is rendered FE-only; it never reads or writes
/// `Character.power | spirit | speed | luck` or any combat / progression
/// field — this preserves the Phase 25.x no-power guarantee.
model CosmeticLoadout {
  id                        String    @id @default(cuid())
  characterId               String    @unique
  character                 Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  activeAuraId              String?
  activeTitleId             String?
  activeAvatarFrameId       String?
  activeChatBadgeId         String?
  activeProfileDecorationId String?
  activeElementAuraId       String?
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt
}

/// Phase 14.1.B — Async Arena Match.
///
/// Mỗi row là 1 trận PvP async. Attacker initiate, defender không cần
/// online. Combat resolution deterministic qua `resolveCombatWithSnapshot`
/// (Phase 14.1.A) — cùng (`attackerSnapshotJson`, `defenderSnapshotJson`,
/// `seed`) → cùng kết quả mỗi lần replay.
///
/// Idempotency: caller có thể pass `seed` field (test/admin) để force
/// deterministic seed; mặc định server tự generate via `hashSeed(id)` sau
/// khi tạo row.
///
/// `result` = ENUM string ('ATTACKER_WIN' | 'DEFENDER_WIN' | 'DRAW')
/// kèm `winnerCharacterId` nullable cho draw.
///
/// `ratingDeltaJson` cache rating delta áp dụng lúc resolve — dùng cho
/// history view + audit nếu rating logic đổi sau.
model ArenaMatch {
  id                   String    @id @default(cuid())
  attackerCharacterId  String
  attacker             Character @relation("ArenaMatchAttacker", fields: [attackerCharacterId], references: [id], onDelete: Cascade)
  defenderCharacterId  String
  defender             Character @relation("ArenaMatchDefender", fields: [defenderCharacterId], references: [id], onDelete: Cascade)
  /// Lifecycle: PENDING (in-flight) | RESOLVED | CANCELLED. Phase 14.1.B
  /// chỉ emit RESOLVED (resolve sync trong cùng request handler).
  status               String    @default("PENDING")
  /// Outcome enum: ATTACKER_WIN | DEFENDER_WIN | DRAW. Null khi PENDING.
  result               String?
  winnerCharacterId    String?
  attackerSnapshotJson Json
  defenderSnapshotJson Json
  /// Numeric seed dùng resolve match (32-bit signed). Phục vụ replay verify.
  seed                 Int
  battleLogJson        Json
  /// Rating delta áp dụng lúc resolve. Null khi PENDING / CANCELLED.
  ratingDeltaJson      Json?
  createdAt            DateTime  @default(now())
  resolvedAt           DateTime?

  @@index([attackerCharacterId, createdAt])
  @@index([defenderCharacterId, createdAt])
  @@index([status, createdAt])
}

/// Phase 14.1.C — Arena Season.
///
/// 1 row mỗi season key (vd `arena_2026-W19`). Server tạo lazy-create khi
/// match đầu tiên trong season được resolve (xem
/// `ArenaSeasonService.getOrCreateActiveSeason`). Status:
///   - ACTIVE   : đang diễn ra; settle chưa chạy.
///   - SETTLED  : settle đã chạy → reward đã được mail (idempotent).
///   - ARCHIVED : reserved cho UI history Phase 14.1.D+.
///
/// `seasonKey` UNIQUE đảm bảo không có 2 row cùng key (idempotent
/// settle / lazy create race-safe).
model ArenaSeason {
  id           String                   @id @default(cuid())
  /// Stable key — `arena_<isoWeekKey>`. Đừng reuse cross-year.
  seasonKey    String                   @unique
  /// Lifecycle status — `ACTIVE` | `SETTLED` | `ARCHIVED`.
  status       String                   @default("ACTIVE")
  /// UTC ISO của Monday 00:00 ICT — start (inclusive).
  startsAt     DateTime
  /// UTC ISO của Monday 00:00 ICT tuần kế — end (exclusive).
  endsAt       DateTime
  /// ISO của lúc settle chạy — null khi ACTIVE.
  settledAt    DateTime?
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt
  standings    ArenaStanding[]
  rewardGrants ArenaSeasonRewardGrant[]

  @@index([status, endsAt])
}

/// Phase 14.1.C — Arena Standing per character per season.
///
/// Tách khỏi `ArenaProfile` (Phase 14.1.B) để giữ rating đời + counter
/// daily limit ở 1 chỗ và rating per-season scoped ở chỗ khác. Server
/// lazy-create row khi match đầu tiên trong season được resolve.
///
/// `rating` là rating tích luỹ trong season (Elo apply mỗi match). `wins`/
/// `losses` cũng count theo season. `rank` snapshot chỉ được set khi
/// settlement chạy (Phase 14.1.C — server compute rank desc theo rating).
/// `tier` cache theo `rating` (compute từ shared catalog) — denorm cho
/// leaderboard query nhanh.
model ArenaStanding {
  id          String      @id @default(cuid())
  seasonId    String
  season      ArenaSeason @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  characterId String
  character   Character   @relation(fields: [characterId], references: [id], onDelete: Cascade)
  rating      Int         @default(1000)
  wins        Int         @default(0)
  losses      Int         @default(0)
  /// Rank snapshot tại settle — null khi season chưa settle.
  rank        Int?
  /// Tier (BRONZE/SILVER/GOLD/DIAMOND/IMMORTAL) compute theo rating.
  tier        String      @default("SILVER")
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@unique([seasonId, characterId])
  @@index([seasonId, rating])
  @@index([characterId])
}

/// Phase 14.1.C — Arena Season reward grant audit.
///
/// 1 row per (seasonId, characterId) mỗi khi settlement grant reward —
/// idempotency guard chống double-mail. Settlement gọi lại thấy row tồn
/// tại sẽ skip mail (`grantedAt` đã set).
///
/// `mailId` nullable: server set sau khi `MailService.sendToCharacter`
/// trả về mail row id để audit truy ngược; nếu mail step fail rollback
/// giao dịch (transaction) thì row grant cũng rollback theo.
model ArenaSeasonRewardGrant {
  id          String      @id @default(cuid())
  seasonId    String
  season      ArenaSeason @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  characterId String
  character   Character   @relation(fields: [characterId], references: [id], onDelete: Cascade)
  /// Rank snapshot tại lúc grant — duplicate `ArenaStanding.rank` nhưng
  /// audit-correct nếu standing rank đổi sau (vd recompute lại).
  rank        Int
  /// Tier snapshot — duplicate `ArenaStanding.tier`.
  tier        String
  /// Reward payload JSON (linhThach/tienNgoc/exp/items snapshot từ catalog).
  rewardJson  Json
  /// Mail row id (`Mail.id`) — null nếu không có gì để mail (vd reward
  /// rỗng theo design).
  mailId      String?
  grantedAt   DateTime    @default(now())

  @@unique([seasonId, characterId])
  @@index([seasonId])
  @@index([characterId])
}

/// Phase 14.1.D — Arena Wintrade Alert.
///
/// Detection-only audit row được tạo bởi `ArenaAntiWintradeService` khi
/// scan phát hiện pattern bất thường. KHÔNG ban / KHÔNG rollback /
/// KHÔNG public notify — admin tự xem panel + quyết định.
///
/// Idempotency: scanner gọi lại trên cùng `windowKey` + cùng cặp character
/// SẼ KHÔNG tạo alert trùng. Unique key `(type, windowKey,
/// attackerCharacterId, defenderCharacterId)` — `null` cho phép coexist
/// nhưng các rule chính đều set ≥1 trong 2 fields. Postgres index xử lý
/// `null` như distinct nên chấp nhận được.
///
/// `severity`: `INFO|WARN|CRITICAL`. `status`: `OPEN|ACKNOWLEDGED|RESOLVED`.
/// `type`: tag rule trigger (`REPEATED_OPPONENT_PAIR`,
/// `RECIPROCAL_WIN_LOSS`, `RATING_GAIN_SPIKE`, `REWARD_FARM_PATTERN`,
/// `SEASON_SUSPICIOUS_ACTOR`).
///
/// `attackerCharacterId` / `defenderCharacterId` nullable — rule
/// `RECIPROCAL_WIN_LOSS` set cả 2 (cặp đối xứng — sort lex để windowKey
/// stable). `SEASON_SUSPICIOUS_ACTOR` chỉ set `attackerCharacterId`
/// (suspect actor).
///
/// `relatedCharacterIdsJson` chứa danh sách character liên quan thêm
/// ngoài attacker/defender (vd opponent pool nhỏ trong farm pattern).
///
/// `seasonId` nullable — set khi rule scope theo season (vd
/// `SEASON_SUSPICIOUS_ACTOR`). Không cascade khi season xóa (giữ audit).
///
/// `detailsJson` snapshot raw để admin reproduce mà không cần re-run query.
model ArenaWintradeAlert {
  id                      String   @id @default(cuid())
  /// Optional season scope. Nullable.
  seasonId                String?
  /// Attacker (suspect) — nullable cho rule không hướng (vd reciprocal
  /// đặt cặp sort lex; xem `arenaWintradePairKey`).
  attackerCharacterId     String?
  /// Defender (suspect) — nullable.
  defenderCharacterId     String?
  /// JSON array of additional related character ids (opponent pool, ...).
  relatedCharacterIdsJson Json     @default("[]")
  severity                String
  type                    String
  status                  String   @default("OPEN")
  /// Identifier cửa sổ thời gian + scope cụ thể, kết hợp `(type, windowKey,
  /// attackerCharacterId, defenderCharacterId)` UNIQUE để idempotent.
  windowKey               String
  detailsJson             Json     @default("{}")
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@unique([type, windowKey, attackerCharacterId, defenderCharacterId])
  @@index([status, severity, createdAt])
  @@index([type, createdAt])
  @@index([seasonId, severity])
  @@index([attackerCharacterId, createdAt])
  @@index([defenderCharacterId, createdAt])
}

/// Phase 11.3.A — Audit log cho mỗi lần roll Linh căn (onboard auto + future
/// manual reroll bằng `linh_can_dan` Phase 11.3.B). Idempotency: server-side
/// chống double-roll bằng query `findFirst({ characterId, source })` trước khi
/// roll mới (chỉ 1 row source='onboard' per character).
model SpiritualRootRollLog {
  id                        String    @id @default(cuid())
  characterId               String
  character                 Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  /// Source: `onboard` (auto-roll khi tạo character) | `reroll` (manual qua item).
  source                    String
  /// Grade trước khi roll (null nếu lần đầu onboard).
  previousGrade             String?
  newGrade                  String
  /// Element trước khi roll (null nếu lần đầu onboard).
  previousElement           String?
  newElement                String
  /// Số element phụ trước/sau (validate match grade tier).
  previousSecondaryElements String[]  @default([])
  newSecondaryElements      String[]  @default([])
  /// Purity trước/sau roll.
  previousPurity            Int?
  newPurity                 Int
  /// Seed RNG (test deterministic) — nullable nếu dùng Math.random.
  rngSeed                   String?
  rolledAt                  DateTime  @default(now())

  @@index([characterId, source])
  @@index([rolledAt])
}

/// Phase 11.1.B / Phase 26.3 — Sổ tay công pháp đã học của character.
/// Mỗi cặp (characterId, methodKey) duy nhất 1 row.
///
/// Phase 26.3 mở rộng cho hệ Cultivation Method V2:
///   - `level` (default 1, max = method.maxLevel) tăng qua upgrade.
///   - `star` (default 0, max = method.maxStar) tăng qua star-up consume
///     fragments + breakthrough materials.
///   - `methodExp` (BigInt default 0) tích lũy từ tu luyện / consumable
///     để chuyển hoá thành level up cost (Phase 26.3+ feature).
///   - `equippedSlot` nullable enum MethodEquipSlot (`QI_MAIN` |
///     `BODY_MAIN` | `SUPPORT` | `SECT` | `SPECIAL`) — chỉ 1 method
///     mỗi slot per character (xem index unique partial bên dưới).
///   - `methodSource` (rename của `source` cũ để rõ nghĩa "method
///     source" vs "row source") forward-compat — vẫn map String.
///
/// `learn(...)` rely on `@@unique([characterId, methodKey])` để đảm bảo
/// idempotency (P2002 → return existing). `equip(slot)` set `equippedSlot`
/// trên row tương ứng. Để giữ tương thích Phase 11.1.B legacy code,
/// `Character.equippedCultivationMethodKey` MIRROR slot QI_MAIN sau khi
/// equip (xem CultivationMethodV2Service).
model CharacterCultivationMethod {
  id          String    @id @default(cuid())
  characterId String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  /// Khoá tham chiếu `CULTIVATION_METHODS` (legacy) hoặc
  /// `CULTIVATION_METHODS_V2` (Phase 26.3) trong shared.
  methodKey   String
  /// Nguồn học method: `starter` | `dungeon_drop` | `boss_drop` |
  /// `sect_shop` | `event` | `quest_milestone` | `admin_grant` |
  /// `fragment_combine` (Phase 26.3). Khớp với `MethodSource` enum
  /// nhưng String để forward-compat.
  source      String
  learnedAt   DateTime  @default(now())

  // Phase 26.3 — progression V2 fields.
  level        Int      @default(1)
  star         Int      @default(0)
  methodExp    BigInt   @default(0)
  /// Slot equipped: `QI_MAIN` | `BODY_MAIN` | `SUPPORT` | `SECT` |
  /// `SPECIAL`. Null = chưa equip. Constraint mỗi (characterId, slot)
  /// chỉ 1 row (xem `@@unique` partial index migration tay sau khi
  /// generate).
  equippedSlot String?
  updatedAt    DateTime @default(now()) @updatedAt

  @@unique([characterId, methodKey])
  @@index([characterId])
  @@index([characterId, equippedSlot])
}

/// Phase 26.3 — log từng lần upgrade/star-up method để audit/replay.
/// Một row mỗi attempt (success hoặc fail). Materials JSON snapshot
/// vật phẩm/linhThach đã consume hoặc dự kiến consume.
model MethodUpgradeLog {
  id            String    @id @default(cuid())
  characterId   String
  character     Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  methodKey     String
  /// `'UPGRADE'` (level up) | `'STAR_UP'` (sao up) | `'UNLOCK'`.
  action        String
  fromLevel     Int
  toLevel       Int
  fromStar      Int
  toStar        Int
  success       Boolean
  /// JSON snapshot vật phẩm/linhThach đã consume:
  ///   `{ items: [{key,qty}], linhThach: number }`
  materialsJson Json
  /// JSON snapshot bonus mới (sau khi success) hoặc lỗi (nếu fail).
  resultJson    Json?
  createdAt     DateTime  @default(now())

  @@index([characterId, methodKey])
  @@index([characterId, createdAt])
}

/// Phase 26.4 — Pháp bảo V2 instance (1 row per artifact owned).
/// Sống song song với hệ pháp bảo cũ (Phase 23.5/23.7 dùng `InventoryItem`
/// slot ARTIFACT_1..3). Slot V2 mới (MAIN/DEFENSE/SUPPORT/ALCHEMY/SPECIAL
/// đuôi `_ARTIFACT_V2`) lưu vào `equippedSlot` dạng String.
///
/// Stats / substats / skills snapshot vào JSONB để combat snapshot không
/// phải JOIN catalog tại runtime; chỉ cần lookup ArtifactDef khi craft /
/// upgrade / refine / awaken (server-authoritative).
///
/// Partial unique `(characterId, equippedSlot)` chỉ áp dụng khi
/// `equippedSlot` IS NOT NULL — implement qua raw SQL trong migration
/// 20261230000000_phase_26_4_artifact_crafting_v2 (Prisma không hỗ trợ
/// partial unique trực tiếp; index thường thay thế).
model CharacterArtifactV2 {
  id           String    @id @default(cuid())
  characterId  String
  character    Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  artifactKey  String
  name         String
  /// `ArtifactType` (FLYING_SWORD | CAULDRON | BELL | SEAL | BANNER |
  /// MIRROR | PEARL | ARMOR | RING | GOURD).
  type         String
  /// `ArtifactElement` (kim/moc/thuy/hoa/tho/NONE/MIXED/HON_NGUYEN).
  element      String
  tier         Int
  /// `ArtifactGrade` (HA_PHAM | TRUNG_PHAM | THUONG_PHAM | CUC_PHAM |
  /// LINH_VAN | DAO_VAN).
  grade        String
  level        Int       @default(1)
  star         Int       @default(0)
  refineLevel  Int       @default(0)
  awakenLevel  Int       @default(0)
  spiritExp    BigInt    @default(0)
  spiritLevel  Int       @default(0)
  locked       Boolean   @default(false)
  /// `ArtifactEquipSlot` (`MAIN_ARTIFACT_V2` | … | `SPECIAL_ARTIFACT_V2`)
  /// hoặc NULL nếu chưa equip.
  equippedSlot String?
  /// Snapshot stat đã clamp (atk/def/hp/mp/spirit + % bonuses) dạng
  /// `ArtifactStatBlock` JSON.
  statsJson    Json
  /// Snapshot substats: `Array<{ key, value }>`.
  subStatsJson Json?
  /// Snapshot skill keys đã awaken: `Array<string>`.
  skillsJson   Json?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([characterId])
  @@index([characterId, artifactKey])
  @@index([characterId, equippedSlot])
}

/// Phase 26.4 — log từng craft attempt pháp bảo V2 (success hoặc fail).
/// Server-authoritative; mỗi attempt 1 row, materials JSON snapshot
/// nguyên liệu/linhThach đã consume (kể cả khi fail). Hỗ trợ replay
/// + audit anti-cheat + dashboard balance.
model ArtifactCraftAttemptLog {
  id                String    @id @default(cuid())
  characterId       String
  character         Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  blueprintKey      String
  success           Boolean
  successRate       Float
  rollValue         Float
  artifactKey       String?
  artifactTier      Int
  artifactGrade     String?
  /// `{ items: [{ key, qty }], linhThach: number }`.
  materialsJson     Json
  linhThachConsumed Int       @default(0)
  createdAt         DateTime  @default(now())

  @@index([characterId])
  @@index([characterId, createdAt])
}

/// Phase 26.4 — log từng level / star-up / refine / awaken / spirit
/// pháp bảo V2 (success hoặc fail). Một row mỗi attempt.
model ArtifactUpgradeLogV2 {
  id              String    @id @default(cuid())
  characterId     String
  character       Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  artifactId      String
  /// `'UPGRADE'` (level up) | `'STAR_UP'` | `'REFINE'` | `'AWAKEN'` |
  /// `'SPIRIT_FEED'`.
  action          String
  fromLevel       Int?
  toLevel         Int?
  fromStar        Int?
  toStar          Int?
  fromRefineLevel Int?
  toRefineLevel   Int?
  fromAwakenLevel Int?
  toAwakenLevel   Int?
  success         Boolean
  /// `{ items: [{ key, qty }], linhThach: number }`.
  materialsJson   Json
  createdAt       DateTime  @default(now())

  @@index([characterId])
  @@index([characterId, artifactId])
  @@index([characterId, createdAt])
}

/// Phase 11.2.B — Skill mastery progression. Mỗi cặp (characterId, skillKey)
/// duy nhất 1 row. `learn()` rely on `@@unique` cho idempotency (P2002 →
/// return existing). `upgradeMastery()` increment `masteryLevel` + deduct
/// LinhThach via CurrencyLedger. `equip()` toggle `isEquipped` (cap số skill
/// active đồng thời). Combat runtime đọc row này để compose
/// `applyMasteryEffect(template, masteryLevel, baseSkill)` thay vì dùng
/// SkillDef thô. Legacy character (không row) → masteryLevel=0 → hành vi
/// identical baseline pre-11.2.B.
model CharacterSkill {
  id           String    @id @default(cuid())
  characterId  String
  character    Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  /// Khoá tham chiếu `SKILLS` trong `packages/shared/src/combat.ts` + `SKILL_TEMPLATES`
  /// trong `packages/shared/src/skill-templates.ts` (1-1 mapping).
  skillKey     String
  /// Level mastery hiện tại — 1 sau khi `learn`, increment bởi
  /// `upgradeMastery`, clamp tới `SKILL_TIER_DEFS[tier].maxMastery`.
  masteryLevel Int       @default(1)
  /// Skill có đang được trang bị (active slot) hay không. Cap MVP = 4 active
  /// đồng thời (kiểm tra trong service `equip`).
  isEquipped   Boolean   @default(false)
  /// Nguồn học skill: `starter` (basic_attack auto-grant) | `realm_unlock`
  /// (đột phá tự động học skill mở khi đạt realm) | `sect_shop` | `quest_milestone`
  /// | `boss_drop` | `event` | `admin_grant`.
  source       String
  learnedAt    DateTime  @default(now())

  @@unique([characterId, skillKey])
  @@index([characterId])
  @@index([characterId, isEquipped])
}

/// Phase 11.6.B — Audit log cho mỗi attempt Tribulation/Tâm Ma.
/// Server-authoritative deterministic kiếp:
///   - `tribulationKey` ref `TRIBULATIONS` trong `packages/shared/src/tribulation.ts`.
///   - `fromRealmKey`/`toRealmKey` snapshot (catalog có thể đổi sau).
///   - `success` true → realm đã advance + reward đã grant qua `CurrencyLedger.TRIBULATION_REWARD`.
///   - `success` false → `expLoss` áp dụng (`computeTribulationFailurePenalty`),
///     `cooldownAt` set vào `Character.tribulationCooldownAt`, optional Tâm Ma
///     debuff (`taoMaActive=true` + `taoMaExpiresAt`).
///   - `taoMaRoll` = RNG snapshot cho replay determinism.
///   - `attemptIndex` = thứ tự attempt cho transition này (1..N).
/// Idempotency: KHÔNG có natural unique key — caller phải debounce. Mỗi attempt
/// = 1 row mới (audit replay). Wipe cascade khi character xoá.
model TribulationAttemptLog {
  id              String    @id @default(cuid())
  characterId     String
  character       Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  tribulationKey  String
  fromRealmKey    String
  toRealmKey      String
  /// `TribulationSeverity` ∈ {minor, major, heavenly, saint}.
  severity        String
  /// `TribulationType` ∈ {lei, phong, bang, hoa, tam}.
  type            String
  success         Boolean
  wavesCompleted  Int
  totalDamage     Int
  finalHp         Int
  hpInitial       Int
  /// EXP snapshot trước attempt (BigInt, có thể vượt Number.MAX_SAFE_INTEGER).
  expBefore       BigInt
  /// EXP sau attempt — success: `expBefore - cost(stage9) + bonus`; fail:
  /// `computeTribulationFailurePenalty(...).expAfter`.
  expAfter        BigInt
  /// Nếu fail: `expBefore - expAfter`. Nếu success: 0 (không loss).
  expLoss         BigInt    @default(0)
  /// Tâm Ma debuff trigger (chỉ khi fail + RNG roll trúng).
  taoMaActive     Boolean   @default(false)
  taoMaExpiresAt  DateTime?
  /// Cooldown gate cho retry (chỉ khi fail).
  cooldownAt      DateTime?
  /// Reward — chỉ set khi success.
  linhThachReward Int       @default(0)
  expBonusReward  BigInt    @default(0)
  titleKeyReward  String?
  attemptIndex    Int
  /// RNG roll [0,1] cho `taoMaDebuffChance` check; persist cho replay.
  taoMaRoll       Float
  createdAt       DateTime  @default(now())

  @@index([characterId, createdAt])
  @@index([tribulationKey, createdAt])
}

/// Phase 26.0 — audit log cho mỗi lần đột phá Luyện Thể.
/// Lưu snapshot requirement/material/pill đã dùng để replay cân bằng và
/// điều tra race/abuse. FK cascade khi character bị xoá.
model BodyBreakthroughAttemptLog {
  id               String    @id @default(cuid())
  characterId      String
  character        Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  fromBodyRealmKey String
  fromBodyStage    Int
  toBodyRealmKey   String
  toBodyStage      Int
  success          Boolean
  successRate      Float
  materialsJson    Json      @default("[]")
  pillItemKey      String?
  injuryUntil      DateTime?
  createdAt        DateTime  @default(now())

  @@index([characterId, createdAt])
}

model AlchemyAttemptLog {
  id                String   @id @default(cuid())
  characterId       String
  recipeKey         String
  recipeTier        Int
  recipeCategory    String
  success           Boolean
  successRate       Float
  rollValue         Float
  pillGrade         String?
  outputItem        String?
  outputQty         Int
  inputsJson        Json
  linhThachConsumed Int
  alchemyExpGained  BigInt   @default(0)
  createdAt         DateTime @default(now())

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@index([characterId, createdAt])
  @@index([recipeKey, createdAt])
}

/// Phase 14.3.D — Tribulation Encounter session (mini-encounter trước khi
/// resolve thành 1 `TribulationAttemptLog`). 2-phase commit:
///   - `start` → tạo row state='pending' với `selectedSupportItemKeys`
///     snapshot (FE đã commit lựa chọn item hỗ trợ).
///   - `resolve` → server-authoritative simulate + consume item + atomic
///     update character / currency / log. Set state='resolved' +
///     `resolvedAttemptLogId` pointer, idempotent gọi lại không double
///     breakthrough.
///
/// Tại 1 thời điểm character chỉ có 1 row state='pending' (enforced bởi
/// service layer). State machine:
///   pending → resolved (terminal)
///   pending → cancelled (player abort, future PR)
///
/// **Quan trọng**: row này KHÔNG thay thế `TribulationAttemptLog` — log
/// vẫn được tạo trong resolve (1:1 mapping qua `resolvedAttemptLogId`).
/// Encounter row chỉ là session state cho 2-phase UX.
model TribulationEncounter {
  id                      String    @id @default(cuid())
  characterId             String
  character               Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  tribulationKey          String
  fromRealmKey            String
  toRealmKey              String
  /// Encounter catalog key (`tribulation_encounter_<element>`).
  encounterKey            String
  /// `TribulationEncounterEffectType` ∈ {BURST, SUSTAIN, POISON_RECOVERY,
  /// ARMOR_CRIT, DEFENSE_ENDURANCE}.
  effectType              String
  /// `ElementKey` ∈ {kim, moc, thuy, hoa, tho}.
  element                 String
  /// `TribulationEncounterDifficulty` (alias `TribulationSeverity`).
  difficulty              String
  /// Snapshot list các item key player chọn lúc start. Empty nếu không
  /// chọn item hỗ trợ. Resolve sẽ recalc support từ list này (server-side).
  selectedSupportItemKeys String[]
  /// State machine: 'pending' (started, chưa resolve) | 'resolved' (đã
  /// resolve thành 1 attempt log) | 'cancelled' (future, chưa dùng).
  state                   String    @default("pending")
  startedAt               DateTime  @default(now())
  resolvedAt              DateTime?
  /// Pointer 1:1 sang `TribulationAttemptLog` khi đã resolved. NULL khi
  /// state='pending'.
  resolvedAttemptLogId    String?

  @@index([characterId, state])
  @@index([characterId, startedAt])
}

/// Phase 14.3.E.1 — Tribulation Mini-Battle (turn-based runtime). Layer mới
/// trên top encounter row (Phase 14.3.D). Khác `TribulationEncounter`:
///   - Encounter = 2-phase commit pre-RNG (start → resolve = 1-shot snapshot).
///   - MiniBattle = state machine ACTIVE per-turn, mỗi action 1 phase.
///
/// State machine:
///   PENDING → ACTIVE (sau action đầu tiên)
///   ACTIVE → RESOLVED (player win: trib HP = 0 hoặc qua đủ phase)
///   ACTIVE → FAILED (player HP = 0)
///   * → EXPIRED (server cleanup nếu inactive lâu — future PR)
///
/// Race-safety:
///   - Service-level guard: chỉ 1 row state ∈ {PENDING, ACTIVE} per character
///     (check trong transaction trước khi insert/update).
///   - `clientNonce` (optional) idempotent dedupe — nếu repo có pattern
///     persist nonce thì service so sánh `lastClientNonce` field.
///
/// Persistence:
///   - `actionLogJson`: serialized array `TribulationBattleEvent[]`
///     append-only sau mỗi action.
///   - `resultJson`: snapshot `TribulationMiniBattleSummary` khi terminal
///     (RESOLVED/FAILED). NULL khi đang ACTIVE.
///   - `seed`: deterministic RNG seed (32-bit signed) — composer ở
///     `composeBattlePhaseSeed(seed, phase)`.
model TribulationMiniBattle {
  id               String    @id @default(cuid())
  characterId      String
  character        Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  /// Pointer optional sang `TribulationEncounter.id` nếu battle hatched
  /// từ encounter session. NULL nếu standalone (rare).
  encounterId      String?
  /// Mirror `TribulationDef.key` (catalog).
  tribulationKey   String
  realmKey         String
  /// `TribulationEncounterEffectType` ∈ {BURST, SUSTAIN, POISON_RECOVERY,
  /// ARMOR_CRIT, DEFENSE_ENDURANCE}.
  effectType       String
  /// `ElementKey` ∈ {kim, moc, thuy, hoa, tho}.
  element          String
  /// `TribulationSeverity` ∈ {minor, major, heavenly, saint}.
  difficulty       String
  /// `TribulationMiniBattleState` ∈ {PENDING, ACTIVE, RESOLVED, FAILED, EXPIRED}.
  state            String    @default("PENDING")
  currentPhase     Int       @default(1)
  phaseCount       Int
  playerHp         Int
  playerHpMax      Int
  tribulationHp    Int
  tribulationHpMax Int
  shield           Int       @default(0)
  dotStacks        Int       @default(0)
  focusCharge      Int       @default(0)
  /// Deterministic seed cho replay/test.
  seed             Int
  /// Append-only log `TribulationBattleEvent[]` JSON.
  actionLogJson    Json      @default("[]")
  /// Set khi terminal — `TribulationMiniBattleSummary` JSON shape.
  resultJson       Json?
  /// Last client-supplied nonce (optional) cho idempotency replay.
  lastClientNonce  String?
  startedAt        DateTime  @default(now())
  resolvedAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([characterId, state])
  @@index([characterId, startedAt])
  @@index([encounterId])
}

/// Phase 11 nâng cao §5 PR2 prep — audit log mỗi lần đột phá (success + fail).
///
/// Khác `TribulationAttemptLog` (vượt kiếp = realm transition gate, severity
/// theo realm boundary): `BreakthroughAttemptLog` cover stage transition +
/// realm cross thường ngày khi `realmStage=9 + đủ exp`. Mỗi attempt = 1 row
/// (audit replay determinism qua `rngRoll` snapshot).
///
/// Schema design intent:
///   - `chance` + 4 layer breakdown (`baseChance`, `rootPurityBonus`,
///     `methodAffinityBonus`, `itemBonus`) — match `BreakthroughChanceBreakdown`
///     từ `packages/shared/src/breakthrough-chance.ts`. `rawChance` = sum
///     trước clamp; `chance` = `finalChance` clamp `[MIN, MAX]`.
///   - `rngRoll ∈ [0, 1)` — server-resolved (deterministic seed-by-attemptId
///     hoặc `Math.random` runtime); compare với `chance` → `success`.
///   - `success=true` → realm/stage advance, `expAfter = expBefore - cost`.
///     `success=false` → realm giữ nguyên, `expAfter = expBefore` (no loss
///     ở MVP — closed-beta không nên trừ EXP nặng), `tamMaActive=true`,
///     `tamMaExpiresAt = now + BREAKTHROUGH_FAIL_DEBUFF_DURATION_SEC`.
///   - `idempotencyKey` (optional) — caller-provided UUID để debounce double
///     submit. Postgres treats NULL distinct → unique constraint chỉ enforce
///     khi caller pass key. Khuyến nghị format: `<userId>:<attemptIndex>`.
///   - `attemptIndex` — thứ tự attempt cho character này (1..N), audit replay.
///
/// Forward-compat: model TỒN TẠI nhưng CharacterService.breakthrough() chưa
/// log/tạo row (Phase 11 nâng cao §5 PR2 wire sẽ INSERT mỗi attempt). Idle
/// table = no-op cho production runtime hiện tại.
///
/// Idempotency: Caller debounce qua `idempotencyKey`. Wipe cascade khi
/// character xoá.
model BreakthroughAttemptLog {
  id                  String    @id @default(cuid())
  characterId         String
  character           Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  /// Realm key trước attempt (vd `kim_dan`). Audit cross-realm transition.
  fromRealmKey        String
  /// Realm stage trước attempt (luôn = 9 ở MVP — peak gate enforce).
  fromRealmStage      Int
  /// Realm key sau attempt — `success`: next realm key. `fail`: same as `fromRealmKey`.
  toRealmKey          String
  /// Realm stage sau attempt — `success`: 1 (next realm fresh). `fail`: 9.
  toRealmStage        Int
  /// Final chance clamp `[BREAKTHROUGH_CHANCE_MIN, BREAKTHROUGH_CHANCE_MAX]` (display + audit).
  chance              Float
  /// Layer 1 baseline (`BREAKTHROUGH_CHANCE_BASE`).
  baseChance          Float
  /// Layer 2 bonus từ root purity (`purity * BREAKTHROUGH_ROOT_PURITY_BONUS_MAX`).
  rootPurityBonus     Float
  /// Layer 3 bonus từ method element affinity (primary / secondary / no-match).
  methodAffinityBonus Float
  /// Layer 4 aggregated item/pill/buff bonus (caller dồn trước, clamp `[0, MAX]`).
  itemBonus           Float
  /// Sum 4 layer trước clamp — audit transparency (debug "vì sao bonus thiếu").
  rawChance           Float
  /// RNG roll `[0, 1)` so sánh với `chance`. Persist cho replay determinism.
  rngRoll             Float
  /// Result.
  success             Boolean
  /// EXP snapshot trước attempt (BigInt — có thể vượt Number.MAX_SAFE_INTEGER).
  expBefore           BigInt
  /// EXP sau attempt — `success`: `expBefore - cost`. `fail`: `expBefore` (no loss MVP).
  expAfter            BigInt
  /// Tâm Ma debuff trigger (chỉ khi `success=false` — mọi fail đều apply ở MVP).
  /// Wire qua `BuffService.applyBuff('tam_ma_light', 'breakthrough')` ở PR2 wire.
  tamMaActive         Boolean   @default(false)
  /// `now + BREAKTHROUGH_FAIL_DEBUFF_DURATION_SEC × 1000`. Null nếu không apply.
  tamMaExpiresAt      DateTime?
  /// Optional caller-provided idempotency key (format `<userId>:<attemptIndex>`).
  idempotencyKey      String?
  /// Thứ tự attempt cho character này (1..N) — audit replay.
  attemptIndex        Int
  createdAt           DateTime  @default(now())

  @@unique([characterId, idempotencyKey])
  @@index([characterId, createdAt])
  @@index([characterId, success])
}

/// Phase 11.8.B Buff MVP — duration-based buff/debuff persistence.
/// 1 row per (`characterId`, `buffKey`). `BuffService.applyBuff` dùng upsert:
///   - non-stackable: refresh `expiresAt` (catalog `BuffDef.stackable=false`).
///   - stackable: increment `stacks` capped tại `BuffDef.maxStacks` + refresh
///     `expiresAt`.
/// `BuffService.removeBuff` xóa row explicit. `BuffService.pruneExpired(now)`
/// xóa row có `expiresAt <= now` (cron sweep). `BuffService.listActive(charId,
/// now)` auto-prune trước khi return. `BuffService.getMods(charId, now)` rely
/// vào `composeBuffMods(activeBuffs)` từ `packages/shared/src/buffs.ts`.
///
/// Source ref `BuffSource` ∈ {pill, sect_aura, event, equipment, skill, talent,
/// boss_skill, tribulation}. Không enum để giữ catalog flexible (catalog có
/// thể mở rộng source mới mà không cần migration).
///
/// Wire FUTURE PR (out of scope 11.8.B):
///   - tribulation FAIL Tâm Ma → `applyBuff('debuff_taoma','tribulation')`.
///   - alchemy pill consume → `applyBuff('buff_pill_*', 'pill')`.
///   - skill DOT/CC → applyBuff('debuff_*', 'skill')` trong combat tick.
///   - `composeBuffMods` wire vào `CharacterStatService.computeStats` để stat
///     mod (atk/def/hpMax/mpMax/spirit) áp dụng vào combat + cultivation tick.
model CharacterBuff {
  id          String    @id @default(cuid())
  characterId String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  /// Khoá tham chiếu `BUFFS` trong `packages/shared/src/buffs.ts`.
  buffKey     String
  /// Stack count hiện tại (1..`def.maxStacks`). Non-stackable luôn = 1.
  stacks      Int       @default(1)
  /// `BuffSource` snapshot — audit nguồn gốc (catalog có thể đổi sau).
  source      String
  expiresAt   DateTime
  createdAt   DateTime  @default(now())

  @@unique([characterId, buffKey])
  @@index([expiresAt])
  @@index([characterId, expiresAt])
}

/// Phase 11.7.B Talent (Thần Thông) MVP — passive/active talent persistence.
/// 1 row per (`characterId`, `talentKey`); composite UNIQUE đảm bảo mỗi
/// character học mỗi talent tối đa 1 lần. Talent point budget tính từ realm
/// order qua `computeTalentPointBudget(currentRealmOrder)` (3 realm = 1 điểm
/// ngộ đạo); spent points = sum `talentPointCost` of learned rows.
///
/// Wire FUTURE PR (out of scope 11.7.B):
///   - `composePassiveTalentMods` vào `CharacterStatService.computeStats`
///     → atk/def/hpMax/mpMax/spirit + drop/exp multiplier + element damage_bonus.
///   - Active talent ("thần thông") execution `useActiveTalent` qua mp
///     consume + cooldown turns enforce trong combat tick (Phase 11.7.C).
model CharacterTalent {
  id                     String    @id @default(cuid())
  characterId            String
  character              Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  /// Khoá tham chiếu `TALENTS` trong `packages/shared/src/talents.ts`.
  talentKey              String
  learnedAt              DateTime  @default(now())
  /// Phase 11.7.E — số lượt cooldown còn lại của active talent. 0 = sẵn sàng
  /// cast. Sau khi cast thành công trong combat, set =
  /// `talent.activeEffect.cooldownTurns`. Mỗi action combat tiếp theo
  /// (skill flow + active talent flow) decrement -1 cho tất cả row > 0.
  /// Passive talent luôn 0 (không cast nên không tick).
  cooldownTurnsRemaining Int       @default(0)

  @@unique([characterId, talentKey])
  @@index([characterId, learnedAt])
}

/// Phase 11.9.B Title (Danh hiệu) MVP — title ownership persistence.
/// 1 row per (`characterId`, `titleKey`); composite UNIQUE đảm bảo idempotent
/// `unlockTitle`. `Character.title String?` đã tồn tại từ phase 0 — đó là
/// field "equipped title" (chỉ 1 title slot tại 1 thời điểm). Bảng này
/// persist **danh sách title đã unlock** cho character; `equipTitle` validate
/// ownership từ bảng này trước khi set `Character.title`.
///
/// `source` là `TitleSource` snapshot ('realm_milestone' | 'achievement' |
/// 'sect_rank' | 'event' | 'donation' | 'element_mastery'). Catalog có thể
/// đổi sau nên không enum.
///
/// Wire FUTURE PR (out of scope 11.9.B):
///   - auto-grant trên realm breakthrough → `unlockTitle('realm_*', 'realm_milestone')`.
///   - auto-grant trên achievement complete → `unlockTitle(..., 'achievement')`.
///   - `composeTitleMods([equipped])` wire vào `CharacterStatService.computeStats`
///     cho flavor stat bonus (rare ≤ +2%, mythic ≤ +15%).
model CharacterTitleUnlock {
  id          String    @id @default(cuid())
  characterId String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  /// Khoá tham chiếu `TITLES` trong `packages/shared/src/titles.ts`.
  titleKey    String
  /// `TitleSource` snapshot — audit nguồn unlock.
  source      String
  unlockedAt  DateTime  @default(now())

  @@unique([characterId, titleKey])
  @@index([characterId, unlockedAt])
}

/// Phase 11.10.B Achievement (Thành Tựu) MVP — progress + completion
/// persistence (no reward claim — defer to Phase 11.10.C).
///
/// 1 row per (`characterId`, `achievementKey`); composite UNIQUE đảm bảo
/// idempotent progress upsert. `completedAt` set một lần khi `progress >=
/// def.goalAmount`, không bao giờ unset (achievement permanent).
///
/// `progress` capped tại `def.goalAmount` (service-side enforce — schema
/// không có CHECK constraint vì goalAmount đến từ catalog runtime).
///
/// Phase 11.10.C-1 (PR-pending) thêm `claimedAt DateTime?` + index để
/// `claimReward(charId, achievementKey)` atomic grant via CurrencyService.applyTx
/// (LINH_THACH/TIEN_NGOC reason='ACHIEVEMENT_REWARD') + tx.character.update
/// (exp) + auto-unlock title qua TitleService.unlockTitleTx
/// (`titleForAchievement(achievementKey)`).
///
/// Wire FUTURE PR (out of scope 11.10.C-1):
///   - Event listener wire vào combat/dungeon/breakthrough/cultivate/market
///     /chat/sect cho mỗi `goalKind` để auto-call `incrementProgress` (Phase
///     11.10.C-2).
///   - Item rewards (`def.reward.items`) — defer khi catalog cần (current 32
///     baseline không có items); sẽ cần extract AchievementModule + ItemLedger
///     reason='ACHIEVEMENT_REWARD' để tránh circular dep CharacterModule ↔
///     InventoryModule (Phase 11.10.D).
model CharacterAchievement {
  id             String    @id @default(cuid())
  characterId    String
  character      Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  /// Khoá tham chiếu `ACHIEVEMENTS` trong `packages/shared/src/achievements.ts`.
  achievementKey String
  /// Cumulative progress amount (0..`def.goalAmount`).
  progress       Int       @default(0)
  /// Set một lần khi `progress >= def.goalAmount`. Không bao giờ unset.
  completedAt    DateTime?
  /// Phase 11.10.C-1: set một lần khi player claim reward (linhThach/tienNgoc
  /// /exp/title qua `claimReward`). CAS guard `where { id, claimedAt: null }`
  /// đảm bảo idempotent — concurrent call chỉ có 1 winner. Không bao giờ unset.
  claimedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([characterId, achievementKey])
  @@index([characterId, completedAt])
  @@index([characterId, claimedAt])
}

model CharacterReputation {
  id              String    @id @default(cuid())
  characterId     String
  character       Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  reputationGroup String
  score           Int       @default(0)
  dailyGain       Int       @default(0)
  dailyKey        String?
  lastGainedAt    DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([characterId, reputationGroup])
  @@index([characterId, score])
  @@index([reputationGroup, score])
}

model CharacterLongTermGoal {
  id          String    @id @default(cuid())
  characterId String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  goalKey     String
  progress    Int       @default(0)
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([characterId, goalKey])
  @@index([characterId, completedAt])
}

/// Phase 12.10.A — NPC Affinity & Relationship Foundation.
///
/// Mỗi cặp `(characterId, npcKey)` duy nhất 1 row (composite UNIQUE) — `score`
/// mutate atomic qua `NpcAffinityService.addAffinityTx()`:
///   - upsert lazy: row mới được create với `score = NPC_AFFINITY[npcKey].initialScore`
///     khi character lần đầu gain affinity với NPC đó (hoặc service eager
///     `ensureRow`).
///   - atomic add: `update {score: { increment: delta }}` rồi server clamp
///     `[minScore, maxScore]` (catalog `NpcAffinityDef`).
///   - idempotency: caller (StoryDialogueService.applyChoice) wrap trong cùng
///     `$transaction` với mark_seen + grant effects → re-pick choice cùng
///     node đã `seen` throw `ALREADY_APPLIED` (mirror `give_reward`).
///
/// `npcKey` reference `NPCS[].key` (catalog tĩnh ở `packages/shared/src/npcs.ts`).
/// KHÔNG FK ra Sect/NPC table (NPC là catalog, không có DB row riêng).
///
/// Phase tiếp (12.10.B+) sẽ thêm `CharacterNpcGiftLog` (nguồn gain affinity
/// thứ 2) + `CharacterNpcRelationFlag` (rival/friend mutex) — pattern giữ nguyên.
model CharacterNpcAffinity {
  id          String    @id @default(cuid())
  characterId String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  /// Reference `NPCS[].key` (catalog) — KHÔNG FK (NPC là catalog tĩnh).
  npcKey      String
  /// Điểm thân thiện hiện tại — clamp `[minScore, maxScore]` của catalog
  /// `NPC_AFFINITY[npcKey]`. Default mirror `initialScore` (thường 0).
  score       Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([characterId, npcKey])
  @@index([characterId])
}

/// Phase 12.10.B — NPC gift audit log + daily limit enforcement.
///
/// Mỗi gift / NPC / character ghi 1 row. Service `NpcAffinityService.giftNpcTx`
/// count rows trong cùng UTC day cho `(characterId, npcKey, dayBucket)` để
/// enforce `dailyLimit` của catalog `NPC_GIFT_PREFERENCES[npcKey]`.
///
/// `dayBucket`: ISO date `YYYY-MM-DD` (UTC). Composite UNIQUE
/// `(characterId, npcKey, dayBucket, sequence)` cho phép multi-gift / day
/// (sequence 1..dailyLimit) nhưng vẫn unique-per-row cho idempotency CAS
/// (gift submit retry với cùng `clientNonce` không double).
///
/// Audit fields:
/// - `itemKey`: item đã consume (reference `ITEMS[]` catalog).
/// - `affinityDelta`: delta affinity đã apply (mirror `addAffinityTx` result).
/// - `previousScore`/`newScore`: snapshot trước/sau apply (clamped).
///
/// `Quest` reward affinity (Phase 12.10.B integration) KHÔNG ghi vào table này
/// — chỉ dùng cho gift path. Quest dùng `QuestProgress.claimedAt` CAS guard +
/// `addAffinityTx` (atomic cùng claim transaction).
model CharacterNpcGiftLog {
  id            String    @id @default(cuid())
  characterId   String
  character     Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  /// Reference `NPCS[].key` (catalog) — KHÔNG FK.
  npcKey        String
  /// Reference `ITEMS[].key` (catalog) — KHÔNG FK.
  itemKey       String
  /// Delta affinity đã apply (catalog `NPC_GIFT_PREFERENCES[npcKey].acceptedItems[].affinityMin..Max`).
  affinityDelta Int
  /// Score affinity trước khi apply gift (post-lazy-create initialScore).
  previousScore Int
  /// Score affinity sau khi apply gift (clamped `[minScore, maxScore]`).
  newScore      Int
  /// ISO `YYYY-MM-DD` UTC — daily bucket cho rate limit count.
  dayBucket     String
  /// Sequence trong ngày (1..dailyLimit). Composite UNIQUE giúp service
  /// CAS-style insert: nếu (char,npc,day,seq) đã tồn tại → race với gift
  /// concurrent → retry seq+1.
  sequence      Int
  createdAt     DateTime  @default(now())

  @@unique([characterId, npcKey, dayBucket, sequence])
  @@index([characterId, npcKey, dayBucket])
  @@index([characterId, dayBucket])
}

enum MissionPeriod {
  DAILY
  WEEKLY
  ONCE
}

/// Tiến độ nhiệm vụ của từng character theo catalog tĩnh (`packages/shared/src/missions.ts`).
/// Mỗi (character, missionKey) có 1 hàng; cron reset sẽ đưa `currentAmount=0`,
/// `claimed=false`, cập nhật `windowEnd` cho DAILY/WEEKLY. Mission `ONCE` không reset.
model MissionProgress {
  id            String        @id @default(cuid())
  characterId   String
  character     Character     @relation(fields: [characterId], references: [id], onDelete: Cascade)
  missionKey    String
  period        MissionPeriod
  currentAmount Int           @default(0)
  goalAmount    Int
  claimed       Boolean       @default(false)
  claimedAt     DateTime?
  startedAt     DateTime      @default(now())
  /// Mốc cuối của cửa sổ hiện tại (DAILY/WEEKLY). null với ONCE.
  windowEnd     DateTime?
  updatedAt     DateTime      @updatedAt

  @@unique([characterId, missionKey])
  @@index([characterId, claimed])
  @@index([period, windowEnd])
}

/// Phase 12 Story PR-2 — quest runtime persistence.
///
/// Catalog (`packages/shared/src/quests.ts`) là static; mỗi character có
/// max 1 row per `questKey`. Status flow:
///   - LOCKED       — `Character.realmStage` chưa đủ `requiredRealmOrder`
///                    hoặc prerequisite quest chưa CLAIMED. Hidden khỏi UI list.
///   - AVAILABLE    — đã thoả gate, sẵn sàng nhận. Lazy-create on `list`.
///   - ACCEPTED     — player đã accept; track step progress.
///   - COMPLETED    — tất cả step đạt `count`. Chờ Phase 12 PR-3 `claim`.
///   - CLAIMED      — Phase 12 PR-3 sẽ set sau khi reward đi qua
///                    `RewardLedger` idempotency `(characterId, QUEST_CLAIM, questKey)`.
///
/// `stepProgress` là JSON map `{ <stepId>: <currentCount> }` — server-authoritative,
/// FE KHÔNG được tự cộng. Service chỉ cộng qua `progress()` (talk/explore/choice
/// endpoint) hoặc `track()` (kill/collect hook từ CombatService/InventoryService).
///
/// Idempotency: `accept` dùng `where { id, status: AVAILABLE }` CAS guard chống
/// double-accept; `progress` step kind kill dùng atomic `updateMany` với
/// `currentAmount` guard chống concurrent kill increment double-count.
model QuestProgress {
  id           String    @id @default(cuid())
  characterId  String
  character    Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  questKey     String
  /// LOCKED | AVAILABLE | ACCEPTED | COMPLETED | CLAIMED.
  status       String    @default("AVAILABLE")
  /// Map `{ <stepId>: <currentCount> }`. Default `{}`. Khi `status='ACCEPTED'`
  /// mọi step bắt đầu ở 0; service tự cộng tới `step.count` rồi chuyển COMPLETED.
  stepProgress Json      @default("{}")
  acceptedAt   DateTime?
  completedAt  DateTime?
  claimedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([characterId, questKey])
  @@index([characterId, status])
  @@index([status, completedAt])
}

model Mail {
  id               String    @id @default(cuid())
  recipientId      String
  recipient        Character @relation(fields: [recipientId], references: [id], onDelete: Cascade)
  senderName       String    @default("Thiên Đạo Sứ Giả")
  subject          String
  body             String
  rewardLinhThach  BigInt    @default(0)
  rewardTienNgoc   Int       @default(0)
  rewardExp        BigInt    @default(0)
  /// JSON [{ itemKey, qty }]
  rewardItems      Json      @default("[]")
  readAt           DateTime?
  claimedAt        DateTime?
  expiresAt        DateTime?
  /// userId của admin đã gửi (null cho hệ thống / script).
  createdByAdminId String?
  /// Phase 31.0 — taxonomy lý do gửi mail. Mail cũ migrate sang `SYSTEM`.
  mailType         MailType  @default(SYSTEM)
  /// Phase 31.0 — soft delete bởi user (user delete mail trong inbox). Khác
  /// với expire/claim. Mail bị deletedAt KHÔNG hiển thị trong list nhưng vẫn
  /// đếm vào audit (admin có thể xem qua admin route nếu cần).
  deletedAt        DateTime?

  createdAt DateTime @default(now())

  @@index([recipientId, createdAt])
  @@index([recipientId, claimedAt])
  @@index([recipientId, readAt])
  @@index([recipientId, mailType, createdAt])
  @@index([expiresAt])
}

model InventoryItem {
  id                 String     @id @default(cuid())
  characterId        String
  character          Character  @relation(fields: [characterId], references: [id], onDelete: Cascade)
  itemKey            String
  qty                Int        @default(1)
  equippedSlot       EquipSlot?
  /// Phase 11.4.B Gem MVP — danh sách gemKey đã khảm theo thứ tự slot.
  /// Capacity tối đa = `socketCapacityForQuality(item.quality)` (PHAM=0,
  /// LINH=1, HUYEN=2, TIEN=3, THAN=4) enforce ở `GemService.socketGem`
  /// server-authoritative. Item non-equipment / chưa khảm giữ `[]`.
  sockets            String[]   @default([])
  /// Phase 11.5.B Refine MVP — cấp luyện khí 0..15 (`REFINE_MAX_LEVEL`).
  /// Stat multiplier = `getRefineStatMultiplier(refineLevel)` áp dụng lên
  /// `bonuses` + socket bonus của trang bị khi tính `equipBonus()`.
  /// Item non-equipment / chưa luyện giữ `0`. Server-authoritative qua
  /// `RefineService.refineEquipment` (no client mutation).
  refineLevel        Int        @default(0)
  /// Phase 23.7 — Pháp Bảo persisted star level. Meaningful only when
  /// `itemKey ∈ PHAP_BAO_CATALOG`; normal inventory rows keep the harmless
  /// default. Server-authoritative via `PhapBaoService.starUp`.
  phapBaoStarLevel   Int        @default(1)
  /// Phase 23.7 — Pháp Bảo persisted awaken stage. Meaningful only for
  /// Pháp Bảo rows. Server-authoritative via `PhapBaoService.awaken`.
  phapBaoAwakenStage Int        @default(0)
  /// Phase 23.7 — instance lock. Locked rows cannot be consumed/upgraded.
  locked             Boolean    @default(false)
  /// Phase 15.0.A — Equipment Reforge Foundation.
  /// Array of `{ kind, value }` rolled khi reforge (`rollReforgedSubstats`).
  /// kind ∈ {atk,def,hpMax,mpMax,spirit}. Server-authoritative qua
  /// `EquipmentService.reforge` — overwrite toàn bộ slot mỗi reroll.
  /// Empty `[]` cho legacy row + non-equipment.
  substatsJson       Json       @default("[]")
  /// Phase 15.0.A — Equipment Enchant Foundation.
  /// Element key Ngũ Hành (`kim`/`moc`/`thuy`/`hoa`/`tho`). NULL = chưa
  /// enchant. Element được khoá khi `enchantLevel >= 1` — đổi hệ cần PR
  /// future với reset cost. Bonus apply qua `composeEnchantBonus`.
  enchantElement     String?
  /// Phase 15.0.A — Equipment Enchant Level (0..MAX_ENCHANT_LEVEL=5).
  /// 0 = chưa enchant. Server-authoritative qua `EquipmentService.enchant`.
  enchantLevel       Int        @default(0)
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  @@unique([characterId, equippedSlot])
  @@index([characterId, itemKey])
  @@index([characterId, itemKey, phapBaoStarLevel])
}

/// Phase 15.0.A — Equipment Reforge audit history.
/// Mỗi reroll thành công ghi 1 row trong cùng `$transaction` với mutation
/// `InventoryItem.substatsJson` + currency/material consume. KHÔNG idempotent
/// (mỗi reroll = 1 row mới). Caller chịu trách nhiệm debounce / rate-limit.
model EquipmentReforgeHistory {
  id              String    @id @default(cuid())
  characterId     String
  character       Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  /// Soft pointer tới `InventoryItem.id`. KHÔNG có FK vì item có thể bị bán/
  /// transfer ⇒ history audit vẫn giữ row.
  inventoryItemId String
  itemKey         String
  /// Substats trước reroll (snapshot `EquipmentSubstat[]`).
  beforeJson      Json      @default("[]")
  /// Substats sau reroll (snapshot `EquipmentSubstat[]`).
  afterJson       Json      @default("[]")
  /// Cost detail: `{ linhThachCost, materialKey, materialQty }`.
  costJson        Json      @default("{}")
  createdAt       DateTime  @default(now())

  @@index([characterId, createdAt])
  @@index([inventoryItemId, createdAt])
}

/// Phase 15.0.A — Equipment Enchant audit history.
/// Mỗi level-up thành công ghi 1 row. Mỗi row = 1 (element, level) tăng từ
/// `before` sang `after`. Lưu cả `beforeElement`/`afterElement` để track
/// trường hợp chuyển hệ (foundation phase chưa hỗ trợ — reserved cho future).
model EquipmentEnchantHistory {
  id              String    @id @default(cuid())
  characterId     String
  character       Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  inventoryItemId String
  itemKey         String
  beforeElement   String?
  beforeLevel     Int       @default(0)
  afterElement    String?
  afterLevel      Int       @default(0)
  /// Cost detail: `{ linhThachCost, materialKey, materialQty }`.
  costJson        Json      @default("{}")
  createdAt       DateTime  @default(now())

  @@index([characterId, createdAt])
  @@index([inventoryItemId, createdAt])
}

enum ListingStatus {
