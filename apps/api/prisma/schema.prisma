model BossDamage {
  id            String    @id @default(cuid())
  bossId        String
  boss          WorldBoss @relation(fields: [bossId], references: [id], onDelete: Cascade)
  characterId   String
  characterName String
  totalDamage   BigInt    @default(0)
  hits          Int       @default(0)
  lastHitAt     DateTime  @default(now())

  @@unique([bossId, characterId])
  @@index([bossId, totalDamage])
}

enum EncounterStatus {
  ACTIVE
  WON
  LOST
  ABANDONED
}

enum CurrencyKind {
  LINH_THACH
  TIEN_NGOC
}

/// Audit trail mọi mutation của linhThach / tienNgoc (Phase 4-8). Một dòng = một
/// thao tác đổi tiền của 1 character. `delta` có dấu (âm = trừ).
model CurrencyLedger {
  id          String       @id @default(cuid())
  characterId String
  character   Character    @relation(fields: [characterId], references: [id], onDelete: Cascade)
  currency    CurrencyKind
  delta       BigInt
  reason      String
  refType     String?
  refId       String?
  meta        Json         @default("{}")
  /// Nếu thao tác do admin/MOD thực hiện (vd ADMIN_GRANT, ADMIN_TOPUP_APPROVE).
  actorUserId String?
  createdAt   DateTime     @default(now())

  @@index([characterId, createdAt])
  @@index([reason, createdAt])
  @@index([refType, refId])
  @@index([actorUserId, createdAt])
}

model Encounter {
  id          String          @id @default(cuid())
  characterId String
  dungeonKey  String
  status      EncounterStatus @default(ACTIVE)
  /// JSON state: { monsterIndex, monsterHp, lastTurn }
  state       Json            @default("{}")
  /// JSON list of log lines [{ side, text, ts }]
  log         Json            @default("[]")
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([characterId, status])
}

/// Phase 12.2.B — DungeonRun runtime status. Khác `Encounter` (single
/// turn-based monster) — DungeonRun là multi-encounter expedition flow:
/// player call `next` để auto-resolve 1 encounter / lần (kill monster +
/// quest track + advance), khi hết list `monsters` thì status=COMPLETED,
/// claim reward bonus → CLAIMED. ABANDONED = player drop run, slot daily
/// vẫn bị tiêu (anti-grind).
enum DungeonRunStatus {
  ACTIVE
  COMPLETED
  CLAIMED
  ABANDONED
}

/// Phase 12.2.B — DungeonRun runtime persistence (multi-encounter expedition).
/// Khác `Encounter`:
///   - `Encounter` = single turn-based combat (CombatService action loop).
///   - `DungeonRun` = expedition flow auto-resolve mỗi `next()` call.
/// Cùng catalog `DUNGEONS` (shared/combat.ts), cùng dailyLimit accounting
/// (count rows trong cửa sổ DAILY VN tz `startOfLocalDay`), cùng quest kill
/// hook (`QuestService.track('kill','monster',monsterKey)` per encounter).
///
/// Reward claim atomic qua `CurrencyService.applyTx` + `InventoryService
/// .grantTx` + `tx.character.update({ exp })` với `reason='DUNGEON_RUN
/// _REWARD'` + `refType='DungeonRun'` + `refId=runId`. Idempotent qua CAS
/// guard `claimedAt=null` updateMany pattern (mirror QuestService.claim
/// Phase 12 PR-3).
///
/// Indexes:
///   - `[characterId, status]` cho list active run + filter status.
///   - `[characterId, startedAt]` cho dailyLimit count.
///   - `[characterId, templateKey, startedAt]` cho per-dungeon dailyLimit.
model DungeonRun {
  id              String           @id @default(cuid())
  characterId     String
  /// Match `DungeonDef.key` từ shared catalog `DUNGEONS`.
  templateKey     String
  status          DungeonRunStatus @default(ACTIVE)
  /// Index của monster hiện tại trong `dungeon.monsters[]` (0..N).
  /// Khi `encounterIndex == monsters.length` → COMPLETED (claim sẵn sàng).
  encounterIndex  Int              @default(0)
  /// JSON list `[{ monsterKey, killedAt: ISO string }]` — log resolution
  /// tracking, dùng cho debug + Phase 12.5 stats UI.
  killedMonsters  Json             @default("[]")
  startedAt       DateTime         @default(now())
  completedAt     DateTime?
  claimedAt       DateTime?
  updatedAt       DateTime         @updatedAt

  @@index([characterId, status])
  @@index([characterId, startedAt])
  @@index([characterId, templateKey, startedAt])
}

model GiftCode {
  id               String               @id @default(cuid())
  /// Normalized upper-case, unique trên toàn hệ.
  code             String               @unique
  rewardLinhThach  BigInt               @default(0)
  rewardTienNgoc   Int                  @default(0)
  rewardExp        BigInt               @default(0)
  /// JSON [{ itemKey, qty }]
  rewardItems      Json                 @default("[]")
  /// null = không giới hạn số lần redeem toàn server (vẫn chặn 1 user 1 lần).
  maxRedeems       Int?
  redeemCount      Int                  @default(0)
  expiresAt        DateTime?
  revokedAt        DateTime?
  createdByAdminId String?
  createdAt        DateTime             @default(now())
  redemptions      GiftCodeRedemption[]

  @@index([expiresAt])
  @@index([revokedAt])
}

model GiftCodeRedemption {
  id          String   @id @default(cuid())
  giftCodeId  String
  giftCode    GiftCode @relation(fields: [giftCodeId], references: [id], onDelete: Cascade)
  userId      String
  characterId String
  redeemedAt  DateTime @default(now())

  @@unique([giftCodeId, userId])
  @@index([userId])
  @@index([characterId])
}

/// Audit trail mọi thay đổi InventoryItem.qty (Phase 9). Một dòng = một thao
/// tác đổi vật phẩm của 1 character. `qtyDelta` có dấu (âm = trừ / mất / dùng).
model ItemLedger {
  id          String    @id @default(cuid())
  characterId String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  itemKey     String
  /// Có dấu: dương khi grant (boss/mail/giftcode/shop/mission), âm khi consume (use/sell).
  qtyDelta    Int
  reason      String
  refType     String?
  refId       String?
  meta        Json      @default("{}")
  /// Nếu thao tác do admin thực hiện (vd ADMIN_GRANT).
  actorUserId String?
  createdAt   DateTime  @default(now())

  @@index([characterId, createdAt])
  @@index([itemKey, createdAt])
  @@index([reason, createdAt])
  @@index([refType, refId])
  @@index([actorUserId, createdAt])
}

/// Idempotency log cho phần thưởng đăng nhập hằng ngày.
/// Mỗi (character, ngày-local) có tối đa 1 hàng — unique constraint đảm bảo
/// không double-claim. `claimDateLocal` là `YYYY-MM-DD` theo `MISSION_RESET_TZ`
/// (Asia/Ho_Chi_Minh mặc định) để mốc reset trùng với daily mission.
model DailyLoginClaim {
  id             String    @id @default(cuid())
  characterId    String
  character      Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  /// `YYYY-MM-DD` theo timezone reset; vd "2026-04-29".
  claimDateLocal String
  /// Số linh thạch đã trao tại lần claim này (positive). BigInt để khớp Character.linhThach.
  linhThachDelta BigInt
  /// Số ngày liên tiếp đã claim trước + bao gồm lần này (1 nếu mới hoặc bị gãy chuỗi).
  streakAtClaim  Int
  createdAt      DateTime  @default(now())

  @@unique([characterId, claimDateLocal])
  @@index([characterId, createdAt])
}

/// Phase 13.1.A — Sect War (Tông Môn Chiến) tuần lễ contribution log.
/// Mỗi row = 1 lần activity → cộng `points` cho `sectId` trong `weekKey`.
///
/// Idempotency: composite UNIQUE
/// `(weekKey, characterId, activityKey, sourceType, sourceId)`. Cùng activity
/// + cùng sourceId trong cùng tuần chỉ ghi 1 row (retry endpoint không double).
/// `sourceId = null` cũng được phép (vd activity không có dependent entity);
/// trong PostgreSQL NULL ≠ NULL ⇒ multiple null rows được phép. Activity hooks
/// hiện tại luôn có sourceId không null (DungeonRun.id, WorldBoss.id+charId,
/// claimDateLocal, questKey).
///
/// `sectId` snapshot tại commit time — nếu character đổi sect giữa tuần
/// (rời + join sect khác), điểm cũ vẫn ở sect cũ (history-true). Leaderboard
/// aggregate sum theo `sectId` trong `weekKey`.
///
/// Indexes:
///   - `[weekKey, sectId]` cho leaderboard sum query.
///   - `[weekKey, characterId]` cho personal status / breakdown.
///   - UNIQUE composite cho idempotency.
model SectWarContribution {
  id           String   @id @default(cuid())
  /// ISO week key, format `YYYY-Www` (vd "2026-W19").
  weekKey      String
  sectId       String
  characterId  String
  /// Match `SectWarActivityKey` từ shared catalog.
  activityKey  String
  /// Match `SectWarSourceType` (vd "DungeonRun", "WorldBoss", "DailyLoginClaim", "Quest").
  sourceType   String
  /// Optional source entity id (vd dungeonRunId / bossId+characterId / claimDateLocal / questKey).
  sourceId     String?
  /// Số điểm cộng vào sect — server-authoritative từ catalog (FE không gửi).
  points       Int
  createdAt    DateTime @default(now())

  @@unique([weekKey, characterId, activityKey, sourceType, sourceId])
  @@index([weekKey, sectId])
  @@index([weekKey, characterId])
  @@index([weekKey, createdAt])
}

/// Phase 13.1.A — Sect War weekly reward claim log.
/// Mỗi (weekKey, characterId) có tối đa 1 hàng — unique constraint đảm bảo
/// không double-claim race-safe.
///
/// `rewardTierKey` snapshot tại claim time (vd "rank_1", "rank_2_3",
/// "rank_4_10", "participation"). Catalog tier có thể thay đổi qua phase,
/// nhưng row đã claim giữ tier cũ làm audit/replay safe.
///
/// `sectId` snapshot — nếu character đổi sect sau khi claim, không reset.
/// `pointsAtClaim` snapshot personal points dùng để check eligibility
/// (participation tier yêu cầu ≥ minPersonalPoints).
model SectWarWeeklyRewardClaim {
  id            String   @id @default(cuid())
  /// ISO week key (`YYYY-Www`).
  weekKey       String
  sectId        String
  characterId   String
  /// Match `SectWarRewardTierKey` từ shared catalog.
  rewardTierKey String
  /// Snapshot points cá nhân tại thời điểm claim (audit + breakdown view).
  pointsAtClaim Int
  /// Snapshot rank của Sect tại claim time (1-based).
  sectRankAtClaim Int
  /// Snapshot tổng điểm Sect tại claim time.
  sectPointsAtClaim Int
  claimedAt     DateTime @default(now())

  @@unique([weekKey, characterId])
  @@index([weekKey, sectId])
  @@index([characterId, claimedAt])
}

/// Phase 13.1.B — Sect Mission claim log (idempotency dedupe).
/// Mỗi `(characterId, missionKey, periodKey)` tối đa 1 row — UNIQUE đảm bảo
/// claim không double dù retry. `periodKey` format:
///   - DAILY  → `YYYY-MM-DD` theo `MISSION_RESET_TZ` (Asia/Ho_Chi_Minh).
///   - WEEKLY → `YYYY-Www` ISO week (cùng helper với SectWar).
///
/// `rewardContributionGranted` snapshot tại claim time (audit).
model SectMissionClaim {
  id                        String    @id @default(cuid())
  characterId               String
  character                 Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  /// Match key trong shared `SECT_MISSIONS` catalog.
  missionKey                String
  /// Period key dùng để dedupe — mission DAILY/WEEKLY đổi key mỗi reset.
  periodKey                 String
  /// Snapshot reward contribution đã trao (positive Int).
  rewardContributionGranted Int
  claimedAt                 DateTime  @default(now())

  @@unique([characterId, missionKey, periodKey])
  @@index([characterId, claimedAt])
  @@index([missionKey, periodKey])
}

/// Phase 13.1.B — Sect Shop purchase log + idempotency / window aggregation.
/// Mỗi row = 1 lần buy (multiple buys của cùng entry trong cùng ngày tạo
/// nhiều row). Daily/weekly limit compute từ SUM `qty` trong window.
///
/// `contributionSpent` snapshot cost (`def.contributionCost * qty`) tại
/// commit time — catalog có thể đổi giá tương lai, row đã ghi giữ nguyên
/// audit trail.
model SectShopPurchase {
  id                String    @id @default(cuid())
  characterId       String
  character         Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  /// Match key trong shared `SECT_SHOP_ENTRIES`.
  entryKey          String
  /// Item key shipped (snapshot — match `SectShopEntryDef.itemKey`).
  itemKey           String
  qty               Int
  contributionSpent Int
  /// Period key DAILY (`YYYY-MM-DD` theo `MISSION_RESET_TZ`) tại commit time —
  /// dùng SUM(qty) trong window làm `dailyLimit` enforcement (faster query
  /// hơn so với date-range filter, indexable).
  dailyPeriodKey    String
  /// Period key WEEKLY (`YYYY-Www` ISO) tại commit time — dùng SUM(qty) cho
  /// `weeklyLimit` enforcement.
  weeklyPeriodKey   String
  createdAt         DateTime  @default(now())

  @@index([characterId, entryKey, dailyPeriodKey])
  @@index([characterId, entryKey, weeklyPeriodKey])
  @@index([characterId, createdAt])
}

/// Phase 13.1.B — Sect Contribution Ledger.
/// Mỗi mutate `Character.sectContribBalance` + `sectContribLifetime` ghi 1
/// row. `delta` ký:
///   - dương: earn (mission claim, admin grant, optional sect war reward).
///   - âm:    spend (sect shop buy).
///
/// Reason whitelist:
///   - `SECT_MISSION_CLAIM`
///   - `SECT_SHOP_BUY`
///   - `SECT_CONTRIBUTION_SPEND`
///   - `ADMIN_GRANT`
///   - `SECT_WAR_REWARD`
///
/// `refType + refId` trace ngược source — vd `Mission`/missionKey,
/// `SectShop`/entryKey, `SectWarWeeklyRewardClaim`/weekKey.
model SectContributionLedger {
  id          String    @id @default(cuid())
  characterId String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  delta       Int
  reason      String
  refType     String?
  refId       String?
  meta        Json      @default("{}")
  actorUserId String?
  createdAt   DateTime  @default(now())

  @@index([characterId, createdAt])
  @@index([reason, createdAt])
}

/// Phase 13.1.B — LiveOps event override (admin LiveOps controls).
/// Mỗi row = override 1 event key trong `LIVE_OPS_EVENTS` catalog. `enabled`
/// toggle (false = ẩn event khỏi `liveOpsEventsForToday`). `startsAt`/`endsAt`
/// optional override window (caller dùng cho hot-fix Limited Time Event).
///
/// `updatedBy` (User.id) audit trail; `reason` for log/debug. UNIQUE `key`
/// → upsert pattern (insert nếu chưa có, update nếu đã tồn tại).
model LiveOpsEventOverride {
  id          String    @id @default(cuid())
  /// LiveOps event key (match `LIVE_OPS_EVENTS[*].key`).
  key         String    @unique
  enabled     Boolean
  startsAt    DateTime?
  endsAt      DateTime?
  reason      String?
  updatedBy   String
  updatedAt   DateTime  @updatedAt
  createdAt   DateTime  @default(now())

  @@index([enabled, updatedAt])
}
