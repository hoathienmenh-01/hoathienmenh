  @@index([status, itemKind])
  @@index([status, itemKey])
  @@index([sellerId, status])
}

enum SectRole {
  LEADER
  ELDER
  MEMBER
}

model Sect {
  id                   String                @id @default(cuid())
  name                 String                @unique
  description          String                @default("")
  level                Int                   @default(1)
  treasuryLinhThach    BigInt                @default(0)
  leaderId             String?               @unique
  characters           Character[]
  members              SectMember[]
  /// Phase 29.0 — PvP anomaly backref.
  pvpAnomalyLogs       PvpAnomalyLog[]
  /// Phase 30.0 — Sect treasury items + log + internal auction.
  treasuryItems        SectTreasuryItem[]
  treasuryLogs         SectTreasuryLog[]
  sectInternalAuctions SectInternalAuction[]
  /// Phase 13.8 — Sect boss instances.
  bossInstances        SectBossInstance[]
  createdAt            DateTime              @default(now())
}

model SectMember {
  id          String    @id @default(cuid())
  sectId      String
  sect        Sect      @relation(fields: [sectId], references: [id], onDelete: Cascade)
  characterId String    @unique
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  role        SectRole  @default(MEMBER)
  joinedAt    DateTime  @default(now())

  @@index([sectId, role])
  @@index([sectId, joinedAt])
}

model SectAuditLog {
  id           String    @id @default(cuid())
  sectId       String
  actorCharId  String
  targetCharId String
  action       String
  fromRole     SectRole?
  toRole       SectRole?
  meta         Json      @default("{}")
  createdAt    DateTime  @default(now())

  @@index([sectId, createdAt])
  @@index([actorCharId, createdAt])
}

/// Phase 13.8 — Sect boss instance (spawned by ELDER/LEADER).
model SectBossInstance {
  id           String                @id @default(cuid())
  sectId       String
  sect         Sect                  @relation(fields: [sectId], references: [id], onDelete: Cascade)
  bossKey      String
  maxHp        Int
  currentHp    Int
  defeated     Boolean               @default(false)
  spawnedAt    DateTime              @default(now())
  defeatedAt   DateTime?
  participants SectBossParticipant[]

  @@index([sectId, defeated])
  @@index([sectId, bossKey, spawnedAt])
}

/// Phase 13.8 — Sect boss participant damage + claim tracking.
model SectBossParticipant {
  id          String           @id @default(cuid())
  instanceId  String
  instance    SectBossInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  characterId String
  character   Character        @relation(fields: [characterId], references: [id], onDelete: Cascade)
  damage      Int              @default(0)
  claimed     Boolean          @default(false)
  createdAt   DateTime         @default(now())

  @@unique([instanceId, characterId])
  @@index([characterId, createdAt])
}

enum ChatChannel {
  WORLD
  SECT
}

model ChatMessage {
  id         String      @id @default(cuid())
  channel    ChatChannel
  /// scopeKey: with WORLD = 'world'; with SECT = sectId
  scopeKey   String
  senderId   String
  senderName String
  text       String
  createdAt  DateTime    @default(now())

  @@index([channel, scopeKey, createdAt])
}

/// Phase 19.1 — Social System Foundation
///
/// Friend request status lifecycle:
///   PENDING -> ACCEPTED (tạo `Friendship`)
///   PENDING -> DECLINED (giữ history, không tạo friendship)
///   PENDING -> CANCELLED (sender huỷ trước khi receiver phản hồi)
///
/// Khi block xảy ra, mọi pending request giữa 2 user transition sang
/// CANCELLED (service-level) và không cho gửi mới.
enum FriendRequestStatus {
  PENDING
  ACCEPTED
  DECLINED
  CANCELLED
}

/// Phase 19.1 — Friend request giữa 2 user. Soft-ref `senderUserId` /
/// `receiverUserId` (no DB FK) — giảm rủi ro cascade. Cấm self-request
/// + cấm duplicate PENDING ở service-level (đã unique partial index
/// theo `status` thấp ở DB).
///
/// Idempotency: chỉ cho duy nhất 1 PENDING giữa (sender, receiver) tại
/// 1 thời điểm. Sau DECLINED/CANCELLED có thể gửi lại — service check.
model FriendRequest {
  id             String              @id @default(cuid())
  /// userId người gửi lời mời.
  senderUserId   String
  /// userId người nhận lời mời.
  receiverUserId String
  status         FriendRequestStatus @default(PENDING)
  /// Tin nhắn kèm lời mời (optional, ≤140 ký tự).
  message        String?
  createdAt      DateTime            @default(now())
  /// Thời điểm transition khỏi PENDING. Null khi PENDING.
  respondedAt    DateTime?

  @@index([receiverUserId, status, createdAt])
  @@index([senderUserId, status, createdAt])
}

/// Phase 19.1 — Friendship 2 chiều giữa 2 user. Invariant:
/// `userAId < userBId` (so sánh lexicographic) — chặn duplicate
/// (A,B) vs (B,A) qua `@@unique([userAId, userBId])`. Service phải
/// `assertSortedPair` trước khi insert.
model Friendship {
  id        String   @id @default(cuid())
  /// userId nhỏ (lexicographic).
  userAId   String
  /// userId lớn (lexicographic).
  userBId   String
  createdAt DateTime @default(now())

  @@unique([userAId, userBId])
  @@index([userAId])
  @@index([userBId])
}

/// Phase 19.1 — PlayerBlock 1 chiều (`blockerUserId` chặn
/// `blockedUserId`). Block thì:
///   - Chặn `FriendRequest` từ cả 2 hướng.
///   - Chặn `PrivateChatMessage` từ cả 2 hướng.
///   - KHÔNG xoá `Friendship` cũ (service quyết — Phase 19.1 mặc định
///     auto-removeFriend khi block — invariant test-enforced).
///   - KHÔNG hiển thị `blocker` trong friend list của `blocked` và
///     ngược lại (filter service-level).
model PlayerBlock {
  id            String   @id @default(cuid())
  /// userId người chặn.
  blockerUserId String
  /// userId người bị chặn.
  blockedUserId String
  createdAt     DateTime @default(now())

  @@unique([blockerUserId, blockedUserId])
  @@index([blockedUserId])
}

/// Phase 35.1 — Co-Cultivation / Hợp Luyện session lifecycle.
///
/// PENDING → ACTIVE (partner accept) → COMPLETED (initiator complete) hoặc
/// CANCELLED / EXPIRED.
///
/// Server-authoritative — bonus EXP áp 1 lần ở `complete` qua
/// `RewardCapService.applyCapTx({ source: 'CULTIVATION' })` (share budget
/// tránh dual-farm với regular tick). `rewardApplied` boolean CAS-guard
/// idempotent — không double-apply nếu controller retry.
///
/// Anti-abuse: cần friendship (Phase 19.1) + cả 2 không block + presence
/// optional + daily cap 3/30 phút.
enum CoCultivationStatus {
  PENDING
  ACTIVE
  COMPLETED
  CANCELLED
  EXPIRED
}

model CoCultivationSession {
  id                   String              @id @default(cuid())
  /// userId người gửi yêu cầu hợp luyện.
  initiatorUserId      String
  /// userId người nhận yêu cầu hợp luyện.
  partnerUserId        String
  /// Snapshot characterId tại lúc tạo — phục vụ audit + future
  /// processor wire. Không FK để mirror soft-ref Phase 19.1 social.
  initiatorCharacterId String
  partnerCharacterId   String
  status               CoCultivationStatus @default(PENDING)
  /// Tổng thời lượng buff dự kiến (giây). Default 600s = 10 phút.
  durationSec          Int                 @default(600)
  /// Phần trăm bonus áp lên base cultivation rate (1..5). Server clamp.
  buffPercent          Int                 @default(3)
  startedAt            DateTime?
  completedAt          DateTime?
  /// Hạn chót để accept (PENDING expire). Service hoặc cron set/check.
  expiresAt            DateTime?
  rewardApplied        Boolean             @default(false)
  /// Tổng EXP bonus thực sự được grant (cả initiator + partner sau cap).
  bonusExpGranted      BigInt              @default(0)
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  @@index([initiatorUserId, status, createdAt])
  @@index([partnerUserId, status, createdAt])
  @@index([status, createdAt])
}

/// Phase 35.1 — Daily usage bucket per-user cho co-cultivation. Track
/// `sessionsCompleted` (cap 3/ngày) + `totalBuffSeconds` (cap 1800s/ngày)
/// + `totalBonusExp` (audit). Reset theo `dateKey` (YYYY-MM-DD theo
/// `DAILY_REWARD_CAP_TZ`, default Asia/Ho_Chi_Minh).
model CoCultivationDailyUsage {
  id                String   @id @default(cuid())
  userId            String
  dateKey           String
  sessionsCompleted Int      @default(0)
  totalBuffSeconds  Int      @default(0)
  totalBonusExp     BigInt   @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([userId, dateKey])
  @@index([dateKey])
}

/// Phase 19.1 — Loại chat thread:
///   - `PRIVATE`: 1-1 message giữa 2 user (`PrivateChatThread` +
///     `PrivateChatMessage`).
///   - `GROUP`: nhóm chat có owner + danh sách member (`GroupChat` +
///     `GroupChatMember` + `GroupChatMessage`).
enum ChatThreadType {
  PRIVATE
  GROUP
}

/// Phase 19.1 — Private chat thread giữa 2 user. Invariant:
/// `userAId < userBId` (lexicographic) → chặn duplicate thread
/// (A,B) vs (B,A) qua `@@unique`. Service `getOrCreatePrivateThread`
/// chuẩn hoá thứ tự trước khi upsert.
model PrivateChatThread {
  id        String   @id @default(cuid())
  /// userId nhỏ (lexicographic).
  userAId   String
  /// userId lớn (lexicographic).
  userBId   String
  createdAt DateTime @default(now())

  @@unique([userAId, userBId])
  @@index([userAId])
  @@index([userBId])
}

/// Phase 19.1 — Private chat message. Soft-ref `threadId` /
/// `senderUserId` (no DB FK). Server cap `body` ≤500 char (test-
/// enforced).
model PrivateChatMessage {
  id              String    @id @default(cuid())
  threadId        String
  /// userId của người gửi (phải là 1 trong 2 thành viên thread).
  senderUserId    String
  body            String
  createdAt       DateTime  @default(now())
  /// Phase 19.2 — soft-hide moderation. Khi `hiddenAt != null`, list
  /// messages render placeholder "Tin nhắn đã bị ẩn" thay vì body raw.
  /// Hard-delete KHÔNG dùng — giữ row cho audit (admin có thể truy
  /// vết nội dung qua AdminAuditLog meta).
  hiddenAt        DateTime?
  hiddenByAdminId String?
  /// Lý do hide (admin nhập, ≤200 ký tự, sanitized). Hiển thị trong
  /// admin moderation panel — KHÔNG render cho user.
  hideReason      String?

  @@index([threadId, createdAt])
  @@index([senderUserId, createdAt])
  @@index([hiddenAt])
}

/// Phase 19.1 — Group chat. Owner tạo group, add/remove member. Owner
/// luôn là member (test-enforced). Tên group ≤60 ký tự.
///
/// Phase 19.2 — moderation: admin có thể `lock` group (cấm send + add
/// member) hoặc `dissolve` group (set `dissolvedAt`, soft-delete để giữ
/// audit message history). Cả 2 đều ghi AdminAuditLog.
model GroupChat {
  id                 String    @id @default(cuid())
  /// Tên hiển thị (do owner đặt). Trim + non-empty + ≤60 char.
  name               String
  /// userId của owner. Soft-ref (no FK).
  ownerUserId        String
  createdAt          DateTime  @default(now())
  /// Phase 19.2 — lock state. Khi `lockedAt != null`, group reject
  /// send + add member với code `GROUP_LOCKED`. Admin có thể unlock
  /// bằng cách set lại null qua admin endpoint.
  lockedAt           DateTime?
  lockedByAdminId    String?
  lockReason         String?
  /// Phase 19.2 — dissolve state. Khi `dissolvedAt != null`, group bị
  /// coi như xoá soft: không list trong `listGroupsForUser`, reject
  /// mọi mutation. Member rows giữ nguyên cho audit.
  dissolvedAt        DateTime?
  dissolvedByAdminId String?
  dissolveReason     String?

  @@index([ownerUserId])
  @@index([lockedAt])
  @@index([dissolvedAt])
}

/// Phase 19.1 — Group chat member. Unique (groupId, userId) ngăn
/// member duplicate. Service kiểm tra block trước khi add (không add
/// 2 user đang block lẫn nhau vào cùng group — test-enforced).
model GroupChatMember {
  id       String   @id @default(cuid())
  groupId  String
  userId   String
  joinedAt DateTime @default(now())

  @@unique([groupId, userId])
  @@index([userId])
}

/// Phase 19.1 — Group chat message. Service-level kiểm tra
/// `senderUserId` là member của group trước khi insert. Non-member
/// đọc/gửi → 404 mask (không leak existence).
///
/// Phase 19.2 — soft-hide moderation (cùng pattern PrivateChatMessage).
model GroupChatMessage {
  id              String    @id @default(cuid())
  groupId         String
  senderUserId    String
  body            String
  createdAt       DateTime  @default(now())
  /// Phase 19.2 — soft-hide. Render placeholder thay vì body khi
  /// `hiddenAt != null`.
  hiddenAt        DateTime?
  hiddenByAdminId String?
  hideReason      String?

  @@index([groupId, createdAt])
  @@index([senderUserId, createdAt])
  @@index([hiddenAt])
}

/// Phase 19.2 — Chat Moderation & Report System.
///
/// Loại tin nhắn bị report — quyết định FK pointer nào được set ở
/// `ChatMessageReport`. Soft-ref pattern (KHÔNG FK constraint).
enum ChatMessageReportType {
  PRIVATE
  GROUP
}

/// Lifecycle của report:
///   OPEN -> ACKNOWLEDGED (admin xác nhận đang xử lý)
///   OPEN | ACKNOWLEDGED -> RESOLVED (action đã thực hiện)
///   OPEN | ACKNOWLEDGED -> REJECTED (không vi phạm, đóng case)
/// Sau RESOLVED/REJECTED report là terminal, KHÔNG transition lại.
enum ChatMessageReportStatus {
  OPEN
  ACKNOWLEDGED
  RESOLVED
  REJECTED
}

/// Lý do report mà user chọn từ FE — enum cố định để chống free-text
/// abuse + analytics (so sánh tỷ lệ spam vs harassment vs scam).
enum ChatMessageReportReason {
  SPAM
  HARASSMENT
  SCAM
  OFFENSIVE
  OTHER
}

/// Scope mute — quyết định channel nào user bị câm.
///   - `PRIVATE_CHAT`: cấm gửi `PrivateChatMessage`.
///   - `GROUP_CHAT`: cấm gửi `GroupChatMessage`.
///   - `WORLD_SECT_CHAT`: cấm gửi `ChatMessage` (WORLD/SECT cũ).
///   - `ALL_CHAT`: gộp 3 scope trên.
enum ChatMuteScope {
  PRIVATE_CHAT
  GROUP_CHAT
  WORLD_SECT_CHAT
  ALL_CHAT
}

/// Phase 19.2 — ChatMessageReport: user-submitted report về tin
/// nhắn vi phạm (private hoặc group). Soft-ref pointer (`privateMessageId`
/// hoặc `groupMessageId`) — chỉ 1 trong 2 có giá trị, validate ở
/// service level. Cấm duplicate `(reporterUserId, privateMessageId)`
/// hoặc `(reporterUserId, groupMessageId)` qua unique partial index để
/// chống report-storm. User chỉ report message mình có quyền nhìn
/// thấy (thread member / group member) — server enforce.
///
/// Privacy:
///   - `detailsText` ≤500 ký tự, sanitized (strip control char) ở
///     shared validator trước khi persist.
///   - KHÔNG lưu raw IP / cookie / token.
model ChatMessageReport {
  id                String                  @id @default(cuid())
  /// userId người báo cáo.
  reporterUserId    String
  /// userId người gửi message bị báo cáo. Service tự lookup khi tạo
  /// (snapshot tại thời điểm report — không bị tác động bởi việc xoá
  /// account sau này). Nullable cho edge-case message orphan.
  targetUserId      String?
  messageType       ChatMessageReportType
  /// FK soft-ref tới `PrivateChatMessage.id`. Set khi `messageType=PRIVATE`,
  /// null cho `GROUP`.
  privateMessageId  String?
  /// FK soft-ref tới `GroupChatMessage.id`. Set khi `messageType=GROUP`,
  /// null cho `PRIVATE`.
  groupMessageId    String?
  /// FK soft-ref tới `GroupChat.id` (denormalized cho query filter).
  /// Set cùng `groupMessageId`.
  groupId           String?
  reason            ChatMessageReportReason
  /// Lý do chi tiết do user nhập (optional, sanitized ≤500).
  detailsText       String?
  status            ChatMessageReportStatus @default(OPEN)
  createdAt         DateTime                @default(now())
  resolvedAt        DateTime?
  /// userId admin xử lý (ack / resolve / reject). Set khi status rời
  /// `OPEN`. KHÔNG xoá cascade — admin xoá account vẫn giữ row.
  resolvedByAdminId String?
  /// Ghi chú admin khi resolve / reject (≤500 ký tự, sanitized).
  resolutionNote    String?

  @@unique([reporterUserId, privateMessageId])
  @@unique([reporterUserId, groupMessageId])
  @@index([status, createdAt(sort: Desc)])
  @@index([reporterUserId, createdAt(sort: Desc)])
  @@index([targetUserId, createdAt(sort: Desc)])
  @@index([reason, status])
  @@index([messageType, status])
}

/// Phase 19.2 — ChatMute: admin câm user trong 1 hoặc nhiều kênh chat.
/// Mute active khi `startsAt ≤ now < expiresAt` (hoặc `expiresAt`
/// null → indefinite cho tới `revokedAt`) và `revokedAt == null`.
/// Service check `findActiveMuteForUser` trước mọi `send*` call và
/// reject với code `MUTED`.
///
/// KHÔNG auto-ban vĩnh viễn — mute mặc định có `expiresAt` set
/// (admin chọn 1h / 24h / 7 ngày). Indefinite mute yêu cầu admin
/// explicit set `expiresAt = null`.
model ChatMute {
  id               String        @id @default(cuid())
  userId           String
  mutedByAdminId   String
  /// Lý do mute (≤200 ký tự, sanitized).
  reason           String
  scope            ChatMuteScope
  startsAt         DateTime      @default(now())
  /// Thời điểm mute hết hạn. Null = indefinite (chỉ revoke thủ công).
  expiresAt        DateTime?
  /// Thời điểm admin lift mute sớm. Khi != null, mute không còn active.
  revokedAt        DateTime?
  revokedByAdminId String?
  createdAt        DateTime      @default(now())

  @@index([userId, revokedAt, expiresAt])
  @@index([scope, revokedAt, expiresAt])
  @@index([createdAt(sort: Desc)])
}

enum BossStatus {
  ACTIVE
  DEFEATED
  EXPIRED
}

model WorldBoss {
  id          String     @id @default(cuid())
  bossKey     String
  name        String
  level       Int
  maxHp       BigInt
  currentHp   BigInt
  status      BossStatus @default(ACTIVE)
  spawnedAt   DateTime   @default(now())
  expiresAt   DateTime
  defeatedAt  DateTime?
  rewardTotal BigInt     @default(0)
  // Phase 12.6 — region scope cho multi-region auto-spawn. Default 'world'
  // legacy world boss; mới: 'hac_lam', 'kim_son_mach', v.v. (match
  // `BossDef.regionKey` ở `packages/shared/src/boss.ts`). Partial unique
  // index `WorldBoss_status_region_active_unique` enforce ≤1 ACTIVE per
  // region (xem migration `20260523000000_phase_12_6_world_boss_region_key`).
  regionKey   String     @default("world")

  damages BossDamage[]

  @@index([status, spawnedAt])
  @@index([regionKey, status])
}

model BossDamage {
  id            String    @id @default(cuid())
  bossId        String
  boss          WorldBoss @relation(fields: [bossId], references: [id], onDelete: Cascade)
  characterId   String
  characterName String
  totalDamage   BigInt    @default(0)
  hits          Int       @default(0)
  lastHitAt     DateTime  @default(now())

  @@unique([bossId, characterId])
  @@index([bossId, totalDamage])
}

enum EncounterStatus {
  ACTIVE
  WON
  LOST
  ABANDONED
}

enum CurrencyKind {
  LINH_THACH
  TIEN_NGOC
  /// Phase 27.0 — Bound premium currency. Không giao dịch được; reward
  /// thẻ tháng / pass / event / bồi thường / vé quét.
  TIEN_NGOC_KHOA
  /// Phase 27.0 — Cống Hiến Tông Môn. Earn từ nhiệm vụ / boss / bí cảnh
  /// tông môn. Khác `sectContribBalance` (Phase 13.1.B spendable) — đây
  /// là wallet view chung cho monetization layer.
  CONG_HIEN_TONG_MON
  /// Phase 27.0 — Trial Point (Đăng Tiên Tháp / Linh Khí Tháp / Huyết
  /// Thể Tháp). Earn từ trial tower clear.
  TRIAL_POINT
  /// Phase 27.0 — Event token. Earn từ hoạt động mùa, event pass.
  EVENT_TOKEN
}

/// Audit trail mọi mutation của linhThach / tienNgoc (Phase 4-8). Một dòng = một
/// thao tác đổi tiền của 1 character. `delta` có dấu (âm = trừ).
model CurrencyLedger {
  id          String       @id @default(cuid())
  characterId String
  character   Character    @relation(fields: [characterId], references: [id], onDelete: Cascade)
  currency    CurrencyKind
  delta       BigInt
  reason      String
  refType     String?
  refId       String?
  meta        Json         @default("{}")
  /// Nếu thao tác do admin/MOD thực hiện (vd ADMIN_GRANT, ADMIN_TOPUP_APPROVE).
  actorUserId String?
  createdAt   DateTime     @default(now())

  @@index([characterId, createdAt])
  @@index([reason, createdAt])
  @@index([refType, refId])
  @@index([actorUserId, createdAt])
}

model Encounter {
  id          String          @id @default(cuid())
  characterId String
  dungeonKey  String
  status      EncounterStatus @default(ACTIVE)
  /// JSON state: { monsterIndex, monsterHp, lastTurn }
  state       Json            @default("{}")
  /// JSON list of log lines [{ side, text, ts }]
  log         Json            @default("[]")
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([characterId, status])
}

/// Phase 12.2.B — DungeonRun runtime status. Khác `Encounter` (single
/// turn-based monster) — DungeonRun là multi-encounter expedition flow:
/// player call `next` để auto-resolve 1 encounter / lần (kill monster +
/// quest track + advance), khi hết list `monsters` thì status=COMPLETED,
/// claim reward bonus → CLAIMED. ABANDONED = player drop run, slot daily
/// vẫn bị tiêu (anti-grind).
enum DungeonRunStatus {
  ACTIVE
  COMPLETED
  CLAIMED
  ABANDONED
}

/// Phase 12.2.B — DungeonRun runtime persistence (multi-encounter expedition).
/// Khác `Encounter`:
///   - `Encounter` = single turn-based combat (CombatService action loop).
///   - `DungeonRun` = expedition flow auto-resolve mỗi `next()` call.
/// Cùng catalog `DUNGEONS` (shared/combat.ts), cùng dailyLimit accounting
/// (count rows trong cửa sổ DAILY VN tz `startOfLocalDay`), cùng quest kill
/// hook (`QuestService.track('kill','monster',monsterKey)` per encounter).
///
/// Reward claim atomic qua `CurrencyService.applyTx` + `InventoryService
/// .grantTx` + `tx.character.update({ exp })` với `reason='DUNGEON_RUN
/// _REWARD'` + `refType='DungeonRun'` + `refId=runId`. Idempotent qua CAS
/// guard `claimedAt=null` updateMany pattern (mirror QuestService.claim
/// Phase 12 PR-3).
///
/// Indexes:
///   - `[characterId, status]` cho list active run + filter status.
///   - `[characterId, startedAt]` cho dailyLimit count.
///   - `[characterId, templateKey, startedAt]` cho per-dungeon dailyLimit.
model DungeonRun {
  id             String           @id @default(cuid())
  characterId    String
  /// Match `DungeonDef.key` từ shared catalog `DUNGEONS`.
  templateKey    String
  status         DungeonRunStatus @default(ACTIVE)
  /// Index của monster hiện tại trong `dungeon.monsters[]` (0..N).
  /// Khi `encounterIndex == monsters.length` → COMPLETED (claim sẵn sàng).
  encounterIndex Int              @default(0)
  /// JSON list `[{ monsterKey, killedAt: ISO string }]` — log resolution
  /// tracking, dùng cho debug + Phase 12.5 stats UI.
  killedMonsters Json             @default("[]")
  startedAt      DateTime         @default(now())
  completedAt    DateTime?
  claimedAt      DateTime?
  updatedAt      DateTime         @updatedAt

  @@index([characterId, status])
  @@index([characterId, startedAt])
  @@index([characterId, templateKey, startedAt])
}

/// Phase 38.0 — Roguelike Bí Cảnh run status.
///
/// ACTIVE → COMPLETED/FAILED/ABANDONED → CLAIMED (only COMPLETED can claim).
/// CLAIMED is terminal and guarded by atomic status CAS to prevent duplicate
/// ledger/inventory grants under parallel claim spam.
enum RoguelikeRunStatus {
  ACTIVE
  COMPLETED
  FAILED
  ABANDONED
  CLAIMED
}

/// Phase 38.0 — Roguelike Bí Cảnh / Random Adventure runtime.
///
/// A run is a seeded multi-floor adventure. Floor definitions and choice
/// outcomes live in `packages/shared/src/roguelike.ts`; this table persists only
/// character state (HP/resource), active temporary buffs/debuffs and floor log.
/// Rewards are granted once at final claim via CurrencyLedger/ItemLedger and
/// daily/weekly caps.
model RoguelikeRun {
  id            String             @id @default(cuid())
  characterId   String
  character     Character          @relation(fields: [characterId], references: [id], onDelete: Cascade)
  realmKey      String
  status        RoguelikeRunStatus @default(ACTIVE)
  seed          String
  currentFloor  Int                @default(0)
  hp            Int
  hpMax         Int
  resource      Int                @default(0)
  score         Int                @default(0)
  rewardMul     Float              @default(1)
  activeBuffs   Json               @default("[]")
  floorHistory  Json               @default("[]")
  rewardPreview Json               @default("{}")
  lastChoiceKey String?
  startedAt     DateTime           @default(now())
  completedAt   DateTime?
  failedAt      DateTime?
  abandonedAt   DateTime?
  claimedAt     DateTime?
  expiresAt     DateTime?
  updatedAt     DateTime           @updatedAt

  @@index([characterId, status])
  @@index([characterId, startedAt])
  @@index([realmKey, status])
}

/// Phase 38.0 — Roguelike leaderboard foundation.
///
/// Stores all-time best per character plus coarse weekly/monthly bucket of the
/// latest best update. Reward distribution is intentionally deferred.
model RoguelikeLeaderboard {
  id             String    @id @default(cuid())
  characterId    String    @unique
  character      Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  bestFloor      Int       @default(0)
  bestScore      Int       @default(0)
  fastestClearMs Int?
  bestRunId      String?
  weekBucket     String
  monthBucket    String
  updatedAt      DateTime  @updatedAt
  createdAt      DateTime  @default(now())

  @@index([weekBucket, bestFloor, bestScore])
  @@index([monthBucket, bestFloor, bestScore])
}

/// Phase 39.0 — Server season lifecycle.
enum SeasonStatus {
  UPCOMING
  ACTIVE
  ENDED
  ARCHIVED
}

/// Phase 39.0 — Season leaderboard categories.
enum SeasonLeaderboardKind {
  POINTS
  ROGUELIKE_FLOOR
  BOSS_DEFEATS
  DUNGEON_CLEARS
}

/// Phase 39.0 — Monthly/quarterly liveops season.
///
/// A season is a soft-reset competitive window. It owns points,
/// leaderboards, server milestones and reward claims, but never mutates core
/// player assets when a new season starts.
model ServerSeason {
  id               String       @id @default(cuid())
  seasonKey        String       @unique
  name             String
  description      String       @default("")
  status           SeasonStatus @default(UPCOMING)
  startAt          DateTime
  endAt            DateTime
  pointConfig      Json         @default("{}")
  rewardConfig     Json         @default("[]")
  milestoneConfig  Json         @default("[]")
  createdByAdminId String?
  updatedByAdminId String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  progress           SeasonProgress[]
  leaderboardEntries SeasonLeaderboardEntry[]
  rewardClaims       SeasonRewardClaim[]
  serverMilestones   SeasonServerMilestone[]

  @@index([status, startAt, endAt])
  @@index([startAt, endAt])
}

/// Phase 39.0 — Per-character progress scoped to one season.
model SeasonProgress {
  id                 String       @id @default(cuid())
  seasonId           String
  season             ServerSeason @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  characterId        String
  character          Character    @relation(fields: [characterId], references: [id], onDelete: Cascade)
  points             Int          @default(0)
  bestRoguelikeFloor Int          @default(0)
  bossDefeats        Int          @default(0)
  dungeonClears      Int          @default(0)
  craftCount         Int          @default(0)
  breakthroughCount  Int          @default(0)
  lastPointAt        DateTime?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  @@unique([seasonId, characterId])
  @@index([seasonId, points])
  @@index([characterId, updatedAt])
}

/// Phase 39.0 — Soft-reset leaderboard row per season/category/character.
model SeasonLeaderboardEntry {
  id          String                @id @default(cuid())
  seasonId    String
  season      ServerSeason          @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  characterId String
  character   Character             @relation(fields: [characterId], references: [id], onDelete: Cascade)
  kind        SeasonLeaderboardKind
  score       Int                   @default(0)
  tieBreaker  Int                   @default(0)
  meta        Json                  @default("{}")
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  @@unique([seasonId, kind, characterId])
  @@index([seasonId, kind, score, tieBreaker])
}

/// Phase 39.0 — Idempotent reward claim guard.
model SeasonRewardClaim {
  id          String       @id @default(cuid())
  seasonId    String
  season      ServerSeason @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  characterId String
  character   Character    @relation(fields: [characterId], references: [id], onDelete: Cascade)
  rewardKey   String
  grantJson   Json         @default("{}")
  claimedAt   DateTime     @default(now())
  createdAt   DateTime     @default(now())

  @@unique([seasonId, characterId, rewardKey])
  @@index([characterId, claimedAt])
  @@index([seasonId, rewardKey])
}

/// Phase 39.0 — Server-wide milestone progress scoped to one season.
model SeasonServerMilestone {
  id           String       @id @default(cuid())
  seasonId     String
  season       ServerSeason @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  milestoneKey String
  metric       String
  target       Int
  progress     Int          @default(0)
  unlockedAt   DateTime?
  effectKey    String?
  meta         Json         @default("{}")
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@unique([seasonId, milestoneKey])
  @@index([seasonId, metric])
  @@index([seasonId, unlockedAt])
}

/// Phase 12.8.B — StoryDungeonRun runtime status. Khác `DungeonRun`:
/// story dungeon = đoạn cốt truyện gắn với main quest, có quest gate +
/// minRealm gate + `oneTime` enforcement (catalog `STORY_DUNGEONS`). Status
/// flow: ACTIVE → CLEARED → CLAIMED. FAILED reserved cho tương lai (player
/// chết / quit) — Phase 12.8.B chưa wire FAILED transition (KHÔNG migrate).
enum StoryDungeonRunStatus {
  ACTIVE
  CLEARED
  CLAIMED
  FAILED
}

/// Phase 12.8.B — StoryDungeonRun runtime persistence (story arc dungeon).
///
/// Tách riêng khỏi `DungeonRun` (farm dungeon) vì:
///   - Khác catalog: `STORY_DUNGEONS` (shared/story-dungeons.ts) thay vì
///     `DUNGEONS` (shared/combat.ts). Story dungeon gate bằng quest +
///     minRealm + oneTime, không gate stamina/dailyLimit.
///   - Khác lifecycle: status enum tách riêng (ACTIVE/CLEARED/CLAIMED/
///     FAILED) — không reuse `DungeonRunStatus.COMPLETED` để keep semantic
///     rõ ràng.
///   - Khác reward path: `STORY_DUNGEON_REWARD` reason riêng cho ledger
///     audit; `refType='StoryDungeonRun'` + `refId=runId`.
///
/// One-time enforcement: nếu `STORY_DUNGEONS[key].oneTime=true`, service
/// reject `start` nếu đã có row `claimedAt != null` cho `(characterId,
/// templateKey)`. Pre-claim ACTIVE run được resume (idempotent) để chống
/// double-create khi network retry.
///
/// Quest integration: khi `clear` thành công, service set
/// `stepProgress[requiredQuestStep]` = step.count + auto-COMPLETE quest
/// nếu mọi step đã đạt count. Re-clear không double-progress (CAS guard
/// `status=ACTIVE` updateMany).
///
/// Reward claim atomic qua `CurrencyService.applyTx` + `InventoryService
/// .grantTx` + `tx.character.update({ exp })` với `reason='STORY_DUNGEON
/// _REWARD'`. Idempotent qua CAS guard `claimedAt=null` updateMany
/// (mirror DungeonRun + QuestService.claim Phase 12 PR-3).
///
/// Indexes:
///   - `[characterId, status]` cho list active run + filter status.
///   - `[characterId, templateKey, status]` cho one-time check + idempotent
///     start (resume pre-claim ACTIVE run).
///   - `[characterId, startedAt]` cho audit history view.
model StoryDungeonRun {
  id             String                @id @default(cuid())
  characterId    String
  /// Match `StoryDungeonTemplateDef.key` từ shared catalog `STORY_DUNGEONS`.
  templateKey    String
  status         StoryDungeonRunStatus @default(ACTIVE)
  /// Index của monster hiện tại trong `template.monsterKeys[]` (0..N).
  /// Khi `currentStep == monsterKeys.length` → CLEARED (claim sẵn sàng).
  currentStep    Int                   @default(0)
  /// JSON list `[{ monsterKey, killedAt: ISO string }]` — log resolution
  /// tracking, dùng cho debug + future stats.
  killedMonsters Json                  @default("[]")
  startedAt      DateTime              @default(now())
  clearedAt      DateTime?
  claimedAt      DateTime?
  updatedAt      DateTime              @updatedAt

  @@index([characterId, status])
  @@index([characterId, templateKey, status])
  @@index([characterId, startedAt])
}

model GiftCode {
  id               String               @id @default(cuid())
  /// Normalized upper-case, unique trên toàn hệ.
  code             String               @unique
  rewardLinhThach  BigInt               @default(0)
  rewardTienNgoc   Int                  @default(0)
  rewardExp        BigInt               @default(0)
  /// JSON [{ itemKey, qty }]
  rewardItems      Json                 @default("[]")
  /// null = không giới hạn số lần redeem toàn server (vẫn chặn 1 user 1 lần).
  maxRedeems       Int?
  redeemCount      Int                  @default(0)
  expiresAt        DateTime?
  revokedAt        DateTime?
  createdByAdminId String?
  createdAt        DateTime             @default(now())
  redemptions      GiftCodeRedemption[]

  @@index([expiresAt])
  @@index([revokedAt])
}

model GiftCodeRedemption {
  id          String   @id @default(cuid())
  giftCodeId  String
  giftCode    GiftCode @relation(fields: [giftCodeId], references: [id], onDelete: Cascade)
  userId      String
  characterId String
  redeemedAt  DateTime @default(now())

  @@unique([giftCodeId, userId])
  @@index([userId])
  @@index([characterId])
}

/// Audit trail mọi thay đổi InventoryItem.qty (Phase 9). Một dòng = một thao
/// tác đổi vật phẩm của 1 character. `qtyDelta` có dấu (âm = trừ / mất / dùng).
model ItemLedger {
  id          String    @id @default(cuid())
  characterId String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  itemKey     String
  /// Có dấu: dương khi grant (boss/mail/giftcode/shop/mission), âm khi consume (use/sell).
  qtyDelta    Int
  reason      String
  refType     String?
  refId       String?
  meta        Json      @default("{}")
  /// Nếu thao tác do admin thực hiện (vd ADMIN_GRANT).
  actorUserId String?
  createdAt   DateTime  @default(now())

  @@index([characterId, createdAt])
  @@index([itemKey, createdAt])
  @@index([reason, createdAt])
  @@index([refType, refId])
  @@index([actorUserId, createdAt])
}

/// Idempotency log cho phần thưởng đăng nhập hằng ngày.
/// Mỗi (character, ngày-local) có tối đa 1 hàng — unique constraint đảm bảo
/// không double-claim. `claimDateLocal` là `YYYY-MM-DD` theo `MISSION_RESET_TZ`
/// (Asia/Ho_Chi_Minh mặc định) để mốc reset trùng với daily mission.
model DailyLoginClaim {
  id             String    @id @default(cuid())
  characterId    String
  character      Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  /// `YYYY-MM-DD` theo timezone reset; vd "2026-04-29".
  claimDateLocal String
  /// Số linh thạch đã trao tại lần claim này (positive). BigInt để khớp Character.linhThach.
  linhThachDelta BigInt
  /// Số ngày liên tiếp đã claim trước + bao gồm lần này (1 nếu mới hoặc bị gãy chuỗi).
  streakAtClaim  Int
  createdAt      DateTime  @default(now())

  @@unique([characterId, claimDateLocal])
  @@index([characterId, createdAt])
}

/// Phase 13.1.A — Sect War (Tông Môn Chiến) tuần lễ contribution log.
/// Mỗi row = 1 lần activity → cộng `points` cho `sectId` trong `weekKey`.
///
/// Idempotency: composite UNIQUE
/// `(weekKey, characterId, activityKey, sourceType, sourceId)`. Cùng activity
/// + cùng sourceId trong cùng tuần chỉ ghi 1 row (retry endpoint không double).
/// `sourceId = null` cũng được phép (vd activity không có dependent entity);
/// trong PostgreSQL NULL ≠ NULL ⇒ multiple null rows được phép. Activity hooks
/// hiện tại luôn có sourceId không null (DungeonRun.id, WorldBoss.id+charId,
/// claimDateLocal, questKey).
///
/// `sectId` snapshot tại commit time — nếu character đổi sect giữa tuần
/// (rời + join sect khác), điểm cũ vẫn ở sect cũ (history-true). Leaderboard
/// aggregate sum theo `sectId` trong `weekKey`.
///
/// Indexes:
///   - `[weekKey, sectId]` cho leaderboard sum query.
///   - `[weekKey, characterId]` cho personal status / breakdown.
///   - UNIQUE composite cho idempotency.
model SectWarContribution {
  id          String   @id @default(cuid())
  /// ISO week key, format `YYYY-Www` (vd "2026-W19").
  weekKey     String
  sectId      String
  characterId String
  /// Match `SectWarActivityKey` từ shared catalog.
  activityKey String
  /// Match `SectWarSourceType` (vd "DungeonRun", "WorldBoss", "DailyLoginClaim", "Quest").
  sourceType  String
  /// Optional source entity id (vd dungeonRunId / bossId+characterId / claimDateLocal / questKey).
  sourceId    String?
  /// Số điểm cộng vào sect — server-authoritative từ catalog (FE không gửi).
  points      Int
  createdAt   DateTime @default(now())

  @@unique([weekKey, characterId, activityKey, sourceType, sourceId])
  @@index([weekKey, sectId])
  @@index([weekKey, characterId])
  @@index([weekKey, createdAt])
}

/// Phase 13.1.A — Sect War weekly reward claim log.
/// Mỗi (weekKey, characterId) có tối đa 1 hàng — unique constraint đảm bảo
/// không double-claim race-safe.
///
/// `rewardTierKey` snapshot tại claim time (vd "rank_1", "rank_2_3",
/// "rank_4_10", "participation"). Catalog tier có thể thay đổi qua phase,
/// nhưng row đã claim giữ tier cũ làm audit/replay safe.
///
/// `sectId` snapshot — nếu character đổi sect sau khi claim, không reset.
/// `pointsAtClaim` snapshot personal points dùng để check eligibility
/// (participation tier yêu cầu ≥ minPersonalPoints).
model SectWarWeeklyRewardClaim {
  id                String   @id @default(cuid())
  /// ISO week key (`YYYY-Www`).
  weekKey           String
  sectId            String
  characterId       String
  /// Match `SectWarRewardTierKey` từ shared catalog.
  rewardTierKey     String
  /// Snapshot points cá nhân tại thời điểm claim (audit + breakdown view).
  pointsAtClaim     Int
  /// Snapshot rank của Sect tại claim time (1-based).
  sectRankAtClaim   Int
  /// Snapshot tổng điểm Sect tại claim time.
  sectPointsAtClaim Int
  claimedAt         DateTime @default(now())

  @@unique([weekKey, characterId])
  @@index([weekKey, sectId])
  @@index([characterId, claimedAt])
}

/// Phase 13.1.B — Sect Mission claim log (idempotency dedupe).
/// Mỗi `(characterId, missionKey, periodKey)` tối đa 1 row — UNIQUE đảm bảo
/// claim không double dù retry. `periodKey` format:
///   - DAILY  → `YYYY-MM-DD` theo `MISSION_RESET_TZ` (Asia/Ho_Chi_Minh).
///   - WEEKLY → `YYYY-Www` ISO week (cùng helper với SectWar).
///
/// `rewardContributionGranted` snapshot tại claim time (audit).
model SectMissionClaim {
  id                        String    @id @default(cuid())
  characterId               String
  character                 Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  /// Match key trong shared `SECT_MISSIONS` catalog.
  missionKey                String
  /// Period key dùng để dedupe — mission DAILY/WEEKLY đổi key mỗi reset.
  periodKey                 String
  /// Snapshot reward contribution đã trao (positive Int).
  rewardContributionGranted Int
  claimedAt                 DateTime  @default(now())

  @@unique([characterId, missionKey, periodKey])
  @@index([characterId, claimedAt])
  @@index([missionKey, periodKey])
}

/// Phase 13.1.B — Sect Shop purchase log + idempotency / window aggregation.
/// Mỗi row = 1 lần buy (multiple buys của cùng entry trong cùng ngày tạo
/// nhiều row). Daily/weekly limit compute từ SUM `qty` trong window.
///
/// `contributionSpent` snapshot cost (`def.contributionCost * qty`) tại
/// commit time — catalog có thể đổi giá tương lai, row đã ghi giữ nguyên
/// audit trail.
model SectShopPurchase {
  id                String    @id @default(cuid())
  characterId       String
  character         Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  /// Match key trong shared `SECT_SHOP_ENTRIES`.
  entryKey          String
  /// Item key shipped (snapshot — match `SectShopEntryDef.itemKey`).
  itemKey           String
  qty               Int
  contributionSpent Int
  /// Period key DAILY (`YYYY-MM-DD` theo `MISSION_RESET_TZ`) tại commit time —
  /// dùng SUM(qty) trong window làm `dailyLimit` enforcement (faster query
  /// hơn so với date-range filter, indexable).
  dailyPeriodKey    String
  /// Period key WEEKLY (`YYYY-Www` ISO) tại commit time — dùng SUM(qty) cho
  /// `weeklyLimit` enforcement.
  weeklyPeriodKey   String
  createdAt         DateTime  @default(now())

  @@index([characterId, entryKey, dailyPeriodKey])
  @@index([characterId, entryKey, weeklyPeriodKey])
  @@index([characterId, createdAt])
}

/// Phase 13.1.B — Sect Contribution Ledger.
/// Mỗi mutate `Character.sectContribBalance` + `sectContribLifetime` ghi 1
/// row. `delta` ký:
///   - dương: earn (mission claim, admin grant, optional sect war reward).
///   - âm:    spend (sect shop buy).
///
/// Reason whitelist:
///   - `SECT_MISSION_CLAIM`
///   - `SECT_SHOP_BUY`
///   - `SECT_CONTRIBUTION_SPEND`
///   - `ADMIN_GRANT`
///   - `SECT_WAR_REWARD`
///
/// `refType + refId` trace ngược source — vd `Mission`/missionKey,
/// `SectShop`/entryKey, `SectWarWeeklyRewardClaim`/weekKey.
model SectContributionLedger {
  id          String    @id @default(cuid())
  characterId String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  delta       Int
  reason      String
  refType     String?
  refId       String?
  meta        Json      @default("{}")
  actorUserId String?
  createdAt   DateTime  @default(now())

  @@index([characterId, createdAt])
  @@index([reason, createdAt])
}

/// Phase 13.2.B — Sect Season milestone claim log (idempotency dedupe).
///
/// Mỗi `(characterId, seasonKey, milestoneKey)` tối đa 1 row — UNIQUE đảm
/// bảo claim không double dù retry hoặc race (2 promise concurrent → P2002
/// trên row thứ 2). CAS guard kết hợp với insert trước, currency/inventory
/// grant sau cùng tx — fail bất kỳ bước nào sẽ rollback toàn bộ.
///
/// `seasonKey` snapshot — nếu sau này admin retire một season key cũ,
/// row claim cũ vẫn giữ nguyên cho audit.
/// `milestoneKey` snapshot match `SECT_SEASON_MILESTONES[*].key`.
/// `pointsAtClaim` snapshot personal points tại commit time — dùng cho
/// audit, breakdown view, và replay nếu catalog requiredPoints đổi.
/// `rewardSnapshot` JSON copy của `def.reward` tại claim time — đảm bảo
/// audit trail vẫn rõ dù catalog reward đổi giá trị tương lai.
model SectSeasonClaim {
  id             String    @id @default(cuid())
  characterId    String
  character      Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  /// Match key trong shared `SECT_SEASONS` catalog (vd `season_2026_s2`).
  seasonKey      String
  /// Match key trong shared `SECT_SEASON_MILESTONES` catalog (vd `milestone_silver`).
  milestoneKey   String
  /// Snapshot personal points tại commit time (audit + replay safe).
  pointsAtClaim  Int
  /// Snapshot reward grant `{ linhThach?, tienNgoc?, items?, titleKey?,
  /// buffKey? }` tại commit time. Catalog reward có thể đổi tương lai —
  /// row đã claim giữ snapshot làm audit/replay safe.
  rewardSnapshot Json
  claimedAt      DateTime  @default(now())

  @@unique([characterId, seasonKey, milestoneKey])
  @@index([characterId, claimedAt])
  @@index([seasonKey, milestoneKey])
}

/// Phase 13.2.C — Sect Season Snapshot header (Hall of Fame foundation).
/// Mỗi `seasonKey` đã chốt có tối đa 1 row. PRIMARY KEY trên `seasonKey`
/// đảm bảo idempotent snapshot — caller `snapshotSeason()` lần đầu insert
/// thành công, lần sau return existing (no-op).
///
/// Denormalized champion/mvp slice phục vụ history list view không cần
/// JOIN sang `SectSeasonSectRank` / `SectSeasonTopMember`. Snapshot tên
/// tại `finalizedAt` — nếu sect rename / character rename về sau, history
/// view vẫn show tên cũ (audit-correct).
///
/// Rollback: DROP table — không ảnh hưởng `SectWarContribution` (no FK).
model SectSeasonSnapshot {
  /// Stable season key (vd `season_2026_s2`) match shared `SECT_SEASONS[*].key`.
  seasonKey         String   @id
  finalizedAt       DateTime @default(now())
  /// Tổng số sect có ít nhất 1 contribution row trong season window.
  totalSects        Int
  /// Tổng số character có ít nhất 1 contribution row trong season window.
  totalContributors Int
  /// Tổng `points` cộng dồn của mọi contribution row trong season.
  totalPoints       Int
  /// Snapshot rank-1 sect (null nếu season không có contribution nào).
  championSectId    String?
  championSectName  String?
  championPoints    Int?
  /// Snapshot top-1 cá nhân (null nếu không có contributor nào).
  mvpCharacterId    String?
  mvpCharacterName  String?
  mvpSectId         String?
  mvpSectName       String?
  mvpPoints         Int?

  @@index([finalizedAt(sort: Desc)])
}

/// Phase 13.2.C — Sect Season Sect Rank row (snapshot rank-row của Sect
/// trong 1 season đã chốt). TOP N (default 10) theo total points.
///
/// UNIQUE `(seasonKey, sectId)` đảm bảo 1 sect chỉ có 1 row / season.
/// UNIQUE `(seasonKey, rank)` đảm bảo rank không trùng. Cả 2 ghi trong
/// cùng tx với `SectSeasonSnapshot` insert → rollback nguyên khối.
model SectSeasonSectRank {
  id               String @id @default(cuid())
  seasonKey        String
  sectId           String
  /// Snapshot tên sect tại finalize.
  sectName         String
  /// 1-based rank trong season (1 = top).
  rank             Int
  points           Int
  contributors     Int
  weeksContributed Int

  @@unique([seasonKey, sectId])
  @@unique([seasonKey, rank])
  @@index([seasonKey])
  @@index([sectId, rank])
}

/// Phase 13.2.C — Sect Season Top Member (snapshot cá nhân top-N
/// contributor trong 1 season). UNIQUE `(seasonKey, characterId)` đảm bảo
/// 1 character / season. UNIQUE `(seasonKey, rank)` đảm bảo rank không
/// trùng. Tên + sect snapshot tại finalize — nếu character rename / đổi
/// sect, hall of fame vẫn reflect đúng season cũ.
model SectSeasonTopMember {
  id            String  @id @default(cuid())
  seasonKey     String
  characterId   String
  characterName String
  /// Sect tại thời điểm finalize (null nếu character không có sect).
  sectId        String?
  sectName      String?
  /// 1-based rank cá nhân trong season.
  rank          Int
  points        Int

  @@unique([seasonKey, characterId])
  @@unique([seasonKey, rank])
  @@index([seasonKey])
  @@index([characterId, rank])
}

/// Phase 13.1.B — LiveOps event override (admin LiveOps controls).
/// Mỗi row = override 1 event key trong `LIVE_OPS_EVENTS` catalog. `enabled`
/// toggle (false = ẩn event khỏi `liveOpsEventsForToday`). `startsAt`/`endsAt`
/// optional override window (caller dùng cho hot-fix Limited Time Event).
///
/// `updatedBy` (User.id) audit trail; `reason` for log/debug. UNIQUE `key`
/// → upsert pattern (insert nếu chưa có, update nếu đã tồn tại).
model LiveOpsEventOverride {
  id        String    @id @default(cuid())
  /// LiveOps event key (match `LIVE_OPS_EVENTS[*].key`).
  key       String    @unique
  enabled   Boolean
  startsAt  DateTime?
  endsAt    DateTime?
  reason    String?
  updatedBy String
  updatedAt DateTime  @updatedAt
  createdAt DateTime  @default(now())

  @@index([enabled, updatedAt])
}

/// Phase 15.1–15.2 — LiveOps Event Scheduler Core.
///
/// Khác `LiveOpsEventOverride` (override catalog tĩnh `LIVE_OPS_EVENTS`),
/// model này là event row động fully-defined-in-DB cho admin tạo runtime
/// mà KHÔNG cần deploy code. `key` UNIQUE để admin reference + idempotent
/// upsert.
///
/// Status string-typed (không Prisma enum) để forward-compat: thêm status
/// mới (vd `PAUSED`) không cần migration. Validate ở shared
/// `isValidLiveOpsScheduledEventStatus`.
///
/// Status lifecycle (cron 5-phút recompute idempotent — Phase 13.2.D pattern):
///   - `DRAFT`     — admin tạo, chưa schedule.
///   - `SCHEDULED` — admin enable, đợi `startsAt`.
///   - `ACTIVE`    — `now ≥ startsAt < endsAt` (auto-transition).
///   - `ENDED`     — `now ≥ endsAt` (auto-transition, terminal).
///   - `DISABLED`  — admin disable (kill switch, không tự recover).
///
/// Type string-typed match `LiveOpsScheduledEventType` catalog
/// (`DOUBLE_DUNGEON_DROP`, `CULTIVATION_EXP_BOOST`, `SHOP_DISCOUNT`,
/// `SECT_SHOP_DISCOUNT`, `DAILY_LOGIN_BONUS`, `BOSS_REWARD_BOOST`,
/// `FESTIVAL_GIFT`).
///
/// `configJson` shape: `{ multiplier?: number, rewardJson?: object }`.
/// Server-authoritative cap qua `clampLiveOpsMultiplier` — defense-in-depth
/// dù DB row cũ.
model LiveOpsScheduledEvent {
  id               String   @id @default(cuid())
  /// Stable cross-FE/BE event key. Pattern: `^[a-z0-9][a-z0-9_-]{1,62}[a-z0-9]$`.
  key              String   @unique
  type             String
  title            String
  description      String   @default("")
  status           String   @default("DRAFT")
  startsAt         DateTime
  endsAt           DateTime
  /// `{ multiplier?: number, rewardJson?: object }`. Validated ở shared
  /// `validateLiveOpsScheduledEventInput`.
  configJson       Json     @default("{}")
  /// Admin user.id tạo event. SET NULL nếu admin bị xoá (audit history giữ).
  createdByAdminId String?
  createdByAdmin   User?    @relation("LiveOpsScheduledEventCreatedBy", fields: [createdByAdminId], references: [id], onDelete: SetNull)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  rewardClaims LiveOpsEventRewardClaim[]

  @@index([status, startsAt])
  @@index([status, endsAt])
  @@index([type, status])
}

/// Phase 15.3.B — LiveOps Announcement (banner / marquee).
///
/// Khác `LiveOpsScheduledEvent` (event runtime modifier — boost / discount /
/// festival gift), model này là tin nhắn / banner hiển thị cho người chơi:
/// thông báo bảo trì, quảng bá event, cảnh báo, news. KHÔNG ảnh hưởng
/// gameplay runtime — chỉ UX / communication layer.
///
/// Status lifecycle (cron 5-phút recompute idempotent — Phase 13.2.D pattern):
///   - `DRAFT`     — admin tạo, chưa schedule.
///   - `SCHEDULED` — admin enable, đợi `startsAt`.
///   - `ACTIVE`    — `now ≥ startsAt < endsAt` (auto-transition + WS
///     broadcast `ANNOUNCEMENT_ACTIVE`).
///   - `ENDED`     — `now ≥ endsAt` (auto-transition + WS broadcast
///     `ANNOUNCEMENT_ENDED`, terminal).
///   - `DISABLED`  — admin disable (kill switch, không tự recover).
///
/// Severity / target string-typed (forward-compat, validator ở shared
/// `validateLiveOpsAnnouncementInput`):
///   - severity: INFO / EVENT / WARNING / MAINTENANCE.
///   - target: ALL / AUTHENTICATED / ADMIN_ONLY.
///
/// Title / message multi-locale (`titleVi`/`titleEn`/`messageVi`/`messageEn`).
/// `*En` nullable — fallback `*Vi` ở FE khi chưa dịch.
///
/// Public endpoint `GET /liveops/announcements/active` strip
/// `createdByAdminId` + `disabledAt` — chỉ trả public-safe fields.
model LiveOpsAnnouncement {
  id               String    @id @default(cuid())
  /// Stable cross-FE/BE announcement key. Pattern: `^[a-z0-9][a-z0-9_-]{1,78}[a-z0-9]$`.
  key              String    @unique
  severity         String    @default("INFO")
  status           String    @default("DRAFT")
  target           String    @default("ALL")
  titleVi          String
  titleEn          String?
  messageVi        String
  messageEn        String?
  startsAt         DateTime
  endsAt           DateTime
  /// Admin user.id tạo announcement. SET NULL nếu admin bị xoá (audit history giữ).
  createdByAdminId String?
  createdByAdmin   User?     @relation("LiveOpsAnnouncementCreatedBy", fields: [createdByAdminId], references: [id], onDelete: SetNull)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  /// Set khi admin gọi `/disable`. Idempotent — chỉ set lần đầu, không
  /// override nếu admin tắt lại announcement DISABLED.
  disabledAt       DateTime?

  @@index([status, startsAt])
  @@index([status, endsAt])
  @@index([severity, status])
}

/// Phase 15.1–15.2 — One-time reward claim cho event type `FESTIVAL_GIFT`.
///
/// `(eventId, characterId)` UNIQUE → claim exactly once per character per
/// event. `rewardJson` snapshot theo `configJson.rewardJson` ở thời điểm
/// claim (audit trail dù admin sửa event sau đó).
///
/// Phase 15.1 phase này stub: persistence + UNIQUE guard. Service grant
/// item/currency wire ở Phase 15.3+ (festival gift redeem flow).
model LiveOpsEventRewardClaim {
  id          String                @id @default(cuid())
  eventId     String
  event       LiveOpsScheduledEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  characterId String
  character   Character             @relation(fields: [characterId], references: [id], onDelete: Cascade)
  claimedAt   DateTime              @default(now())
  rewardJson  Json                  @default("{}")

  @@unique([eventId, characterId])
  @@index([characterId, claimedAt(sort: Desc)])
}

/// Phase 14.0.A — Sect Territory Influence Foundation.
/// Mỗi row = 1 lần character contribute điểm influence cho `sectId` trong
/// `regionKey`. Hooks ghi: dungeon clear, boss participation, boss top
/// damage. Sect mission KHÔNG hook (mission không gắn region — defer).
///
/// Idempotency: composite UNIQUE
///   `(regionKey, characterId, sourceKey, sourceType, sourceId)`
/// — retry hook cùng entity (vd cùng dungeonRunId / `bossId:characterId`)
/// chỉ ghi 1 row, không double điểm. PostgreSQL NULL ≠ NULL ⇒ row có
/// `sourceId NULL` không chạm UNIQUE; hooks hiện tại luôn truyền
/// non-null sourceId.
///
/// `sectId` snapshot tại commit time — nếu character đổi sect (rời + join
/// sect khác), điểm cũ vẫn ở sect cũ (history-true). Leaderboard
/// aggregate sum theo `sectId` filter `regionKey`.
///
/// Indexes:
///   - `[regionKey, sectId]` cho leaderboard sum (`SUM(points) GROUP BY
///     sectId WHERE regionKey=...`).
///   - `[regionKey, characterId]` cho personal contribution / cap check
///     (`SUM(points) WHERE regionKey=... AND characterId=...`).
///   - `[regionKey, createdAt]` cho admin replay/audit.
///   - UNIQUE composite cho idempotency.
///
/// Rollback: DROP bảng — không ảnh hưởng các bảng khác (no FK ngoài).
/// Hooks ở dungeon-run/boss service có try/catch swallow → no-op khi
/// bảng vắng mặt giữa migration window.
model SectTerritoryInfluence {
  id          String   @id @default(cuid())
  /// Match `RegionKey` từ shared `MAP_REGIONS` (vd `son_coc`, `kim_son_mach`).
  regionKey   String
  sectId      String
  characterId String
  /// Match `TerritoryInfluenceSourceKey` từ shared catalog
  /// (`dungeon_clear`, `boss_participation`, `boss_top_damage`).
  sourceKey   String
  /// Match `TerritoryInfluenceSourceType` (`DungeonRun`, `WorldBoss`).
  sourceType  String
  /// Optional source entity id (vd dungeonRunId / `bossId:characterId`).
  sourceId    String?
  /// Số điểm cộng vào sect — server-authoritative từ catalog (FE không gửi).
  points      Int
  createdAt   DateTime @default(now())

  @@unique([regionKey, characterId, sourceKey, sourceType, sourceId])
  @@index([regionKey, sectId])
  @@index([regionKey, characterId])
  @@index([regionKey, createdAt])
}

/// Phase 14.0.B — Territory Region Ownership State.
/// Tracks current owner sect of each region. Exactly 1 row per regionKey.
/// Updated atomically during settlement. ownerSectId NULL = unclaimed.
///
/// Rollback: DROP bảng — hooks đọc owner sẽ no-op khi bảng vắng mặt.
model SectTerritoryRegionState {
  regionKey     String    @id
  ownerSectId   String?
  ownerSectName String?
  periodKey     String?
  settledAt     DateTime?
  updatedAt     DateTime  @updatedAt
  createdAt     DateTime  @default(now())

  @@index([ownerSectId])
}

/// Phase 14.0.B — Territory Settlement Snapshot (history).
/// Mỗi row = 1 settlement event cho 1 region trong 1 period.
/// Idempotency: UNIQUE `(regionKey, periodKey)` — gọi settlement nhiều lần
/// cùng period chỉ ghi 1 row (P2002 swallow → read existing).
///
/// `winnerSectName` denormalized snapshot — audit trail không đổi khi sect
/// rename. `winnerPoints` / `runnerUpSectId` cho context.
///
/// Rollback: DROP bảng — independent, no FK.
model SectTerritorySettlementSnapshot {
  id               String   @id @default(cuid())
  regionKey        String
  periodKey        String
  winnerSectId     String?
  winnerSectName   String?
  winnerPoints     Int      @default(0)
  runnerUpSectId   String?
  runnerUpSectName String?
  runnerUpPoints   Int      @default(0)
  totalSects       Int      @default(0)
  totalPoints      Int      @default(0)
  settledAt        DateTime @default(now())
  settledBy        String?

  @@unique([regionKey, periodKey])
  @@index([periodKey])
  @@index([regionKey, settledAt])
}

/// Phase 14.0.C — Territory Influence Decay Log.
/// Mỗi row = 1 decay event cho 1 periodKey. UNIQUE periodKey cho idempotency
/// — admin gọi `POST /admin/territory/decay?periodKey=...` nhiều lần cùng
/// period chỉ thực thi 1 lần (P2002 swallow → trả `skipped: true`).
///
/// `decayBps` = decay rate basis points (0..5000). `pointsBefore`/
/// `pointsAfter` denormalized snapshot tổng điểm trước/sau decay
/// (audit trail). `rowsAffected` = số influence row bị scale điểm.
///
/// Rollback: DROP bảng — independent, no FK. Gọi decay lần kế tiếp
/// sẽ chạy lại từ đầu (không có log → không idempotency).
model SectTerritoryDecayLog {
  id           String   @id @default(cuid())
  periodKey    String   @unique
  decayBps     Int
  rowsAffected Int      @default(0)
  pointsBefore Int      @default(0)
  pointsAfter  Int      @default(0)
  triggeredBy  String?
  triggeredAt  DateTime @default(now())

  @@index([triggeredAt])
}

/// Phase 14.0.E — Territory Owner Reward Mail Grant audit row.
/// 1 row = 1 (periodKey, regionKey, characterId) tuple. UNIQUE composite
/// `(periodKey, regionKey, characterId)` enforce idempotency: admin gọi
/// `POST /admin/territory/rewards/grant-weekly` nhiều lần cùng `periodKey`
/// KHÔNG gửi mail trùng cho cùng character. `mailId` nullable cho dryRun
/// hoặc trường hợp grant row đã tạo nhưng mail chưa create xong (race
/// recover: grant row giữ vai trò "lock", mail create theo sau in cùng
/// transaction — `mailId` set đúng id sau khi mail thành công).
///
/// `rewardJson` denormalized snapshot reward def tại thời điểm grant
/// (linhThach / exp / itemRewards) — audit trail không đổi nếu catalog
/// shared thay đổi sau này. `sectId` snapshot tại thời điểm grant
/// (member rời sect sau grant vẫn giữ row history sect cũ).
///
/// Rollback: DROP bảng — independent (FK nullable Mail / Character không
/// constraint). Caller cleanup mail + ledger nếu rollback grant batch.
model TerritoryOwnerRewardGrant {
  id          String   @id @default(cuid())
  periodKey   String
  regionKey   String
  sectId      String
  characterId String
  mailId      String?
  /// JSON snapshot reward def: { linhThach, exp, itemRewards: [{itemKey, qty}] }.
  rewardJson  Json
  grantedAt   DateTime @default(now())

  @@unique([periodKey, regionKey, characterId])
  @@index([periodKey])
  @@index([regionKey])
  @@index([sectId])
  @@index([characterId])
}

/// Phase 15.7 — Sect Season Champion / MVP reward grant audit row.
///
/// 1 row = 1 (seasonKey, rewardType, characterId) tuple. UNIQUE composite
/// `(seasonKey, rewardType, characterId)` enforce idempotency:
///   - Cron `runSectSeasonCycle` chạy 2 lần cùng season → row thứ 2 P2002,
///     skip → KHÔNG gửi mail trùng.
///   - Admin manual `POST /admin/sect-season/cron/run-now` cùng season →
///     cũng dedupe.
///
/// `rewardType`:
///   - `CHAMPION` — member của sect rank-1 (snapshot từ `SectSeasonSnapshot.
///     championSectId`). Có nhiều row cho 1 season (1 row / member của
///     champion sect, capped at SECT_SEASON_CHAMPION_MEMBER_CAP).
///   - `MVP` — top-1 cá nhân (snapshot `SectSeasonSnapshot.mvpCharacterId`).
///     Tối đa 1 row CHAMPION-MVP / season.
///
/// `mailId` nullable cho phép race recover (grant row tạo trước, mail
/// create theo sau trong cùng tx). `rewardJson` denormalized snapshot reward
/// def tại thời điểm grant — catalog có thay đổi sau cũng không đổi audit.
///
/// `sectId` snapshot tại grant time (member rời sect sau grant vẫn giữ row
/// history). Cho MVP, `sectId` là sect hiện tại của character tại finalize.
///
/// Rollback: DROP table — independent. Caller cleanup mail + ledger nếu
/// rollback grant batch.
model SectSeasonRewardGrant {
  id          String   @id @default(cuid())
  /// Match `SECT_SEASONS[*].key` shared catalog.
  seasonKey   String
  /// `CHAMPION` (per-member của champion sect) hoặc `MVP` (top-1 individual).
  rewardType  String
  characterId String
  /// Sect ID tại thời điểm grant (snapshot). Null cho MVP nếu character không có sect.
  sectId      String?
  /// Mail row id (nullable cho dryRun / race recover).
  mailId      String?
  /// JSON snapshot reward def: { linhThach, exp, itemRewards: [{itemKey, qty}] }.
  rewardJson  Json
  grantedAt   DateTime @default(now())

  @@unique([seasonKey, rewardType, characterId])
  @@index([seasonKey])
  @@index([rewardType])
  @@index([characterId])
  @@index([sectId])
}

/// Phase 15.8 — Sect Season Champion membership snapshot (audit-perfect).
///
/// Mục tiêu: Champion reward grant phải dựa trên membership **tại thời
/// điểm season finalize** thay vì current membership. Snapshot chốt
/// danh sách characterId của champion sect lúc `snapshotSeason()` chạy,
/// để reward service grant đúng người dù member rời sect sau finalize.
///
/// Idempotent qua UNIQUE `(seasonKey, sectId, rank)`. Cron retry không
/// duplicate row.
///
/// Cap 100 member/season (deterministic order `characterId ASC`) — match
/// `SECT_SEASON_CHAMPION_MEMBER_CAP`. Sect quá đông thì lấy 100 ID đầu.
///
/// `memberCharacterIdsJson`: JSON array string IDs, deterministic order.
/// `rank` = 1 cho champion; reserve cho future top-N champion expand
/// (vd top-3 sect rewards) — Phase 15.8 chỉ dùng rank=1.
///
/// Rollback: DROP table. Reward service fallback current membership +
/// log warning nếu snapshot không tồn tại (legacy season pre-15.8).
model SectSeasonChampionSnapshot {
  id                     String   @id @default(cuid())
  seasonKey              String
  sectId                 String
  rank                   Int      @default(1)
  /// JSON array `string[]` characterIds, `characterId ASC` deterministic.
  memberCharacterIdsJson Json
  /// Số member trong snapshot (sau cap). Denormalized cho admin/audit query.
  memberCount            Int
  createdAt              DateTime @default(now())

  @@unique([seasonKey, sectId, rank])
  @@index([seasonKey])
  @@index([sectId])
}

/// Phase 16.5 — Daily Reward Cap accum bucket per `(characterId, dayBucket, source)`.
///
/// Mục tiêu: theo dõi tổng EXP / linhThach mà 1 character đã được grant
/// trong 1 ngày local từ 1 nguồn cụ thể (CULTIVATION/DUNGEON/MISSION).
/// Service `RewardCapService.applyCapTx` đọc + update row này trong cùng
/// transaction với grant để cap chính xác (race-safe).
///
/// `dayBucket` = `YYYY-MM-DD` theo timezone reset (env
/// `DAILY_REWARD_CAP_TZ`, default `Asia/Ho_Chi_Minh`) — KHÔNG dùng
/// `DateTime` để tránh phụ thuộc giờ chính xác commit time + tránh
/// conflict timezone. Reset tự nhiên qua thay đổi `dayBucket` chuỗi
/// (no cron cần). Sang ngày mới: lookup miss → bucket mới với accum=0.
///
/// `source` = `RewardSource` từ shared catalog
/// (`packages/shared/src/daily-reward-cap.ts`) — string để forward-compat
/// thêm source mới mà không cần migration enum.
///
/// Idempotency: `@@unique([characterId, dayBucket, source])` — cùng
/// character + ngày + source chỉ có 1 row. Race 2 grant concurrent →
/// upsert + CAS guard `expAccum`/`linhThachAccum` cũ; thread thua
/// retry compute cap với accum mới (xem `RewardCapService.applyCapTx`).
///
/// Indexes:
///   - UNIQUE composite (idempotency).
///   - `[dayBucket]` cho admin/ops query "ai chạm cap hôm nay".
///   - `[characterId, source]` (đã ở UNIQUE prefix) cho lookup nhanh.
model CharacterDailyRewardBucket {
  id             String    @id @default(cuid())
  characterId    String
  character      Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  /// `YYYY-MM-DD` theo timezone reset (default Asia/Ho_Chi_Minh).
  dayBucket      String
  /// `RewardSource`: 'CULTIVATION' | 'BODY_CULTIVATION' | 'DUNGEON' | 'MISSION' (forward-compat).
  source         String
  /// Tổng EXP đã được grant từ source này trong dayBucket. BigInt khớp Character.exp.
  expAccum       BigInt    @default(0)
  /// Tổng linh thạch đã được grant từ source này trong dayBucket. BigInt khớp Character.linhThach.
  linhThachAccum BigInt    @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([characterId, dayBucket, source])
  @@index([dayBucket])
}

/// Phase 16.5 — Reward cap event log (audit trail).
///
/// Ghi MỖI lần `applyCapTx` quyết định cap > 0 (`wasCapped=true`) — vd
/// player request 100 EXP nhưng chỉ grant 30, log lại 70 EXP bị cắt
/// để admin / anomaly scanner sau này có dữ liệu ngữ cảnh.
///
/// KHÔNG ghi khi `wasCapped=false` (giữ table nhỏ + signal-noise cao).
/// Admin truy vấn theo `(characterId, dayBucket)` để hiểu vì sao 1
/// player chạm cap.
///
/// `requested*` / `granted*` / `cappedAmount*` đều BigInt khớp domain
/// values. `reason` text mô tả ngắn (vd "exp cap reached for DUNGEON").
/// `meta` JSONB cho ngữ cảnh thêm (refType, refId, dungeon templateKey,
/// missionKey, …) — query dễ qua Prisma JSON path.
model RewardCapEvent {
  id                 String    @id @default(cuid())
  characterId        String
  character          Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  dayBucket          String
  source             String
  requestedExp       BigInt
  requestedLinhThach BigInt
  grantedExp         BigInt
  grantedLinhThach   BigInt
  cappedExp          BigInt
  cappedLinhThach    BigInt
  reason             String
  refType            String?
  refId              String?
  meta               Json      @default("{}")
  createdAt          DateTime  @default(now())

  @@index([characterId, dayBucket])
  @@index([dayBucket, source])
  @@index([createdAt])
}

/// Phase 26.2 — Drop Economy V2 daily cap counter.
///
/// Track quantity granted per (character, rule, dayBucket) để enforce
/// `MaterialDropRule.maxDailyQty`. `ruleKey` = MaterialDropRule.key
/// (vd `huyet_tinh_t1__BOSS`). Reset hằng ngày theo timezone server
/// (Asia/Ho_Chi_Minh).
///
/// Server-authoritative — KHÔNG trust client. Service `DropEconomyService`
/// atomic upsert + increment trong cùng transaction với `inventory.grant`
/// để chống race (kill 2 mob đồng thời không bypass cap).
model DailyMaterialCap {
  id               String    @id @default(cuid())
  characterId      String
  character        Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  /// `YYYY-MM-DD` theo timezone reset.
  dayBucket        String
  /// `MaterialDropRule.key` (vd `huyet_tinh_t1__BOSS`).
  ruleKey          String
  /// Snapshot category/tier để query analytics (admin dashboard cap usage).
  materialCategory String
  materialTier     Int
  source           String
  /// Tổng qty đã grant trong dayBucket cho rule này.
  qtyAccum         Int       @default(0)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@unique([characterId, dayBucket, ruleKey])
  @@index([dayBucket])
  @@index([characterId, dayBucket])
}

/// Phase 26.2 — Drop Economy V2 weekly cap counter (rare/world-boss only).
///
/// Track quantity granted per (character, rule, weekBucket) cho rule có
/// `maxWeeklyQty` (ARTIFACT_CRAFT từ WORLD_BOSS, TRIBULATION endgame, …).
/// `weekBucket` = ISO week string `YYYY-Www` theo timezone server.
model WeeklyMaterialCap {
  id               String    @id @default(cuid())
  characterId      String
  character        Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  /// ISO week `YYYY-Www` theo timezone reset.
  weekBucket       String
  ruleKey          String
  materialCategory String
  materialTier     Int
  source           String
  qtyAccum         Int       @default(0)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@unique([characterId, weekBucket, ruleKey])
  @@index([weekBucket])
  @@index([characterId, weekBucket])
}

/// Phase 16.6 — Economy Ledger Checker Cron run audit.
///
/// Mỗi lần ledger checker cron (`LEDGER_CHECKER_CRON`) hoặc admin
/// force-run (`POST /admin/economy/ledger-check/run`) chạy thì tạo 1 row.
/// Idempotent qua UNIQUE `dayBucket` — gọi lại trong cùng ngày sẽ
/// `findUnique` thay vì tạo run trùng (return existing row + summary).
///
/// `summaryJson` ghi tổng kết: `{ charactersScanned, currencyDiscrepancies,
/// inventoryDiscrepancies, negativeBalances, suspiciousDeltas, issuesCreated }`.
/// Dùng để render dashboard "lần cuối check khi nào / phát hiện bao nhiêu".
///
/// `status` ∈ `'RUNNING'|'OK'|'ISSUES_FOUND'|'ERROR'`. `OK` = quét xong
/// và 0 issue, `ISSUES_FOUND` = ≥1 issue OPEN, `ERROR` = exception
/// trong service path (admin coi log trace, không tự ban / không tự fix).
model EconomyLedgerCheckRun {
  id          String                    @id @default(cuid())
  /// `YYYY-MM-DD` theo timezone reset (default Asia/Ho_Chi_Minh).
  /// UNIQUE — 1 ngày chỉ 1 run authoritative.
  dayBucket   String                    @unique
  status      String
  startedAt   DateTime                  @default(now())
  finishedAt  DateTime?
  summaryJson Json                      @default("{}")
  triggeredBy String?
  issues      EconomyLedgerCheckIssue[]
  createdAt   DateTime                  @default(now())

  @@index([startedAt])
}

/// Phase 16.6 — Issue cụ thể được phát hiện trong 1 ledger check run.
///
/// Severity: `INFO` < `WARN` < `CRITICAL`. Default tạo `OPEN` — admin tự
/// `ack` (acknowledge — đã xem, đang xử lý) hoặc `resolve` (đã xử lý xong).
/// PR Phase 16.6 KHÔNG tự auto-fix, chỉ phát hiện và báo cáo.
///
/// `type` tag ngắn: `CURRENCY_LEDGER_MISMATCH`, `ITEM_LEDGER_MISMATCH`,
/// `NEGATIVE_BALANCE`, `REWARD_CAP_INCONSISTENT`, `SUSPICIOUS_DELTA_24H`.
/// `detailsJson` chứa snapshot raw (ledgerSum, characterValue, diff, ...)
/// — để admin reproduce mà không cần re-run query.
model EconomyLedgerCheckIssue {
  id          String                @id @default(cuid())
  runId       String
  run         EconomyLedgerCheckRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  severity    String
  type        String
  characterId String?
  detailsJson Json                  @default("{}")
  status      String                @default("OPEN")
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  @@index([runId, severity])
  @@index([status, severity, createdAt])
  @@index([type, status])
}

/// Phase 16.6 — Economy Anomaly từ scanner cron (`ECONOMY_ANOMALY_CRON`)
/// hoặc admin endpoint trigger.
///
/// `source` tag rule đã trigger: `CURRENCY_DELTA_24H`, `RARE_ITEM_GAIN_24H`,
/// `REWARD_CAP_BYPASS`, `ADMIN_GRANT_OVER_LIMIT`, `MARKET_OUTLIER`.
/// `windowKey` = identifier cửa sổ thời gian + scope cụ thể, kết hợp
/// `(source, characterId, windowKey)` UNIQUE để idempotent: scanner gọi
/// lại trên cùng cửa sổ KHÔNG tạo anomaly trùng (giảm noise admin).
///
/// `severity` ∈ `INFO|WARN|CRITICAL`. `status` ∈ `OPEN|ACKNOWLEDGED|RESOLVED`.
/// `userId` nullable — set khi `source = ADMIN_GRANT_OVER_LIMIT` cần
/// trace admin nào grant. `characterId` nullable — set khi rule scope
/// theo character (vd `CURRENCY_DELTA_24H` per character).
///
/// Phase 16.6 chính sách: **detection + reporting only**. KHÔNG auto-ban,
/// KHÔNG auto-rollback, KHÔNG public notify. Admin coi panel + tự
/// quyết định (refund/ban/whitelist) qua endpoint khác.
model EconomyAnomaly {
  id          String   @id @default(cuid())
  severity    String
  source      String
  characterId String?
  userId      String?
  detailsJson Json     @default("{}")
  status      String   @default("OPEN")
  windowKey   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([source, characterId, windowKey])
  @@index([status, severity, createdAt])
  @@index([source, createdAt])
  @@index([characterId, createdAt])
  @@index([userId, createdAt])
}

/// Phase 16.3 — Gameplay Anomaly tracking row.
///
/// Khác `EconomyAnomaly` (Phase 16.6):
///   - `EconomyAnomaly` rà soát dòng tiền tổng thể (Σ |delta|
///     linhThạch 24h, RewardCap bypass, market band, admin grant).
///   - `GameplayAnomaly` rà soát hành vi farm bất thường ở từng module
///     gameplay (dungeon / boss / mission / arena / territory) + EXP
///     gain bất thường + item gain bất thường + combat result mismatch.
///
/// Tách bảng riêng để (1) admin filter sạch theo domain; (2) audit
/// history không trộn semantic; (3) future analytics có thể chỉ join
/// đúng bảng cần thiết.
///
/// Lifecycle status: `OPEN → ACKNOWLEDGED → RESOLVED` (mirror
/// `EconomyAnomaly`). Khác `EconomyAnomaly`, model này lưu thêm:
///   - `acknowledgedAt` + `acknowledgedByAdminId` (audit ack).
///   - `resolvedAt` + `resolvedByAdminId` + `resolutionNote` (audit
///     resolve free-form note, sanitized ở caller).
///
/// Idempotency: `@@unique([type, characterId, windowKey])` đảm bảo
/// scanner gọi lại trong cùng cửa sổ KHÔNG tạo duplicate row cho
/// cùng character. Multi-instance race: `prisma.create` raise P2002
/// unique violation → caller catch + skip.
///
/// **KHÔNG** auto-ban / KHÔNG auto-rollback / KHÔNG tự trừ currency
/// / item / EXP / KHÔNG khóa tài khoản — detection-only.
model GameplayAnomaly {
  id                    String    @id @default(cuid())
  /// `GameplayAnomalyType` literal — phân loại chi tiết (vd
  /// `DUNGEON_REWARD_FARM`). Type guard ở
  /// `packages/shared/src/gameplay-anticheat.ts` (`isGameplayAnomalyType`).
  type                  String
  /// `INFO` | `WARN` | `CRITICAL`.
  severity              String
  /// `OPEN` | `ACKNOWLEDGED` | `RESOLVED`. Default OPEN khi tạo.
  status                String    @default("OPEN")
  /// `GameplayAnomalySource` (vd `DUNGEON_RUN`). Fail-soft `OTHER`
  /// cho source lạ qua `coerceGameplayAnomalySource`.
  source                String
  /// `Character.id` liên quan. Nullable cho rule scope không hướng
  /// (vd combat mismatch chưa rõ chủ thể — admin diagnose tay).
  characterId           String?
  /// `User.id` (nếu rule liên quan account-level vd ADMIN_*).
  userId                String?
  /// Identifier cửa sổ thời gian (vd `'1h:2026-05-11T07'`,
  /// `'24h:2026-05-11'`, `'7d:2026-W19'`) — build qua
  /// `buildGameplayAnomalyWindowKey` (shared).
  windowKey             String
  /// Sanitized JSON detail (thresholds, counters, character snapshot).
  /// Phase 16.3 KHÔNG lưu raw IP / token / cookie / refresh hash.
  detailsJson           Json      @default("{}")
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  acknowledgedAt        DateTime?
  /// userId admin/MOD ack. KHÔNG FK để giảm rủi ro cascade khi xoá
  /// admin.
  acknowledgedByAdminId String?
  resolvedAt            DateTime?
  /// userId admin resolve.
  resolvedByAdminId     String?
  /// Note tự do admin nhập khi resolve (≤1000 char, sanitized ở
  /// caller controller).
  resolutionNote        String?

  @@unique([type, characterId, windowKey])
  @@index([status, severity, createdAt])
  @@index([source, createdAt])
  @@index([type, createdAt])
  @@index([characterId, createdAt])
  @@index([userId, createdAt])
}

/// Phase 16.4 — Market Trade Anomaly (detection-only).
///
/// Bổ sung Phase 16.6 (`market-price-band.ts`) — Phase 16.6 reject
/// listing post ngoài rarity band tuyệt đối. Phase 16.4 quan sát
/// PATTERN trong toàn bộ flow market:
///   - `PRICE_EXTREME_LOW` / `PRICE_EXTREME_HIGH` — listing/trade
///     lệch xa reference price (rarity median) ngay cả khi vẫn
///     nằm trong band.
///   - `REPEATED_BUYER_SELLER_PAIR` — cùng cặp (seller, buyer)
///     trade nhiều lần trong 24h/7d (funnel alt account).
///   - `LISTING_SPAM` — 1 seller post quá nhiều listing trong 1h.
///   - `MARKET_VOLUME_SPIKE` — Σ value (price×qty) market của 1
///     character vượt 500k/5M LT trong 24h.
///   - `UNKNOWN_REFERENCE_PRICE` — item không có ItemDef hợp lệ
///     → INFO manual review.
///
/// Tách khỏi `EconomyAnomaly` (Phase 16.6 — economy aggregate /
/// admin grant) và `GameplayAnomaly` (Phase 16.3 — farm pattern)
/// để admin filter sạch theo domain market trade + audit history
/// không trộn semantic.
///
/// Idempotency: `@@unique([type, listingId, windowKey])`. Cho rule
/// per-listing (`PRICE_EXTREME_*`) — `listingId` là listing thật.
/// Cho rule per-character per-window (REPEATED_PAIR / SPAM /
/// VOLUME / UNKNOWN_REFERENCE) — `listingId = ''` (empty string)
/// + dedupe ở `windowKey` (build qua `buildMarketAbuseWindowKey`
/// + scope hash). Multi-instance race → P2002 + skip.
///
/// Detection-only — KHÔNG auto-ban / KHÔNG auto-rollback / KHÔNG
/// trừ currency / item / KHÔNG khóa tài khoản. Admin xem panel
/// + ack/resolve.
model MarketTradeAnomaly {
  id                    String    @id @default(cuid())
  /// `MarketAbuseType` literal (xem
  /// `packages/shared/src/market-trade-abuse.ts`).
  type                  String
  /// `INFO` | `WARN` | `CRITICAL`.
  severity              String
  /// `OPEN` | `ACKNOWLEDGED` | `RESOLVED`. Default OPEN khi tạo.
  status                String    @default("OPEN")
  /// `MarketAbuseSource` ∈ `LISTING_CREATE` | `LISTING_BUY` |
  /// `SCAN_BATCH` | `OTHER`. Fail-soft `OTHER` qua
  /// `coerceMarketAbuseSource`.
  source                String
  /// `Listing.id` cho rule per-listing. Empty string `''` cho rule
  /// per-character per-window (UNIQUE dedupe vẫn hoạt động).
  /// KHÔNG FK để giảm rủi ro cascade khi xoá listing cũ.
  listingId             String    @default("")
  /// `Character.id` của seller. Nullable cho rule không scope
  /// seller (vd UNKNOWN_REFERENCE_PRICE per scan).
  sellerCharacterId     String?
  /// `Character.id` của buyer. Nullable cho rule pre-trade
  /// (listing chưa có buyer).
  buyerCharacterId      String?
  /// Item key trade. Nullable cho rule không scope itemKey
  /// (vd MARKET_VOLUME_SPIKE per character).
  itemKey               String?
  /// Quantity trade snapshot.
  quantity              Int?
  /// Unit price snapshot (BigInt, linh thach).
  unitPrice             BigInt?
  /// Reference price baseline (rarity median hoặc 7-day rolling).
  referencePrice        BigInt?
  /// `unitPrice / referencePrice` ratio (float). Null cho rule
  /// non-price (REPEATED_PAIR / SPAM / VOLUME).
  deviationRatio        Float?
  /// Identifier cửa sổ thời gian (vd `'1h:2026-08-01T07'`,
  /// `'24h:2026-08-01'`, `'7d:2026-W31'`) + scope hash cho rule
  /// per-character per-window.
  windowKey             String
  /// Sanitized JSON detail (counters, snapshot). KHÔNG raw IP /
  /// token / cookie.
  detailsJson           Json      @default("{}")
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  acknowledgedAt        DateTime?
  /// userId admin/MOD ack. KHÔNG FK.
  acknowledgedByAdminId String?
  resolvedAt            DateTime?
  /// userId admin resolve.
  resolvedByAdminId     String?
  /// Note tự do admin khi resolve (≤1000 char).
  resolutionNote        String?

  @@unique([type, listingId, windowKey])
  @@index([status, severity, createdAt])
  @@index([type, createdAt])
  @@index([sellerCharacterId, createdAt])
  @@index([buyerCharacterId, createdAt])
  @@index([itemKey, createdAt])
}

/// Phase 15.4 — Feature Flag DB-backed.
///
/// DB-backed switch cho admin bật/tắt các chức năng quan trọng (Arena,
/// Tribulation Mini-Battle, Reforge/Enchant, LiveOps event/festival/
/// announcement, Territory War, Market, Shop/Sect Shop discount runtime)
/// mà không cần redeploy code. Catalog hardcode shared
/// (`packages/shared/src/feature-flags.ts`) — admin chỉ toggle các key
/// đã khai báo, không tạo flag tùy ý.
///
/// Cache: `FeatureFlagService` đọc qua Redis TTL 30s (fallback in-memory
/// khi Redis lỗi). Admin update → clear cache → flag effect runtime
/// trong ≤ 30s (nếu cache miss / TTL hết).
///
/// Audit: reuse `AdminAuditLog` action `ADMIN_FEATURE_FLAG_UPDATE` —
/// KHÔNG tạo bảng audit riêng. `updatedByAdminId` chỉ ghi admin gần
/// nhất (rotate) cho UX panel hiển thị; full history nằm ở audit log.
///
/// Lazy ensure-default: nếu DB chưa có row cho key, service trả về
/// `defaultEnabled` từ catalog (fail-open). Admin có thể "Refresh
/// defaults" để upsert tất cả keys với defaultEnabled — chuẩn bị seed
/// trước khi cần bật/tắt.
model FeatureFlag {
  id               String   @id @default(cuid())
  /// Stable key — bắt buộc match `FeatureFlagKey` (catalog shared).
  /// Admin update reject nếu key ngoài catalog.
  key              String   @unique
  enabled          Boolean  @default(true)
  /// `FeatureFlagCategory` ∈ `GAMEPLAY|ECONOMY|LIVEOPS|ADMIN|SAFETY`.
  /// Cache vào DB để admin filter UI khỏi cần lookup catalog mỗi lần.
  /// Service ensure-default sync với shared catalog khi seed.
  category         String   @default("GAMEPLAY")
  /// Mô tả admin UI (vi). Cache cho list endpoint.
  description      String   @default("")
  /// Phase 45.0 — optional environment scoping marker (`prod` / `staging` /
  /// `dev`). Nullable = global. Runtime guard chưa đọc field này; field
  /// chỉ phục vụ admin UI gắn tag để filter. Wire runtime defer Phase 45.1.
  environment      String?
  updatedByAdminId String?
  updatedByAdmin   User?    @relation("FeatureFlagUpdatedBy", fields: [updatedByAdminId], references: [id], onDelete: SetNull)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([category])
  @@index([enabled])
  @@index([environment])
}

/// Phase 45.0 — Remote Config Center V1.
///
/// Key/value runtime config admin chỉnh không cần redeploy. Khác với
/// `FeatureFlag` (boolean on/off), `RemoteConfig` lưu nhiều type:
/// `string` / `number` / `boolean` / `json` qua field `valueType` +
/// `valueString` (raw, JSON.stringify cho json).
///
/// Validate: shared `validateRemoteConfigValue` chạy ở admin controller
/// trước khi persist (cap maxLength / range / enum / json bytes).
///
/// Catalog: hardcoded shared `REMOTE_CONFIG_CATALOG` — admin chỉ update
/// được key thuộc catalog. `key` UNIQUE + lazy ensure-default upsert.
///
/// Audit: reuse `AdminAuditLog` action `ADMIN_REMOTE_CONFIG_UPDATE` —
/// KHÔNG tạo bảng audit riêng.
///
/// Cache: 2-tier mirror `FeatureFlagService` (L1 in-memory + L2 Redis,
/// TTL 30s, invalidate on update, fail-open default catalog).
model RemoteConfig {
  id               String   @id @default(cuid())
  /// Stable key — bắt buộc match `RemoteConfigKey` (catalog shared).
  key              String   @unique
  /// `RemoteConfigValueType` ∈ `string|number|boolean|json`. Phải match
  /// catalog — admin không đổi được valueType (catalog là source-of-truth).
  valueType        String
  /// Raw stored value: chuỗi tự nhiên cho string; `String(n)` cho number;
  /// `"true"` / `"false"` cho boolean; `JSON.stringify(...)` cho json.
  /// Service parse khi đọc.
  valueString      String
  /// Optional environment scoping marker (mirror FeatureFlag.environment).
  /// Nullable = global. Runtime chưa wire (defer Phase 45.1).
  environment      String?
  updatedByAdminId String?
  updatedByAdmin   User?    @relation("RemoteConfigUpdatedBy", fields: [updatedByAdminId], references: [id], onDelete: SetNull)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([environment])
}

/// Phase 15.5 — Maintenance Window.
///
/// Admin tạo window bảo trì (DRAFT → SCHEDULED → ACTIVE → ENDED) hoặc
/// disable (DISABLED). Middleware `MaintenanceWindowGuard` đọc cache
/// `MaintenanceWindowService.getActiveWindow(now)` và chặn player khi
/// có window ACTIVE.
///
/// Lifecycle (mirror LiveOpsAnnouncement):
///   - `DRAFT`     — admin chuẩn bị nội dung.
///   - `SCHEDULED` — admin enable, đợi tới `startsAt`.
///   - `ACTIVE`    — cron transition khi `now ≥ startsAt < endsAt`.
///   - `ENDED`     — cron transition khi `now ≥ endsAt`.
///   - `DISABLED`  — admin kill switch (không tự transition).
///
/// Admin bypass:
///   - `allowAdminBypass=true` (default) — ADMIN/MOD vẫn truy cập được
///     mọi route bình thường (trừ khi `target=FULL_LOCKDOWN`).
///   - `allowHealthcheck=true` — cho `/healthz`, `/readyz`, `/version`.
///   - `allowMetrics=true`     — cho `/admin/metrics` (admin-only kiểu cũ;
///     pass middleware nhưng vẫn đi qua AdminGuard).
///
/// Audit:
///   - reuse `AdminAuditLog` action `ADMIN_MAINTENANCE_*` — KHÔNG tạo
///     bảng audit riêng (giảm rủi ro migration).
///
/// Indexes:
///   - `key` UNIQUE — admin lookup + idempotent upsert.
///   - `[status, startsAt]` — cron + getActive query.
///   - `[status, endsAt]`   — cron transition ACTIVE→ENDED.
///   - `[severity, status]` — admin filter UI.
model MaintenanceWindow {
  id               String    @id @default(cuid())
  /// Stable cross-FE/BE maintenance key. Pattern: `^[a-z0-9][a-z0-9_-]{1,78}[a-z0-9]$`.
  key              String    @unique
  /// `MaintenanceWindowStatus` ∈ `DRAFT|SCHEDULED|ACTIVE|ENDED|DISABLED`.
  status           String    @default("DRAFT")
  /// `MaintenanceSeverity` ∈ `INFO|WARNING|CRITICAL`.
  severity         String    @default("INFO")
  /// `MaintenanceTarget` ∈ `ALL_PLAYERS|NON_ADMIN_USERS|API_WRITE_ONLY|FULL_LOCKDOWN`.
  target           String    @default("ALL_PLAYERS")
  titleVi          String
  titleEn          String?
  messageVi        String
  messageEn        String?
  startsAt         DateTime
  endsAt           DateTime
  /// Default true — admin/MOD vẫn truy cập được trừ khi `target=FULL_LOCKDOWN`.
  allowAdminBypass Boolean   @default(true)
  /// Default true — `/healthz`, `/readyz`, `/version` không bị chặn.
  allowHealthcheck Boolean   @default(true)
  /// Default true — `/admin/metrics*` không bị chặn (vẫn qua AdminGuard).
  allowMetrics     Boolean   @default(true)
  /// Admin user.id tạo window. SET NULL nếu admin bị xoá (audit history giữ).
  createdByAdminId String?
  createdByAdmin   User?     @relation("MaintenanceWindowCreatedBy", fields: [createdByAdminId], references: [id], onDelete: SetNull)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  /// Set khi admin gọi `/disable`. Idempotent — chỉ set lần đầu.
  disabledAt       DateTime?

  @@index([status, startsAt])
  @@index([status, endsAt])
  @@index([severity, status])
}

/// Phase 15.6 — Config Version snapshot.
///
/// Mỗi mutation từ admin trên 4 entity admin-managed
/// (`LIVEOPS_EVENT`, `LIVEOPS_ANNOUNCEMENT`, `FEATURE_FLAG`,
/// `MAINTENANCE_WINDOW`) ghi 1 row vào model này. Cho phép admin xem
/// lịch sử thay đổi, diff before/after, dry-run rollback và rollback
/// (tạo 1 row `UPDATE` mới với `afterJson` = snapshot version cũ).
///
/// `entityType` string-typed (forward-compat: thêm `SECT_SEASON_CONFIG`
/// không cần migration). Validate ở shared `isConfigVersionEntityType`.
///
/// `entityId` là id của entity:
///   - LIVEOPS_EVENT          → `LiveOpsScheduledEvent.id` (cuid).
///   - LIVEOPS_ANNOUNCEMENT   → `LiveOpsAnnouncement.id` (cuid).
///   - FEATURE_FLAG           → `FeatureFlag.key` (admin luôn ref bằng key).
///   - MAINTENANCE_WINDOW     → `MaintenanceWindow.id` (cuid).
///
/// `version` tăng tuần tự per (entityType, entityId), bắt đầu từ 1. Service
/// tính `max(version)+1` trong transaction để tránh race.
///
/// `beforeJson` nullable — null cho `CREATE` (chưa có row trước đó).
/// `afterJson` luôn có — snapshot sau khi mutation áp dụng.
///
/// `changedByAdminId` SET NULL khi admin bị xoá (lịch sử giữ).
///
/// Snapshot KHÔNG chứa secret-like field (sanitize ở shared
/// `sanitizeSnapshot` trước khi persist).
///
/// Indexes:
///   - `[entityType, entityId, version]` UNIQUE — tránh duplicate version.
///   - `[entityType, entityId, createdAt]` — list versions newest first.
///   - `[action, createdAt]` — admin filter theo action.
model ConfigVersion {
  id               String   @id @default(cuid())
  entityType       String
  entityId         String
  version          Int
  action           String
  beforeJson       Json?
  afterJson        Json
  changedByAdminId String?
  changedByAdmin   User?    @relation("ConfigVersionChangedBy", fields: [changedByAdminId], references: [id], onDelete: SetNull)
  reason           String?
  createdAt        DateTime @default(now())

  rollbackRuns ConfigRollbackRun[]

  @@unique([entityType, entityId, version])
  @@index([entityType, entityId, createdAt])
  @@index([action, createdAt])
}

/// Phase 15.6 — Config Rollback Run audit.
///
/// Mỗi lần admin gọi dry-run rollback hoặc rollback ghi 1 row vào model
/// này. Hữu ích cho:
///   - Audit history rollback admin đã thực hiện.
///   - Ghi rõ safety level + warnings + status (DRY_RUN / APPLIED /
///     BLOCKED / FAILED) để post-mortem nếu rollback gây sự cố.
///
/// `targetVersionId` ref tới `ConfigVersion.id` của version mà admin
/// muốn rollback về (snapshot source). SET NULL nếu version cũ bị xoá
/// (rare — không xoá tự động Phase 15.6).
///
/// `fromVersion` / `toVersion` là số version (snapshot at compile time,
/// dù DB row có thể bị mutate sau đó).
///
/// `resultJson` lưu summary response trả admin (changedFields,
/// warnings) — phục vụ trace lại.
///
/// `performedByAdminId` SET NULL khi admin bị xoá.
model ConfigRollbackRun {
  id                 String         @id @default(cuid())
  entityType         String
  entityId           String
  fromVersion        Int
  toVersion          Int
  targetVersionId    String?
  targetVersion      ConfigVersion? @relation(fields: [targetVersionId], references: [id], onDelete: SetNull)
  status             String
  safetyLevel        String
  performedByAdminId String?
  performedByAdmin   User?          @relation("ConfigRollbackPerformedBy", fields: [performedByAdminId], references: [id], onDelete: SetNull)
  reason             String?
  resultJson         Json?
  createdAt          DateTime       @default(now())

  @@index([entityType, entityId, createdAt])
  @@index([performedByAdminId, createdAt])
  @@index([status, createdAt])
}

/// Phase 15.8 — LiveOps cron run audit / health tracking.
///
/// Mỗi lần cron job (territory / sect-season / weekly composite) chạy 1
/// chu kỳ sẽ insert 1 row vào bảng này. Dùng cho:
///   - Health monitoring: status endpoint `GET /admin/territory/cron/status`
///     + `GET /admin/sect-season/cron/status` đọc row mới nhất theo
///     `cronKey` để compute `lastRunAt` / `lastSuccessAt` / `lastErrorAt`
///     + status (OK / STALE / DEGRADED) qua shared helper
///     `computeLiveOpsCronHealth`.
///   - Audit: ghi `triggeredBy` (cron = null, admin force-run = userId)
///     + snapshot summary JSON (counts) + error message nếu fail.
///
/// `cronKey` ENUM-like string:
///   - `territory` — `LiveOpsCronService.runTerritoryCycle`.
///   - `sect-season` — `LiveOpsCronService.runSectSeasonCycle`.
///   - `weekly` — `LiveOpsCronService.runWeeklyCycle` (composite wrap).
///
/// `success` rules:
///   - `true` khi cycle return summary với `errors.length === 0` (mọi
///     stage idempotent OK).
///   - `false` khi cycle throw exception NGOÀI lease/DB guard (vd
///     prisma transaction abort, network).
///   - Phase 15.8 lưu cả 2 vào cùng 1 row — finalize bằng update khi
///     cycle xong. Nếu service crash giữa chừng → row remain
///     `finishedAt=null`, status reader treat = "lastRunAt only".
///
/// Rollback: DROP TABLE — bảng độc lập (no FK runtime), không ảnh hưởng
/// cycle logic. Status endpoint chỉ trả `null` health khi bảng rỗng.
model LiveOpsCronRunLog {
  id           String    @id @default(cuid())
  /// `territory` | `sect-season` | `weekly`.
  cronKey      String
  startedAt    DateTime  @default(now())
  finishedAt   DateTime?
  /// True khi cycle return clean (errors=[]); false khi throw hoặc có
  /// `errors[]` non-empty.
  success      Boolean   @default(false)
  /// `null` cho cron-driven run; userId cho admin force-run.
  triggeredBy  String?
  /// JSON snapshot summary (counts) — không log PII / secret.
  summaryJson  Json?
  /// Error message khi `success=false`. Truncated client-side để tránh
  /// log nổ.
  errorMessage String?

  @@index([cronKey, finishedAt(sort: Desc)])
  @@index([cronKey, success, finishedAt(sort: Desc)])
  @@index([cronKey, startedAt(sort: Desc)])
}

// =====================================================================
// Phase 18.1 — Security Rate Limit + Abuse Protection
// =====================================================================
//
// `SecurityEvent` + `SecurityBlock` thuộc Phase 18.1 (Security
// hardening). Phục vụ:
//   - Audit / forensic khi điều tra abuse incident.
//   - Cơ chế fail2ban-style temporary block (`SecurityBlock` row →
//     RateLimitGuard reject request có cùng subjectHash).
//   - Admin Security panel (FE) xem recent events + active blocks +
//     lift block.
//
// **Privacy**:
//   - `ipHash` lưu sha256(salt || ip) — KHÔNG lưu raw IP. Salt từ env
//     `SECURITY_IP_HASH_SALT`. Admin có thể lookup hash→hash khi
//     correlate, nhưng không reverse-lookup IP từ DB.
//   - `userId` lưu raw cuid vì đã thuộc nội bộ schema (không phải PII
//     bên ngoài).
//   - `detailJson` KHÔNG được lưu raw password / token / cookie. Code
//     enforce: service chỉ truyền các field đã sanitize (`policy`,
//     `email` ở dạng cleartext is OK, `path` admin route name).
//
// **Retention**: hiện chưa cron-purge. Có thể bổ sung sau (Phase 18.2
// hoặc Phase 17.x backup) — bảng có index `createdAt` để query nhanh.

/// Phase 18.1 — SecurityEvent: audit trail mọi tín hiệu abuse.
///
/// Types (enum-as-string, không cần Prisma enum vì có thể mở rộng):
///   - `RATE_LIMIT_VIOLATION`: subject vượt rate-limit policy.
///   - `LOGIN_FAILED`: argon2 verify fail.
///   - `REGISTER_SPAM`: nhiều account mới từ IP.
///   - `INVALID_TOKEN`: cookie xt_access / xt_refresh không decode được.
///   - `ADMIN_FORBIDDEN`: PLAYER cố gọi admin route.
///   - `IP_BLOCKED` / `USER_BLOCKED`: SecurityAbuseService tạo block.
///   - `BLOCK_LIFTED`: admin lift block qua endpoint.
///
/// Severity: `INFO` | `WARN` | `CRITICAL`.
///
/// `policy` (nullable) ghi `RateLimitPolicyKey` khi liên quan rate-limit.
model SecurityEvent {
  id          String   @id @default(cuid())
  type        String
  severity    String   @default("INFO")
  /// sha256(salt || ip). Null nếu event không gắn IP cụ thể.
  ipHash      String?
  userId      String?
  characterId String?
  /// `RateLimitPolicyKey` (vd `AUTH_LOGIN`). Null cho event không liên
  /// quan rate-limit.
  policy      String?
  /// JSON sanitized detail (không lưu raw password/token/cookie).
  detailJson  Json     @default("{}")
  createdAt   DateTime @default(now())

  @@index([type, createdAt])
  @@index([severity, createdAt])
  @@index([ipHash, type, createdAt])
  @@index([userId, type, createdAt])
  @@index([policy, createdAt])
}

/// Phase 18.1 — SecurityBlock: active block subject.
///
/// `type`:
///   - `IP`: `subjectHash` = sha256(salt || ip).
///   - `USER`: `subjectHash` = raw userId (cuid).
///
/// Active condition: `liftedAt IS NULL AND expiresAt > now()`.
///
/// `expiresAt` luôn được set (không có vĩnh viễn) — Phase 18.1 chính
/// sách KHÔNG auto-ban. Admin có thể `liftBlock` sớm.
model SecurityBlock {
  id          String    @id @default(cuid())
  type        String
  subjectHash String
  reason      String
  expiresAt   DateTime
  createdAt   DateTime  @default(now())
  liftedAt    DateTime?
  /// Admin userId thực hiện lift. Null nếu block hết hạn tự nhiên.
  liftedById  String?

  @@index([type, subjectHash, liftedAt, expiresAt])
  @@index([type, expiresAt])
  @@index([createdAt])
}

// =====================================================================
// Phase 18.3 — Security Audit / Alert Polish
// =====================================================================
//
// `SecurityAlert` row đại diện 1 sự kiện bảo mật **cần admin theo dõi**
// — workflow OPEN → ACKNOWLEDGED → RESOLVED. Khác với `SecurityEvent`
// (audit log immutable), `SecurityAlert` mutable status để admin
// ack/resolve + lưu `resolutionNote`.
//
// Quan hệ:
//   - `eventId` (optional) link tới `SecurityEvent` gốc (1-1 đơn giản
//     ở Phase 18.3 — chưa fan-in nhiều event vào 1 alert; sẽ thêm
//     nếu thấy cần ở phase sau). Không FK Prisma → vì
//     `SecurityEvent.id` đã unique và alert lifecycle khác event
//     lifecycle; chỉ index để query nhanh khi cần.
//
// Privacy:
//   - KHÔNG lưu raw IP — chỉ `ipHash` đã được hash qua `IpHashService`
//     ở caller (SecurityAbuseService / SessionService).
//   - `detailsJson` đã sanitize ở caller — không chứa password / token
//     / cookie / refresh hash.
//
// **KHÔNG** auto-ban + KHÔNG auto-rollback + KHÔNG tự xoá session ở
// Phase 18.3 — chỉ workflow monitoring + admin ack/resolve.

/// Phase 18.3 — SecurityAlert: workflow row cho admin theo dõi.
///
/// `severity`: `INFO` | `WARN` | `CRITICAL` (string literal).
/// `status`:   `OPEN` | `ACKNOWLEDGED` | `RESOLVED`.
/// `type`:     `SecurityAlertType` ở `packages/shared/src/security-alerts.ts`.
/// `source`:   `SecurityAlertSource` (RATE_LIMIT/AUTH/SESSION/ADMIN/BLOCK/OTHER).
///
/// Phân loại tự động qua `classifySecurityEventForAlert(...)`. Alert
/// chỉ được tạo cho event WARN/CRITICAL (xem
/// `shouldCreateAlertForClassification`).
model SecurityAlert {
  id                    String    @id @default(cuid())
  /// `SecurityAlertType` literal — phân loại chi tiết (vd RATE_LIMIT_ABUSE).
  type                  String
  /// `INFO` | `WARN` | `CRITICAL`.
  severity              String
  /// `OPEN` | `ACKNOWLEDGED` | `RESOLVED`. Default OPEN khi tạo.
  status                String    @default("OPEN")
  /// `SecurityAlertSource` (vd `SESSION`).
  source                String
  /// `SecurityEvent.id` gốc nếu alert phát sinh từ event. Null nếu
  /// alert tạo thủ công hoặc fan-in. KHÔNG FK Prisma — event lifecycle
  /// khác alert lifecycle; chỉ index để query nhanh.
  eventId               String?
  /// userId của user liên quan (nạn nhân hoặc actor). Null cho alert
  /// thuần IP-based.
  relatedUserId         String?
  /// characterId liên quan. Hiếm khi set ở Phase 18.3 vì 18.1/18.2
  /// chủ yếu user-scope.
  relatedCharacterId    String?
  /// `UserSession.id` liên quan (vd REFRESH_TOKEN_REUSED, SESSION_REVOKED).
  /// KHÔNG FK để giữ history sau khi session bị xoá.
  relatedSessionId      String?
  /// Sanitized JSON từ event gốc / caller. KHÔNG chứa raw secret/token.
  detailsJson           Json      @default("{}")
  createdAt             DateTime  @default(now())
  acknowledgedAt        DateTime?
  /// userId admin/mod thực hiện ack. KHÔNG FK để giảm rủi ro cascade
  /// khi xoá admin.
  acknowledgedByAdminId String?
  resolvedAt            DateTime?
  /// userId admin thực hiện resolve.
  resolvedByAdminId     String?
  /// Note tự do admin nhập khi resolve (≤1000 char, sanitized).
  resolutionNote        String?

  @@index([status, severity, createdAt(sort: Desc)])
  @@index([source, createdAt(sort: Desc)])
  @@index([type, createdAt(sort: Desc)])
  @@index([relatedUserId, createdAt(sort: Desc)])
  @@index([eventId])
  @@index([createdAt(sort: Desc)])
}

// =====================================================================
// Phase 17.2 — Backup / Restore Weekly Verification
// =====================================================================
//
// `BackupRun` + `BackupVerifyRun` tracking row cho mỗi lần backup
// (pg_dump) hoặc verify-restore chạy. Service ghi row trước khi spawn
// shell, update khi kết thúc.
//
// String literal (không enum Prisma) cho `status`/`storage`
// /`triggeredBy` để dễ mở rộng (vd thêm `S3` storage) không cần
// migration enum. Validator ở `packages/shared/src/backup.ts`
// (Phase 17.2) là source-of-truth cho FE/BE.
//
// **KHÔNG** có FK từ `BackupVerifyRun.backupRunId` → `BackupRun.id`
// vì verify có thể chạy ad-hoc không gắn 1 backup cụ thể (vd verify
// DB hiện tại sau migration). `backupRunId` nullable + index.
//
// **Retention**: hiện chưa cron-purge (closed-beta scale nhỏ). Có
// thể bổ sung khi rows > 10k.

/// Phase 17.2 — BackupRun: tracking 1 lần backup pg_dump.
///
/// Lifecycle:
///   - Service tạo row `status=RUNNING` + `startedAt=now()` trước khi
///     spawn `scripts/backup-db.sh`.
///   - Khi shell exit 0 → update `status=SUCCESS`, `finishedAt`,
///     `fileName`, `fileSizeBytes`, `checksumSha256`.
///   - Khi shell exit != 0 hoặc service catch error → update
///     `status=FAILED`, `finishedAt`, `errorMessage` (truncate
///     2048 char).
///
/// Race-safety: nếu API crash mid-spawn, row `RUNNING` orphan sẽ stale
/// > BACKUP_CRON_MAX_SILENCE_MS → admin nhìn thấy DEGRADED. Không cần
/// FK lock — row orphan tự healing nhờ TTL silence.
model BackupRun {
  id             String    @id @default(cuid())
  /// `RUNNING` | `SUCCESS` | `FAILED` (see shared `BACKUP_RUN_STATUSES`).
  status         String    @default("RUNNING")
  startedAt      DateTime  @default(now())
  finishedAt     DateTime?
  /// Backup file path tương đối hoặc absolute, không lưu credentials.
  fileName       String?
  /// File size (bytes). BigInt vì backup size có thể vượt 2GB.
  fileSizeBytes  BigInt?
  /// SHA-256 hex của file backup (optional — script chưa compute).
  checksumSha256 String?
  /// `LOCAL` | `S3` | `MINIO` | `GCS` (see shared `BACKUP_STORAGES`).
  /// Phase 17.2 chỉ support `LOCAL`.
  storage        String    @default("LOCAL")
  /// Error message (truncated 2048 char) nếu `status=FAILED`.
  errorMessage   String?
  /// `CRON` | `ADMIN` | `MANUAL` | `CI` (see shared `BACKUP_TRIGGERED_BY`).
  triggeredBy    String
  /// Admin userId nếu `triggeredBy=ADMIN`. Null cho cron / manual.
  actorUserId    String?

  @@index([status, startedAt(sort: Desc)])
  @@index([startedAt(sort: Desc)])
  @@index([finishedAt(sort: Desc)])
}

/// Phase 17.2 — BackupVerifyRun: tracking 1 lần verify-restore.
///
/// Verify thường KHÔNG restore vào prod DB — chạy `verify-restore.sh`
/// đọc schema/count critical tables trên DB tạm. Row tracking record
/// kết quả để admin biết "backup gần nhất verify được không".
///
/// `backupRunId` nullable vì verify có thể không gắn 1 backup cụ thể
/// (vd verify DB hiện tại post-migration). Khi gắn được thì lookup
/// theo index `backupRunId`.
model BackupVerifyRun {
  id              String    @id @default(cuid())
  /// Nullable FK theo soft-reference (no DB FK constraint). Index để
  /// query nhanh "verify nào cho backup X".
  backupRunId     String?
  status          String    @default("RUNNING")
  startedAt       DateTime  @default(now())
  finishedAt      DateTime?
  /// Số table phát hiện trong `public` schema (verify-restore.sh
  /// step 2). Null khi verify chưa hoàn tất hoặc fail trước step 2.
  checkedTables   Int?
  /// Tên migration mới nhất đã `finished_at IS NOT NULL` trong
  /// `_prisma_migrations` (verify-restore.sh step 4).
  latestMigration String?
  errorMessage    String?
  triggeredBy     String
  actorUserId     String?

  @@index([status, startedAt(sort: Desc)])
  @@index([startedAt(sort: Desc)])
  @@index([finishedAt(sort: Desc)])
  @@index([backupRunId])
}

/// Phase 19.3 — Social Presence & Notification Center.
///
/// Type của notification — quyết định i18n key tương ứng + entry-point
/// điều hướng khi click (FE map type → route). Enum cố định để chống
/// drift FE/BE; thêm type mới phải migrate + cập nhật shared catalog.
///
/// `SECURITY_ALERT_USER` là placeholder cho future surface (vd
/// admin gửi cảnh báo bảo mật cho user). Không build trong Phase 19.3.
enum NotificationType {
  FRIEND_REQUEST_RECEIVED
  FRIEND_REQUEST_ACCEPTED
  PRIVATE_MESSAGE_RECEIVED
  GROUP_MESSAGE_RECEIVED
  GROUP_INVITE_RECEIVED
  GROUP_MEMBER_ADDED
  CHAT_REPORT_RESOLVED
  SECURITY_ALERT_USER
}

/// Phase 19.3 — Notification row, persistent inbox per user.
///
/// Server-authoritative invariants (test-enforced):
///   - User chỉ list / markRead / markAllRead notification của
///     chính mình (`userId === callerUserId`). Truy cập notification
///     của user khác → `NOT_FOUND` mask (không leak existence).
///   - `titleKey` + `bodyKey` là i18n KEY deterministic. Bất kỳ
///     dynamic param render từ `dataJson` (vd `{ peerName }`). KHÔNG
///     lưu free-text user-controlled (chống injection).
///   - `dataJson` chứa entity reference + bodyParams. Server không
///     leak field nhạy cảm (IP, token, sessionId, raw socket id).
///   - Realtime fanout best-effort: nếu emit fail, row vẫn lưu trong
///     DB → user thấy notification ở REST poll/reload.
model Notification {
  id         String           @id @default(cuid())
  /// userId của người nhận (recipient). Soft-ref (no FK).
  userId     String
  type       NotificationType
  /// i18n title key (e.g. `notification.friendRequestReceived.title`).
  titleKey   String
  /// i18n body key (e.g. `notification.friendRequestReceived.body`).
  bodyKey    String
  /// Loại entity liên quan (FE map sang route): vd `FRIEND_REQUEST`,
  /// `PRIVATE_THREAD`, `GROUP_CHAT`, `CHAT_REPORT`. Nullable nếu
  /// notification không gắn entity cụ thể.
  entityType String?
  /// Soft-ref ID của entity. Server KHÔNG enforce existence (nếu
  /// entity bị xoá, FE render notification nhưng click no-op an toàn).
  entityId   String?
  /// JSON params cho i18n render + route resolver (vd `senderUserId`,
  /// `senderName`, `groupId`, `count`). Sanitize trước khi lưu — không
  /// lưu raw HTML.
  dataJson   Json             @default("{}")
  readAt     DateTime?
  createdAt  DateTime         @default(now())
  /// Optional TTL — null = không hết hạn (cleanup theo retention
  /// policy admin). Phase 19.3 mặc định KHÔNG set; future scheduler
  /// có thể chèn TTL cho `PRIVATE_MESSAGE_RECEIVED` (vd 30 days).
  expiresAt  DateTime?

  @@index([userId, readAt, createdAt(sort: Desc)])
  @@index([userId, type, createdAt(sort: Desc)])
  @@index([createdAt])
  @@index([expiresAt])
}

/// Phase 19.3 — User presence persistence.
///
/// `lastSeenAt` ghi vào DB khi user disconnect (hoặc periodic heartbeat
/// trong tương lai). `online` boolean KHÔNG ở DB — runtime tính từ
/// `RealtimeService.userSockets` (in-memory). Lý do:
///   - Single-instance API thì in-memory đủ — không cần round-trip DB.
///   - Multi-instance / Redis pub-sub cross-shard presence là
///     follow-up phase (xem RUNBOOK).
///
/// Row 1-1 với User qua `userId` PK. Upsert trên mỗi connect /
/// disconnect (best-effort, fail-soft — nếu DB down, in-memory vẫn
/// tracking).
model UserPresence {
  /// userId — PK (soft-ref).
  userId     String   @id
  lastSeenAt DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([lastSeenAt(sort: Desc)])
}

/// Phase 19.4 — Group / Party System Upgrade.
///
/// Party (tổ đội) khác với `GroupChat` (chat nhóm) ở chỗ:
///   - Có **trưởng nhóm** (`leaderUserId`) + `role` per-member.
///   - Một user CHỈ ở 1 active party — service enforce ở
///     `createParty` / `acceptInvite` bằng cách check active
///     membership (status = 'ACTIVE' + `leftAt IS NULL`).
///   - Có invite flow riêng (`PartyInvite`) với expiry.
///   - Lifecycle `ACTIVE → DISBANDED` (không reactivate).
///
/// Phase 19.4 KHÔNG implement:
///   - Matchmaking tự động.
///   - Dungeon co-op thực (chỉ chuẩn bị dữ liệu).
///   - Loot share / voice / media share / trade-in-party.
///
/// Soft-ref pattern (KHÔNG FK) đồng nhất với Phase 19.1 social /
/// 19.2 moderation / 19.3 presence.
enum PartyStatus {
  ACTIVE
  DISBANDED
}

enum PartyRole {
  LEADER
  MEMBER
}

enum PartyInviteStatus {
  PENDING
  ACCEPTED
  DECLINED
  CANCELED
  EXPIRED
}

/// Phase 19.4 — Party (tổ đội gameplay-ready).
///
/// Server enforce (test-enforced):
///   - `leaderUserId` luôn là 1 trong các `PartyMember` active.
///   - `memberCount` derived ở service (`PartyMember.count` where
///     `partyId=? AND leftAt IS NULL`). DB không store để tránh
///     drift; service tính lúc trả response.
///   - `disbandedAt` chỉ set khi `status === 'DISBANDED'`.
model Party {
  id           String      @id @default(cuid())
  /// userId của leader hiện tại. Soft-ref (no FK). Service đảm bảo
  /// luôn là 1 active `PartyMember.userId` cùng party.
  leaderUserId String
  /// Tên party (nullable, 3..40 char sau trim — xem
  /// `validatePartyName` ở `packages/shared/src/party.ts`).
  name         String?
  status       PartyStatus @default(ACTIVE)
  /// Cap thành viên — mirror `PARTY_LIMITS.maxMembers` ở shared
  /// catalog. Lưu ở DB để future tùy biến (vd subscription-level
  /// nâng cap) mà không cần migration.
  maxMembers   Int         @default(5)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  disbandedAt  DateTime?

  @@index([leaderUserId, status])
  @@index([status, createdAt])
}

/// Phase 19.4 — PartyMember row.
///
/// Server enforce:
///   - UNIQUE `(partyId, userId)` để 1 user không xuất hiện 2 lần
///     trong cùng party.
///   - 1 active membership tối đa (`leftAt IS NULL`) per user toàn
///     hệ thống — service `assertNotInActiveParty` check.
///   - Khi member rời (`leave` / `kick`), service set `leftAt`
///     thay vì delete để giữ audit trail.
model PartyMember {
  id       String    @id @default(cuid())
  partyId  String
  userId   String
  role     PartyRole @default(MEMBER)
  joinedAt DateTime  @default(now())
  /// Set khi member rời party (leave / kick / disband cascade).
  /// Null = active.
  leftAt   DateTime?

  @@unique([partyId, userId])
  @@index([userId, leftAt])
  @@index([partyId, leftAt])
}

/// Phase 19.4 — PartyInvite (lời mời tham gia party).
///
/// Lifecycle:
///   - PENDING → ACCEPTED (invitee accept; service ghi
///     `respondedAt`).
///   - PENDING → DECLINED (invitee từ chối).
///   - PENDING → CANCELED (inviter hoặc leader huỷ trước khi
///     invitee phản hồi).
///   - PENDING → EXPIRED (server lazy-check ở `acceptInvite` /
///     `listInvites`: `now >= expiresAt && status === PENDING` thì
///     transition).
///
/// Server enforce:
///   - Không cho `acceptInvite` nếu invite không còn PENDING
///     hoặc đã quá hạn.
///   - Không cho gửi duplicate PENDING cho cùng `(partyId,
///     inviteeUserId)`.
///   - Không cho gửi invite nếu invitee đã ở party khác active.
///   - Cap số PENDING tới 1 invitee + cap số PENDING của 1 party.
model PartyInvite {
  id            String            @id @default(cuid())
  partyId       String
  inviterUserId String
  inviteeUserId String
  status        PartyInviteStatus @default(PENDING)
  createdAt     DateTime          @default(now())
  expiresAt     DateTime
  respondedAt   DateTime?

  @@index([inviteeUserId, status, createdAt(sort: Desc)])
  @@index([partyId, status, createdAt(sort: Desc)])
  @@index([inviterUserId, status, createdAt(sort: Desc)])
}

/// Phase 20.1 — Party Dungeon / Co-op PvE Foundation enums + models.
///
/// Soft-ref pattern (mirror Phase 19.4 Party): KHÔNG FK constraint
/// để tránh cross-shard issues + cho phép prune Party/User rows mà
/// không cascade. Service `PartyDungeonService` enforce invariants:
///   - `leaderUserId` luôn = `Party.leaderUserId` snapshot tại
///     `createRoom` (không re-validate trên mỗi mutation; mutation
///     chỉ check role qua membership).
///   - Một party chỉ có 1 active room (status ∉ COMPLETED/FAILED/
///     CANCELED). Service `assertNoActiveRoom` check.
///   - `PartyDungeonParticipant` UNIQUE `(roomId, userId)`. Snapshot
///     character ownership tại lúc join.
///   - `PartyDungeonRewardClaim` UNIQUE `(runId, characterId)` để
///     idempotent claim. CAS guard `status='PENDING'` → `'CLAIMED'`.
enum PartyDungeonRoomStatus {
  LOBBY
  READY_CHECK
  IN_PROGRESS
  COMPLETED
  FAILED
  CANCELED
}

enum PartyDungeonRunResult {
  CLEAR
  FAIL
  CANCELED
}

enum PartyDungeonRewardClaimStatus {
  PENDING
  CLAIMED
  SKIPPED
  FAILED
}

/// Phase 20.1 — PartyDungeonRoom (lobby co-op trước khi start run).
///
/// Lifecycle: LOBBY → (READY_CHECK) → IN_PROGRESS → COMPLETED/FAILED.
/// Hoặc LOBBY → CANCELED (leader hủy hoặc party disband).
///
/// `currentRunId` pointer set khi `startRun` thành công, null trước
/// đó. Cho phép FE query `/party/dungeon/room` lấy luôn run state.
///
/// Phase 20.1 foundation: IN_PROGRESS thường chỉ tồn tại trong cùng
/// request `startRun` (auto-resolve inline). Phase 20.2+ sẽ tách
/// persistent state cho realtime combat.
model PartyDungeonRoom {
  id           String                 @id @default(cuid())
  partyId      String
  /// userId của leader tại thời điểm tạo room. Service check role
  /// qua membership hiện tại — không trust field này cho authz.
  leaderUserId String
  /// Match `DungeonDef.key` từ shared catalog `DUNGEONS`.
  dungeonKey   String
  status       PartyDungeonRoomStatus @default(LOBBY)
  /// Số member tối thiểu để start. Service validate ≥
  /// `COOP_DUNGEON_LIMITS.minMembers`.
  minMembers   Int                    @default(2)
  /// Số member tối đa. Service validate ≤
  /// `COOP_DUNGEON_LIMITS.maxMembers`.
  maxMembers   Int                    @default(5)
  /// Pointer tới PartyDungeonRun.id nếu đã start (null trước đó).
  currentRunId String?
  createdAt    DateTime               @default(now())
  startedAt    DateTime?
  finishedAt   DateTime?
  canceledAt   DateTime?
  updatedAt    DateTime               @updatedAt

  @@index([partyId, status])
  @@index([leaderUserId, status, createdAt])
  @@index([status, createdAt])
}

/// Phase 20.1 — PartyDungeonParticipant row.
///
/// Server enforce:
///   - UNIQUE `(roomId, userId)`: 1 user 1 slot trong cùng room.
///   - `characterId` snapshot character đang dùng tại lúc join —
///     dùng cho reward grant về đúng character (user có thể đổi
///     character giữa rooms).
///   - `readyAt` null = chưa ready; set timestamp khi `setReady`.
///   - `leftAt` null = active; set khi user rời room hoặc bị kick.
///   - `resultStatus` set sau khi run resolve (CLEAR/FAIL/CANCELED).
model PartyDungeonParticipant {
  id           String                 @id @default(cuid())
  roomId       String
  userId       String
  /// Soft-ref Character.id snapshot tại lúc join. Null nếu user
  /// không có active character (edge case — service reject join).
  characterId  String?
  readyAt      DateTime?
  joinedAt     DateTime               @default(now())
  leftAt       DateTime?
  resultStatus PartyDungeonRunResult?

  @@unique([roomId, userId])
  @@index([userId, leftAt])
  @@index([roomId, leftAt])
}

/// Phase 20.1 — PartyDungeonRun (server-authoritative run record).
///
/// Tạo bởi `PartyDungeonService.startRun` sau khi validate đủ điều
/// kiện. Phase 20.1 foundation auto-resolve inline trong cùng tx
/// (foundation chưa có combat thật) → `finishedAt` thường set ngay
/// sau `startedAt`. Field `combatSummaryJson` + `rewardSummaryJson`
/// lưu summary để debug + Phase 20.2+ wire combat real.
///
/// Reward grant flow:
///   1. `startRun` resolve CLEAR/FAIL.
///   2. Nếu CLEAR → tạo `PartyDungeonRewardClaim` PENDING cho mỗi
///      active participant với `rewardJson` từ
///      `computePartyDungeonRewardSplit`.
///   3. Member call `POST /party/dungeon/runs/:id/claim-reward` →
///      `claimReward` CAS guard PENDING → CLAIMED + grant qua
///      CurrencyService.applyTx + InventoryService.grantTx.
model PartyDungeonRun {
  id                String                @id @default(cuid())
  roomId            String
  partyId           String
  dungeonKey        String
  result            PartyDungeonRunResult
  startedAt         DateTime              @default(now())
  finishedAt        DateTime?
  combatSummaryJson Json?
  rewardSummaryJson Json?

  @@index([roomId])
  @@index([partyId, startedAt(sort: Desc)])
  @@index([dungeonKey, startedAt(sort: Desc)])
}

/// Phase 20.1 — PartyDungeonRewardClaim (per-participant reward
/// claim row).
///
/// Server enforce:
///   - UNIQUE `(runId, characterId)`: 1 character 1 claim row /
///     run. Idempotent guard chống duplicate claim.
///   - CAS update `status='PENDING'` → `'CLAIMED'` trong cùng tx
///     với CurrencyService.applyTx + InventoryService.grantTx +
///     exp increment. Race-safe: 2 concurrent claim cùng row, đúng
///     1 winner ghi ledger.
///   - `rewardJson` lưu payload tính sẵn lúc tạo (`PartyDungeonRewardPreview`)
///     để FE preview trước claim + để claim grant đúng số.
model PartyDungeonRewardClaim {
  id          String                        @id @default(cuid())
  runId       String
  userId      String
  /// Soft-ref Character.id — server snapshot lúc tạo claim. Grant
  /// reward về đúng characterId này (không grant cho character
  /// khác của cùng user).
  characterId String
  status      PartyDungeonRewardClaimStatus @default(PENDING)
  /// JSON payload `{ linhThach?, tienNgoc?, exp?, items? }`. Server
  /// tính tại lúc tạo (snapshot dungeon catalog `runReward`).
  rewardJson  Json
  claimedAt   DateTime?
  createdAt   DateTime                      @default(now())

  @@unique([runId, characterId])
  @@unique([runId, userId])
  @@index([userId, status])
  @@index([runId, status])
}

/// Phase 20.2 — Co-op Boss / World Boss Party Contribution.
///
/// Foundation tổ đội đánh boss + ghi contribution + reward claim
/// theo tier (NONE/LOW/NORMAL/HIGH/MVP). Soft-ref pattern (mirror
/// Phase 19.4 Party / Phase 20.1 Party Dungeon): KHÔNG FK constraint
/// tới `Party` / `WorldBoss` / `User` để tránh cross-shard issues +
/// cho phép prune row mà không cascade. Service `CoopBossService`
/// enforce invariants:
///
///   - Một party tại 1 thời điểm chỉ có 1 active run (status ∉
///     CLEARED/FAILED/CANCELED). Service `assertNoActiveRun` check.
///   - `CoopBossParticipant` UNIQUE `(runId, userId)`. Snapshot
///     character ownership tại lúc join.
///   - `CoopBossContribution` UNIQUE `(runId, participantId)` —
///     1 row aggregate per participant (server cộng dồn vào row
///     duy nhất, không spawn N row per contribution call).
///   - `CoopBossRewardClaim` UNIQUE `(runId, userId)` để idempotent
///     claim. CAS guard `status='PENDING'` → `'CLAIMED'`.
enum CoopBossStatus {
  LOBBY
  IN_PROGRESS
  CLEARED
  FAILED
  CANCELED
}

enum CoopBossRewardClaimStatus {
  PENDING
  CLAIMED
  SKIPPED
  FAILED
}

enum CoopBossContributionTier {
  NONE
  LOW
  NORMAL
  HIGH
  MVP
}

/// Phase 20.2 — CoopBossRun (đơn vị 1 lần chiến đấu boss tổ đội).
///
/// Lifecycle: LOBBY → IN_PROGRESS → CLEARED/FAILED. Hoặc LOBBY →
/// CANCELED (leader hủy trước start). Foundation phase: server
/// auto-mở IN_PROGRESS khi đủ điều kiện start, member ghi
/// contribution liên tục, leader (hoặc system) gọi finish để
/// resolve.
///
/// `worldBossEventId` (nullable) gắn run với 1 `WorldBoss.id` cụ
/// thể nếu boss event hiện đang active. Foundation không bắt buộc
/// (boss có thể là instance virtual riêng cho run).
///
/// `resultSummaryJson` lưu snapshot tổng kết server-tính tại
/// `finishRun` (totalDamage, mvpUserId, contributionTopRows) —
/// opaque cho FE, dùng cho admin recompute + audit.
model CoopBossRun {
  id                String         @id @default(cuid())
  /// Match `BossDef.key` / `WorldBoss.bossKey` từ shared catalog.
  bossKey           String
  /// Party owner — null cho free-form / event ngoài party (foundation
  /// luôn party-based, nhưng giữ nullable để phase sau mở public).
  partyId           String?
  /// Pointer tới `WorldBoss.id` nếu run gắn với event hiện active.
  /// Null cho instance virtual / single-party boss raid.
  worldBossEventId  String?
  status            CoopBossStatus @default(LOBBY)
  startedAt         DateTime       @default(now())
  finishedAt        DateTime?
  /// Server-authoritative summary snapshot tại finishRun (mvp,
  /// totalDamage, perParticipant rows). Opaque cho FE.
  resultSummaryJson Json?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@index([partyId, status])
  @@index([bossKey, status])
  @@index([status, startedAt])
  @@index([worldBossEventId, status])
}

/// Phase 20.2 — CoopBossParticipant row.
///
/// Server enforce:
///   - UNIQUE `(runId, userId)`: 1 user 1 slot trong cùng run.
///   - `characterId` snapshot character đang dùng tại lúc join —
///     dùng cho reward grant về đúng character.
///   - `leftAt` null = active; set khi user rời run sớm.
///   - `eligibleForReward` set bởi server tại finishRun dựa trên
///     contribution threshold + survival threshold. Default true
///     khi tạo (cho FE optimistic UI), server overwrite.
///   - `finalContributionScore` cache giá trị
///     `CoopBossContribution.contributionScore` tại finishRun để
///     query reward list nhanh không cần join.
model CoopBossParticipant {
  id                     String    @id @default(cuid())
  runId                  String
  userId                 String
  /// Soft-ref Character.id snapshot tại lúc join.
  characterId            String
  /// Soft-ref Party.id snapshot tại lúc join (nullable cho phase
  /// sau public boss, foundation luôn = run.partyId).
  partyId                String?
  joinedAt               DateTime  @default(now())
  leftAt                 DateTime?
  eligibleForReward      Boolean   @default(true)
  /// Set tại finishRun snapshot cuối — null trước đó.
  finalContributionScore Int?

  @@unique([runId, userId])
  @@index([runId, leftAt])
  @@index([userId, joinedAt])
}

/// Phase 20.2 — CoopBossContribution aggregate row per (run,
/// participant).
///
/// Server cộng dồn vào row duy nhất qua `recordContribution`
/// (idempotent merge — không spawn N rows). `contributionScore`
/// derive trong service từ `computeContributionScore({damageDone,
/// supportScore, survivalSeconds})` ở shared.
///
/// Caps + clamp (anti-cheat):
///   - `damageDone` BigInt, server clamp `≥0` + cap theo
///     `COOP_BOSS_LIMITS.maxDamagePerContribution` nếu vượt →
///     anomaly log + ghi clamp value.
///   - `supportScore` Int, server clamp `≥0` + cap
///     `COOP_BOSS_LIMITS.maxSupportPerContribution`.
///   - `survivalSeconds` Int, clamp `0..COOP_BOSS_LIMITS
///     .contributionWindowSeconds`.
///   - `actionCount` Int counter tổng số recordContribution call
///     (per participant per run) — dùng cho admin audit.
model CoopBossContribution {
  id                String   @id @default(cuid())
  runId             String
  participantId     String
  damageDone        BigInt   @default(0)
  supportScore      Int      @default(0)
  survivalSeconds   Int      @default(0)
  actionCount       Int      @default(0)
  /// Derived score qua `computeContributionScore` shared helper —
  /// server tính lại mỗi lần cộng dồn (deterministic).
  contributionScore Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([runId, participantId])
  @@index([runId, contributionScore])
}

/// Phase 20.2 — CoopBossRewardClaim per-participant reward row.
///
/// Tạo bởi `CoopBossService.finishRun` cho mỗi participant đạt
/// `eligibleForReward=true`. Member claim qua endpoint riêng
/// (atomic CAS `PENDING→CLAIMED` + ledger / inventory grant).
///
/// `rewardTier` snapshot tại finishRun (deterministic theo
/// `classifyContributionTier(contributionScore, mvpUserId)`).
/// `rewardJson` snapshot payload `{linhThach?, tienNgoc?, exp?,
/// items?}` server tính.
///
/// Idempotent qua UNIQUE `(runId, userId)` + CAS update guard.
model CoopBossRewardClaim {
  id          String                    @id @default(cuid())
  runId       String
  userId      String
  characterId String
  status      CoopBossRewardClaimStatus @default(PENDING)
  rewardTier  CoopBossContributionTier  @default(NONE)
  rewardJson  Json
  claimedAt   DateTime?
  createdAt   DateTime                  @default(now())

  @@unique([runId, userId])
  @@unique([runId, characterId])
  @@index([userId, status])
  @@index([runId, status])
}

/// Phase 20.3 — Co-op Weekly Season status enum.
///
/// `ACTIVE` (đang mở) → `CLOSED` (qua endsAt, không nhận
/// contribution mới) → `SETTLED` (admin/cron đã settle rank/tier
/// + tạo PENDING claim row).
enum CoopWeeklySeasonStatus {
  ACTIVE
  CLOSED
  SETTLED
}

/// Phase 20.3 — Co-op Weekly Reward Claim status enum.
///
/// `PENDING` (tạo bởi settle) → `CLAIMED` (member claim, ledger
/// ghi) | `SKIPPED` (tier NONE / member rời) | `FAILED` (reserved).
enum CoopWeeklyRewardClaimStatus {
  PENDING
  CLAIMED
  SKIPPED
  FAILED
}

/// Phase 20.3 — Co-op Reward Cap Counter per `(userId, source,
/// dayKey | weekKey)`.
///
/// Track số lần member nhận reward từ co-op boss (Phase 20.2) +
/// party dungeon (Phase 20.1) trong 1 ngày/tuần local
/// (`Asia/Ho_Chi_Minh`). `CoopRewardCapService.checkDailyWeeklyCap`
/// gate trước khi grant; `incrementRewardCapCounter` upsert sau
/// grant.
///
/// Sử dụng 1 row per `(userId, source, dayKey)` — `weekKey` lưu
/// kèm cho easier weekly query (composite filter). Counter tuần
/// được aggregate runtime hoặc qua index `(userId, source, weekKey)`.
///
/// Soft-ref `userId` / `characterId` (không FK) — cho phép xóa user
/// mà counter row không cascade. KHÔNG khoá business logic.
model CoopRewardCapCounter {
  id                String   @id @default(cuid())
  userId            String
  characterId       String
  /// `CoopRewardSource` literal (shared) — `COOP_BOSS` | `PARTY_DUNGEON`.
  source            String
  /// `YYYY-MM-DD` (Asia/Ho_Chi_Minh) — build qua
  /// `buildCoopRewardDayKey` shared.
  dayKey            String
  /// `YYYY-Www` ISO week — build qua `buildCoopRewardWeekKey`.
  weekKey           String
  claimCount        Int      @default(0)
  /// Tổng linhThach approx (best-effort BigInt → Int aggregate).
  /// Dùng cho admin audit khi điều tra abuse.
  rewardValueApprox BigInt   @default(0)
  updatedAt         DateTime @updatedAt
  createdAt         DateTime @default(now())

  @@unique([userId, source, dayKey])
  @@index([userId, source, weekKey])
  @@index([source, dayKey])
}

/// Phase 20.3 — Weekly contribution season aggregate window.
///
/// Tạo bởi admin (hoặc cron Phase 20.3+) khi tuần mới mở. Ghi
/// `weekKey` deterministic qua `buildCoopRewardWeekKey`. Member
/// contribution từ Phase 20.2 finishRun (`COOP_BOSS`) + Phase 20.1
/// dungeon CLEAR (`PARTY_DUNGEON`) → upsert
/// `CoopWeeklyContributionEntry` (cộng dồn `bossContributionPoints`
/// + `dungeonContributionPoints` + `totalPoints`).
///
/// Settle: `status='ACTIVE'→'CLOSED'→'SETTLED'`. Khi SETTLED,
/// service rank theo `totalPoints` DESC + map tier qua
/// `classifyWeeklyRewardTier` + tạo `CoopWeeklyRewardClaim` PENDING
/// cho mỗi entry tier ≠ NONE.
model CoopWeeklyContributionSeason {
  id               String                 @id @default(cuid())
  /// `YYYY-Www` ISO week (Asia/Ho_Chi_Minh).
  weekKey          String                 @unique
  startsAt         DateTime
  endsAt           DateTime
  status           CoopWeeklySeasonStatus @default(ACTIVE)
  createdAt        DateTime               @default(now())
  settledAt        DateTime?
  /// Admin actor settle (nullable cho cron-based future). KHÔNG FK
  /// để giảm cascade rủi ro khi xóa admin.
  settledByAdminId String?

  entries      CoopWeeklyContributionEntry[]
  rewardClaims CoopWeeklyRewardClaim[]

  @@index([status, endsAt])
}

/// Phase 20.3 — Per-user weekly contribution entry.
///
/// 1 row per `(seasonId, userId)`. Upsert mỗi lần finishRun /
/// dungeon CLEAR — cộng dồn points. `rank` + `rewardTier` snapshot
/// chỉ set khi settle.
///
/// Soft-ref `userId` / `characterId`.
model CoopWeeklyContributionEntry {
  id                        String                       @id @default(cuid())
  seasonId                  String
  season                    CoopWeeklyContributionSeason @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  userId                    String
  characterId               String
  /// Cộng dồn `contributionScore` từ `CoopBossContribution`
  /// (Phase 20.2) — đã clamp + classifyTier server-side.
  bossContributionPoints    Int                          @default(0)
  /// Cộng dồn từ `PartyDungeonRun` clear (Phase 20.1). 0 ở
  /// foundation nếu chưa wire integration vào dungeon flow.
  dungeonContributionPoints Int                          @default(0)
  /// = bossPoints * mult + dungeonPoints * mult + mvpBonus.
  /// Server tính qua `computeWeeklyContributionPoints` shared.
  totalPoints               Int                          @default(0)
  /// Snapshot rank tại settle (1-indexed). NULL khi chưa settle.
  rank                      Int?
  /// `CoopWeeklyRewardTier` literal (shared) — snapshot tại settle.
  rewardTier                String?
  updatedAt                 DateTime                     @updatedAt
  createdAt                 DateTime                     @default(now())

  @@unique([seasonId, userId])
  @@index([seasonId, totalPoints])
  @@index([userId])
}

/// Phase 20.3 — Per-user weekly reward claim row.
///
/// Tạo bởi `settleWeeklySeason` cho mỗi entry tier ≠ NONE. Member
/// claim qua `POST /coop/rewards/weekly-claim` (atomic CAS
/// `PENDING→CLAIMED` + ledger / inventory grant reason
/// `COOP_WEEKLY_REWARD`).
///
/// Idempotent UNIQUE `(seasonId, userId)` + CAS guard.
model CoopWeeklyRewardClaim {
  id          String                       @id @default(cuid())
  seasonId    String
  season      CoopWeeklyContributionSeason @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  userId      String
  characterId String
  /// `CoopWeeklyRewardTier` literal (shared) — NONE/BRONZE/SILVER/GOLD/LEGEND.
  rewardTier  String
  /// Snapshot reward payload `{linhThach?, exp?}` server tính qua
  /// `computeWeeklyReward` tại settle. CAS guard giữ snapshot bất
  /// biến giữa các retry claim.
  rewardJson  Json
  status      CoopWeeklyRewardClaimStatus  @default(PENDING)
  claimedAt   DateTime?
  createdAt   DateTime                     @default(now())

  @@unique([seasonId, userId])
  @@index([userId, status])
  @@index([seasonId, status])
}

// ════════════════════════════════════════════════════════════════════════════
//  Phase 26.5 — World Content V2 (Farm / Dungeon / Boss / Sect / Trial Tower)
// ════════════════════════════════════════════════════════════════════════════

/// Phase 26.5 — Farm session (auto farm theo thời gian).
///
/// Server-authoritative: client request `POST /world/farm/start` → tạo
/// session với `freeSessionMinutes` (hoặc cao hơn nếu entitlement cho phép,
/// cap `maxSessionMinutes`). Client `POST /world/farm/claim` → server tính
/// minutes processed = min(requested, capByEntitlement, capByMaxSession,
/// elapsed wallclock). Resulting reward + encounter generated server-side
/// và lưu `rewardsJson`/`encountersJson` (audit). Anti-P2W: premium chỉ
/// nới `maxSessionMinutes` — vẫn enforce daily/weekly cap qua
/// `DailyContentCap`/`WeeklyContentCap`.
model FarmSession {
  id               String    @id @default(cuid())
  characterId      String
  character        Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  /// `FarmMapDef.key` (shared catalog).
  farmMapKey       String
  startedAt        DateTime  @default(now())
  endedAt          DateTime?
  /// Tổng phút đã được claim (granted reward). 0 khi session ACTIVE chưa claim.
  minutesProcessed Int       @default(0)
  /// `'ACTIVE' | 'CLAIMED' | 'EXPIRED' | 'CANCELLED'`.
  status           String    @default("ACTIVE")
  /// Reward payload snapshot khi claim (DropEconomy resolved). Empty until claim.
  rewardsJson      Json      @default("{}")
  /// Encounter list emitted trong session (cơ duyên + elite spawn).
  encountersJson   Json      @default("[]")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  encounters FarmEncounter[]

  @@index([characterId, status])
  @@index([farmMapKey, startedAt])
}

/// Phase 26.5 — Farm encounter (cơ duyên + elite/mini-boss/manual spawn).
///
/// Tạo trong khi farm session đang chạy; FE hiển thị "Khiêu chiến / Bỏ qua"
/// (cho elite) hoặc choice list (cho opportunity). Status PENDING khi tạo,
/// RESOLVED khi player resolve, EXPIRED khi quá hạn (`expiresAt`).
/// Anti-P2W: cơ duyên hiếm bị `OpportunityEncounterDef.maxWeeklyTriggers`
/// cap qua `WeeklyContentCap`.
model FarmEncounter {
  id                String       @id @default(cuid())
  characterId       String
  character         Character    @relation(fields: [characterId], references: [id], onDelete: Cascade)
  farmSessionId     String?
  farmSession       FarmSession? @relation(fields: [farmSessionId], references: [id], onDelete: SetNull)
  /// `OpportunityEncounterDef.key` hoặc monster key (ELITE/MINI_BOSS).
  encounterKey      String
  /// `'OPPORTUNITY' | 'ELITE' | 'MINI_BOSS' | 'HIDDEN_BOSS_HINT'`.
  encounterType     String
  /// `'PENDING' | 'RESOLVED' | 'EXPIRED' | 'SKIPPED'`.
  status            String       @default("PENDING")
  expiresAt         DateTime?
  /// Reward preview shown to UI before resolve (no grant yet).
  rewardPreviewJson Json         @default("{}")
  /// Resolution details (choice taken, success/fail, granted reward).
  resolutionJson    Json         @default("{}")
  createdAt         DateTime     @default(now())
  resolvedAt        DateTime?

  @@index([characterId, status])
  @@index([farmSessionId])
  @@index([expiresAt])
}

/// Phase 26.5 — Daily content cap counter.
///
/// Track usage cho daily-capped content keys (farm session minutes, dungeon
/// attempts, opportunity triggers, sect boss attempts, …). `capKey` =
/// resolver string vd `farm_session_minutes`, `dungeon_attempt:son_coc_duoc_vien`,
/// `opportunity_rarity:COMMON`. `source` = content source for analytics.
/// `dayBucket` = `YYYY-MM-DD` theo timezone server (Asia/Ho_Chi_Minh).
/// Server-authoritative: mutate qua `WorldCapService.consume()` atomic CAS.
/// Anti-P2W: premium KHÔNG bypass — chỉ FarmSession `maxSessionMinutes` mở
/// rộng theo entitlement.
model DailyContentCap {
  id          String    @id @default(cuid())
  characterId String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  capKey      String
  source      String
  /// `YYYY-MM-DD` theo timezone reset.
  dayBucket   String
  usedCount   Int       @default(0)
  usedQty     Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([characterId, dayBucket, capKey])
  @@index([dayBucket])
  @@index([characterId, dayBucket])
}

/// Phase 26.5 — Weekly content cap counter (cho RARE/EPIC opportunity,
/// WORLD_BOSS, SECT_BOSS INVADER, …).
///
/// `weekBucket` = ISO `YYYY-Www` theo timezone server. Mirror logic
/// `DailyContentCap`; cap rule riêng theo `capKey`.
model WeeklyContentCap {
  id          String    @id @default(cuid())
  characterId String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  capKey      String
  source      String
  /// ISO week `YYYY-Www` theo timezone reset.
  weekBucket  String
  usedCount   Int       @default(0)
  usedQty     Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([characterId, weekBucket, capKey])
  @@index([weekBucket])
  @@index([characterId, weekBucket])
}

/// Phase 26.5 — Trial tower progress (highest floor cleared per character/tower).
///
/// Anti-P2W: `claimedMilestonesJson` track milestone reward unique per
/// (character, tower, milestone). `seasonHighestFloor` reset mỗi
/// `TrialTowerRankingSeason.durationDays` cho weekly/season ranking; lifetime
/// `highestFloorCleared` chỉ tăng monotonic.
model TrialTowerProgress {
  id                    String    @id @default(cuid())
  characterId           String
  character             Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  /// `TrialTowerDef.key` (shared catalog).
  towerKey              String
  highestFloorCleared   Int       @default(0)
  seasonHighestFloor    Int       @default(0)
  /// Array of milestone keys (`"every:1000"`, `"every:500"`, …) đã claim.
  claimedMilestonesJson Json      @default("[]")
  lastAttemptAt         DateTime?
  updatedAt             DateTime  @updatedAt

  @@unique([characterId, towerKey])
  @@index([towerKey, highestFloorCleared])
  @@index([towerKey, seasonHighestFloor])
}

/// Phase 26.5 — Trial tower attempt log (audit + ranking input).
///
/// Mỗi attempt (success hoặc fail) → 1 row. Reward chỉ grant khi
/// `success=true` và `floor > previousHighestFloorCleared` (first-clear
/// only) hoặc milestone chưa claim — service runtime enforce.
model TrialTowerAttemptLog {
  id                  String    @id @default(cuid())
  characterId         String
  character           Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  towerKey            String
  floor               Int
  success             Boolean
  /// BattlePower snapshot khi attempt (audit).
  battlePowerSnapshot Int       @default(0)
  clearTimeSeconds    Int?
  /// Reward granted snapshot (empty khi fail / repeat).
  rewardJson          Json      @default("{}")
  createdAt           DateTime  @default(now())

  @@index([characterId, towerKey, floor])
  @@index([towerKey, success, createdAt])
  @@index([createdAt])
}

/// Phase 26.5 — Sect boss attempt log (per character / per attempt).
///
/// Track damage contribution cho ranking + cap weekly. `bossKey` ref
/// `SectBossDef.key`. `damage` BigInt cho INVADER (HP hàng chục triệu).
model SectBossAttemptLog {
  id          String    @id @default(cuid())
  /// Sect ID — không quan hệ trực tiếp (Sect table giữ FK riêng). Index để query.
  sectId      String
  characterId String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  bossKey     String
  damage      BigInt    @default(0)
  /// Reward granted snapshot.
  rewardJson  Json      @default("{}")
  createdAt   DateTime  @default(now())

  @@index([sectId, bossKey, createdAt])
  @@index([characterId, bossKey, createdAt])
  @@index([bossKey, damage])
}

// ─── Phase 27.6 — Admin Control Center V2 / Config-Driven LiveOps Admin ──
//
// Mở rộng admin foundation (`FeatureFlag` Phase 15.4, `MaintenanceWindow`
// Phase 15.5, `ConfigVersion` Phase 15.6, `AdminAuditLog` Phase 18.x) bằng
// 3 model `additive`:
//
//   - `RewardProfile`  — config reward set theo `contentType+contentKey`
//     (BOSS_PERSONAL_T3_DEFAULT, DUNGEON_T5_RARE, MONTHLY_CARD_DAILY ...).
//     Versioning + active flag — chỉ 1 profile `active=true` per (contentType, contentKey).
//     Validator anti-P2W ở shared `validateRewardProfile` chặn tier leak +
//     forbidden item + TIEN_NGOC + missing weekly cap rare T7+.
//   - `DropProfile`    — config drop table theo `sourceType+sourceTier`
//     (NORMAL_MONSTER_T3, BOSS_T5_GENERAL, WORLD_BOSS_T9_ARTIFACT ...).
//     Validator chặn NORMAL_MONSTER rơi T5+, ARTIFACT_CRAFT rareRate > 5%,
//     rareRate > 25%, tier leak.
//   - `ContentStatus`  — per-content enable/pause/disableReward/disableClaim.
//     Phase 27.6 cho admin tắt nguồn lạm phát nhanh (1 farm map xấu → pause)
//     không cần redeploy.
//
// KHÔNG đụng `FeatureFlag`, `MaintenanceWindow`, `ConfigVersion`,
// `LiveOpsScheduledEvent`, `LiveOpsAnnouncement`, `AdminAuditLog` — đã có.
// Audit log dùng `AdminAuditLog` (Phase 18.x) với `meta.permissionKey` +
// `meta.riskLevel` + `meta.reason` + `meta.targetType` + `meta.targetId` +
// `meta.beforeJson` + `meta.afterJson` (extend qua JSON, không migration).

model RewardProfile {
  id               String   @id @default(cuid())
  /// Unique slug (e.g. `BOSS_PERSONAL_T3_DEFAULT`, `DUNGEON_T5_RARE`).
  key              String   @unique
  name             String
  description      String?
  /// Match `RewardProfileContentType` ở shared (FARM_MAP, DUNGEON, BOSS,
  /// WORLD_BOSS, HOURLY_BOSS, EVENT_BOSS, TRIAL_TOWER, SECT_DUNGEON,
  /// SECT_BOSS, SHOP, MONTHLY_CARD, BATTLE_PASS, GROWTH_FUND, QUEST,
  /// DAILY_LOGIN, EVENT, MAIL_BROADCAST). Lưu raw string để forward-compat.
  contentType      String
  /// Optional content key (e.g. `boss_t3_dummy`). NULL = profile mặc định
  /// cho cả contentType.
  contentKey       String?
  /// Tier nguồn (1..9) — validator chặn reward tier > sourceTier.
  sourceTier       Int
  /// JSON snapshot rewards: `RewardProfileEntry[]` ở shared.
  rewardsJson      Json     @default("[]")
  /// JSON snapshot cap rule: `RewardProfileCapRule` ở shared (dailyCount,
  /// dailyQty, weeklyCount, weeklyQty).
  capRuleJson      Json     @default("{}")
  /// Chỉ 1 profile active=true per (contentType, contentKey). Validator
  /// service phải tự enforce trong transaction.
  active           Boolean  @default(false)
  /// Version increment mỗi khi UPDATE — dùng để rollback target version.
  version          Int      @default(1)
  /// Admin gần nhất sửa. SET NULL khi admin bị xoá.
  updatedByAdminId String?
  updatedByAdmin   User?    @relation("RewardProfileUpdatedBy", fields: [updatedByAdminId], references: [id], onDelete: SetNull)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([contentType, active])
  @@index([contentType, contentKey, active])
  @@index([sourceTier])
}

model DropProfile {
  id               String   @id @default(cuid())
  /// Unique slug (e.g. `BOSS_T5_GENERAL`, `WORLD_BOSS_T9_ARTIFACT`).
  key              String   @unique
  name             String
  description      String?
  /// Match `DropProfileSourceType` ở shared (NORMAL_MONSTER, ELITE_MONSTER,
  /// BOSS, WORLD_BOSS, EVENT_BOSS, DUNGEON, TRIAL_TOWER, SECT_DUNGEON).
  sourceType       String
  /// Tier nguồn (1..9).
  sourceTier       Int
  /// Match `DropMaterialCategory` ở shared (GENERAL, ALCHEMY, REFINE,
  /// ARTIFACT_CRAFT, GEM, COSMETIC). NULL = generic.
  materialCategory String?
  /// Probability baseline (0..1).
  baseRate         Float
  /// Probability rare (0..1). Validator chặn > DROP_RARE_RATE_MAX (0.25).
  rareRate         Float
  /// JSON snapshot: `DropProfileItemWeight[]` ở shared (itemKey, tier,
  /// weight, rare).
  weightsJson      Json     @default("[]")
  /// JSON snapshot: `DropProfileCapRule` ở shared (dailyRare, weeklyRare,
  /// dailyTotal). Bắt buộc weeklyRare khi rareRate > 0.
  capsJson         Json     @default("{}")
  active           Boolean  @default(false)
  version          Int      @default(1)
  updatedByAdminId String?
  updatedByAdmin   User?    @relation("DropProfileUpdatedBy", fields: [updatedByAdminId], references: [id], onDelete: SetNull)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([sourceType, active])
  @@index([sourceType, sourceTier, active])
  @@index([materialCategory])
}

model ContentStatus {
  id               String   @id @default(cuid())
  /// Match `ContentStatusType` ở shared (FARM_MAP, DUNGEON, BOSS, ...).
  contentType      String
  /// Vd: `farm_phong_van`, `dungeon_huyet_long`, `boss_tu_thien`.
  contentKey       String
  /// `false` = content KHÔNG khả dụng (player vào sẽ bị `CONTENT_DISABLED`).
  enabled          Boolean  @default(true)
  /// `true` = pause tạm thời (player thấy nhưng không reward). Yêu cầu
  /// `enabled=true` (validator).
  paused           Boolean  @default(false)
  /// `true` = giữ enable nhưng KHÔNG grant reward (admin debug). Yêu cầu
  /// `enabled=true` (validator).
  disableReward    Boolean  @default(false)
  /// `true` = chặn claim reward đã rơi (vd: rare drop nghi bug).
  disableClaim     Boolean  @default(false)
  /// Message banner cho player (tối đa 1000 ký tự).
  message          String?
  updatedByAdminId String?
  updatedByAdmin   User?    @relation("ContentStatusUpdatedBy", fields: [updatedByAdminId], references: [id], onDelete: SetNull)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([contentType, contentKey])
  @@index([contentType, enabled])
  @@index([enabled, paused])
}

// ============================================================================
// Phase 28.0 — Event Builder & Tier-Balanced LiveOps Event System V2
// ============================================================================
//
// Mở rộng `LiveOpsScheduledEvent` (Phase 15.1 — runtime multiplier event) bằng
// hệ event gameplay đầy đủ mà admin có thể bật/tắt và TỰ TẠO mới không cần
// code/redeploy. Khác model cũ ở chỗ: Phase 28 model gồm token wallet,
// mission progress, shop purchase, ranking entry, personal trigger.
//
// Tất cả model **additive** — KHÔNG ALTER `LiveOpsScheduledEvent` cũ. Cron
// runtime / combat hook wire ở PR2 (tách riêng).

/// EventDef — catalog event-builder. Lifecycle DRAFT → SCHEDULED → ACTIVE →
/// PAUSED/REWARD_LOCKED → ENDED → FINALIZED → ARCHIVED / CANCELLED.
model EventDef {
  id               String   @id @default(cuid())
  /// Pattern `^[a-z0-9][a-z0-9_-]{1,62}[a-z0-9]$`.
  key              String   @unique
  name             String
  description      String   @default("")
  eventType        String
  status           String   @default("DRAFT")
  startsAt         DateTime
  endsAt           DateTime
  timezone         String   @default("Asia/Ho_Chi_Minh")
  bannerUrl        String?
  iconUrl          String?
  /// Admin-only nội bộ (không trả endpoint player).
  adminNote        String?
  /// Markdown VI/EN show cho player.
  playerNotice     String?
  enabled          Boolean  @default(true)
  /// Khớp `BracketMode` ở shared.
  bracketMode      String   @default("NONE")
  tokenKey         String?
  eventShopKey     String?
  missionGroupKey  String?
  bossGroupKey     String?
  rankingGroupKey  String?
  rewardProfileKey String?
  createdByAdminId String?
  createdByAdmin   User?    @relation("EventDefCreatedBy", fields: [createdByAdminId], references: [id], onDelete: SetNull)
  updatedByAdminId String?
  updatedByAdmin   User?    @relation("EventDefUpdatedBy", fields: [updatedByAdminId], references: [id], onDelete: SetNull)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  brackets           EventBracket[]
  balancePolicy      EventBalancePolicy?
  itemConfigs        EventItemConfig[]
  missionDefs        EventMissionDef[]
  missionProgresses  EventMissionProgress[]
  shops              EventShopDef[]
  shopPurchases      EventShopPurchase[]
  tokenWallets       EventTokenWallet[]
  bosses             EventBossDef[]
  rankings           EventRankingDef[]
  rankingEntries     EventRankingEntry[]
  personalProgresses PersonalEventProgress[]

  @@index([status, startsAt])
  @@index([status, endsAt])
  @@index([eventType, status])
  @@index([enabled, status])
}

/// Bracket cho 1 event. `bracketMode=NONE` thì KHÔNG có row nào.
model EventBracket {
  id                       String   @id @default(cuid())
  key                      String   @unique
  eventKey                 String
  event                    EventDef @relation(fields: [eventKey], references: [key], onDelete: Cascade)
  name                     String
  minRealmOrder            Int
  maxRealmOrder            Int
  minBodyRealmOrder        Int?
  maxBodyRealmOrder        Int?
  bracketTier              Int
  rewardTierMin            Int
  rewardTierMax            Int
  /// Cap tuyệt đối cho event này.
  eventMaxTier             Int
  rankingEnabled           Boolean  @default(true)
  shopFilterTier           Int      @default(9)
  bossPowerMultiplier      Float    @default(1.0)
  missionScalingMultiplier Float    @default(1.0)
  enabled                  Boolean  @default(true)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  @@unique([eventKey, key])
  @@index([eventKey, enabled])
  @@index([minRealmOrder, maxRealmOrder])
}

/// EventBalancePolicy — cap & policy per-event. 1-1 với EventDef.
model EventBalancePolicy {
  id                                     String   @id @default(cuid())
  eventKey                               String   @unique
  event                                  EventDef @relation(fields: [eventKey], references: [key], onDelete: Cascade)
  maxTokenPerDay                         Int
  maxTokenPerWeek                        Int
  maxTokenPerEvent                       Int
  maxRareRewardPerDay                    Int      @default(2)
  maxRareRewardPerWeek                   Int      @default(5)
  maxShopRareExchangePerEvent            Int      @default(10)
  allowHighLevelEnterLowBracket          Boolean  @default(true)
  highLevelLowBracketTokenPenaltyPercent Float    @default(0.5)
  highLevelLowBracketRankingDisabled     Boolean  @default(true)
  sourceTierRewardCap                    Int      @default(9)
  maxAllowedRewardTierDelta              Int      @default(1)
  /// Match `PaidRewardPolicy` ở shared.
  paidRewardPolicy                       String   @default("FREE_ONLY")
  enabled                                Boolean  @default(true)
  updatedByAdminId                       String?
  updatedByAdmin                         User?    @relation("EventBalancePolicyUpdatedBy", fields: [updatedByAdminId], references: [id], onDelete: SetNull)
  createdAt                              DateTime @default(now())
  updatedAt                              DateTime @updatedAt

  @@index([enabled])
}

/// EventItemConfig — định nghĩa item event (token / chest / ticket / cosmetic).
/// Khác `Item` catalog ở chỗ item event thường ephemeral (expiresAt) hoặc
/// bind-on-pickup, có cap riêng.
model EventItemConfig {
  id                   String    @id @default(cuid())
  key                  String    @unique
  eventKey             String?
  event                EventDef? @relation(fields: [eventKey], references: [key], onDelete: SetNull)
  name                 String
  description          String    @default("")
  itemKind             String
  itemTier             Int       @default(1)
  rarity               String    @default("COMMON")
  category             String    @default("event")
  expiresAt            DateTime?
  tradeable            Boolean   @default(false)
  bindOnPickup         Boolean   @default(true)
  maxStack             Int       @default(99999)
  dailyGainCap         Int?
  weeklyGainCap        Int?
  eventGainCap         Int?
  allowedSourcesJson   Json      @default("[]")
  forbiddenSourcesJson Json      @default("[]")
  sourceHint           String?
  lootTableJson        Json      @default("[]")
  enabled              Boolean   @default(true)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([eventKey, enabled])
  @@index([itemKind, enabled])
}

/// EventMissionDef — nhiệm vụ event.
model EventMissionDef {
  id               String   @id @default(cuid())
  key              String   @unique
  eventKey         String
  event            EventDef @relation(fields: [eventKey], references: [key], onDelete: Cascade)
  bracketKey       String?
  name             String
  description      String   @default("")
  missionType      String
  targetValue      Int
  /// DAILY / WEEKLY / EVENT_ONCE.
  resetType        String   @default("EVENT_ONCE")
  rewardProfileKey String?
  scoreAmount      Int      @default(0)
  tokenReward      Int      @default(0)
  enabled          Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  progresses EventMissionProgress[]

  @@index([eventKey, enabled])
  @@index([bracketKey, enabled])
}

/// EventMissionProgress — tiến độ per character per mission.
model EventMissionProgress {
  id           String          @id @default(cuid())
  eventKey     String
  event        EventDef        @relation(fields: [eventKey], references: [key], onDelete: Cascade)
  missionKey   String
  mission      EventMissionDef @relation(fields: [missionKey], references: [key], onDelete: Cascade)
  characterId  String
  character    Character       @relation(fields: [characterId], references: [id], onDelete: Cascade)
  bracketKey   String?
  currentValue Int             @default(0)
  completedAt  DateTime?
  claimedAt    DateTime?
  /// Reset cycle id (vd ngày YYYYMMDD cho DAILY; week ISO cho WEEKLY).
  resetCycleId String          @default("EVENT")
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@unique([missionKey, characterId, resetCycleId])
  @@index([characterId, eventKey])
  @@index([eventKey, missionKey])
}

/// EventShopDef — shop event gom các shop item.
model EventShopDef {
  id               String   @id @default(cuid())
  key              String   @unique
  eventKey         String
  event            EventDef @relation(fields: [eventKey], references: [key], onDelete: Cascade)
  name             String
  tokenCurrencyKey String
  startsAt         DateTime
  endsAt           DateTime
  enabled          Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  items EventShopItemDef[]

  @@index([eventKey, enabled])
}

/// Item trong shop event.
model EventShopItemDef {
  id                  String       @id @default(cuid())
  key                 String       @unique
  shopKey             String
  shop                EventShopDef @relation(fields: [shopKey], references: [key], onDelete: Cascade)
  itemKey             String
  rewardsJson         Json         @default("[]")
  priceTokenAmount    Int
  requiredBracketKey  String?
  minRealmOrder       Int?
  maxRealmOrder       Int?
  purchaseLimitDaily  Int?
  purchaseLimitWeekly Int?
  purchaseLimitEvent  Int?
  enabled             Boolean      @default(true)
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  purchases EventShopPurchase[]

  @@index([shopKey, enabled])
}

/// EventShopPurchase — lịch sử mua shop event, hỗ trợ track limit.
model EventShopPurchase {
  id          String           @id @default(cuid())
  eventKey    String
  event       EventDef         @relation(fields: [eventKey], references: [key], onDelete: Cascade)
  shopItemKey String
  shopItem    EventShopItemDef @relation(fields: [shopItemKey], references: [key], onDelete: Cascade)
  characterId String
  character   Character        @relation(fields: [characterId], references: [id], onDelete: Cascade)
  qty         Int              @default(1)
  pricePaid   Int
  resetDay    String /// YYYYMMDD theo timezone event.
  resetWeek   String /// YYYYWW ISO.
  createdAt   DateTime         @default(now())

  @@index([characterId, eventKey, createdAt(sort: Desc)])
  @@index([eventKey, shopItemKey])
  @@index([shopItemKey, characterId, resetDay])
  @@index([shopItemKey, characterId, resetWeek])
}

/// EventTokenWallet — số dư token event per character.
model EventTokenWallet {
  id           String    @id @default(cuid())
  eventKey     String
  event        EventDef  @relation(fields: [eventKey], references: [key], onDelete: Cascade)
  characterId  String
  character    Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  tokenKey     String
  balance      Int       @default(0)
  dailyEarned  Int       @default(0)
  weeklyEarned Int       @default(0)
  eventEarned  Int       @default(0)
  resetDay     String    @default("")
  resetWeek    String    @default("")
  updatedAt    DateTime  @updatedAt
  createdAt    DateTime  @default(now())

  @@unique([eventKey, characterId, tokenKey])
  @@index([characterId, eventKey])
}

/// EventBossDef — boss event runtime spec (PR2 sẽ hook combat).
model EventBossDef {
  id                            String   @id @default(cuid())
  key                           String   @unique
  eventKey                      String
  event                         EventDef @relation(fields: [eventKey], references: [key], onDelete: Cascade)
  bracketKey                    String?
  name                          String
  description                   String   @default("")
  bossType                      String
  sourceTier                    Int
  bossTier                      Int
  recommendedPower              Int      @default(0)
  hpFormulaKey                  String?
  scheduleKey                   String?
  participationRewardProfileKey String?
  damageRankingRewardProfileKey String?
  lastHitRewardProfileKey       String?
  sectRewardProfileKey          String?
  dailyAttempts                 Int      @default(3)
  weeklyAttempts                Int?
  enabled                       Boolean  @default(true)
  createdAt                     DateTime @default(now())
  updatedAt                     DateTime @updatedAt

  @@index([eventKey, enabled])
  @@index([bracketKey, enabled])
}

/// EventRankingDef — bảng ranking event.
model EventRankingDef {
  id               String   @id @default(cuid())
  key              String   @unique
  eventKey         String
  event            EventDef @relation(fields: [eventKey], references: [key], onDelete: Cascade)
  rankingType      String
  bracketMode      String
  bracketKey       String?
  scoreFormulaKey  String
  rewardProfileKey String?
  startsAt         DateTime
  endsAt           DateTime
  finalized        Boolean  @default(false)
  enabled          Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  entries EventRankingEntry[]

  @@index([eventKey, enabled])
}

/// EventRankingEntry — score per character per ranking.
model EventRankingEntry {
  id              String          @id @default(cuid())
  eventKey        String
  event           EventDef        @relation(fields: [eventKey], references: [key], onDelete: Cascade)
  rankingKey      String
  ranking         EventRankingDef @relation(fields: [rankingKey], references: [key], onDelete: Cascade)
  characterId     String
  character       Character       @relation(fields: [characterId], references: [id], onDelete: Cascade)
  bracketKey      String?
  score           Int             @default(0)
  rank            Int?
  rewardClaimedAt DateTime?
  updatedAt       DateTime        @updatedAt
  createdAt       DateTime        @default(now())

  @@unique([rankingKey, characterId])
  @@index([rankingKey, bracketKey, score(sort: Desc)])
  @@index([characterId, eventKey])
}

/// PersonalEventProgress — instance event cá nhân (auto trigger).
model PersonalEventProgress {
  id                 String    @id @default(cuid())
  /// Tham chiếu `EventDef.key` của event personal (template tạo từ admin).
  eventKey           String
  event              EventDef  @relation(fields: [eventKey], references: [key], onDelete: Cascade)
  characterId        String
  character          Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  triggerType        String
  triggerValue       Int
  startedAt          DateTime  @default(now())
  expiresAt          DateTime
  completedAt        DateTime?
  claimedAt          DateTime?
  bracketTier        Int       @default(1)
  /// Snapshot reward khi claim — audit history.
  rewardSnapshotJson Json      @default("{}")
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@unique([eventKey, characterId])
  @@index([characterId, expiresAt])
  @@index([eventKey, triggerType])
}

// ─── Phase 31.0 — Social & Retention Foundation V1 ────────────────────────

/// Phase 31.0 — taxonomy lý do gửi mail. Mail từ Phase 12 chưa có cột
/// `mailType`; migration thêm `mailType MailType @default(SYSTEM)` để
/// row cũ map sang `SYSTEM`. Reserved `PVP` cho Phase 29 (PvP / Arena /
/// Sect War / Territory) — Phase 31 KHÔNG write rows với type này.
enum MailType {
  SYSTEM
  ADMIN
  REWARD
  EVENT
  MAINTENANCE
  PURCHASE
  SECT
  FRIEND
  RETURNER
  PVP
}

/// Phase 31.0 — Audit log của mọi admin mail send (one / bulk / global).
/// Mỗi row sinh ra trong CÙNG transaction với việc create Mail rows →
/// đảm bảo invariant "không có admin mail nào không có audit". Recipient
/// snapshot truncate cho SEND_BULK lớn (chỉ giữ ~50 đầu tiên để cap row
/// size). `mailIds` lưu list id mail đã tạo để trace.
///
/// Server-authoritative: caller (`AdminMailService.sendAuthorized`) phải
/// pass `reason ≥ 4 chars` (validator). Mọi route POST `/admin/mail/*`
/// đều ghi 1 row vào bảng này.
model AdminMailLog {
  id                 String   @id @default(cuid())
  adminUserId        String
  kind               String
  mailType           MailType @default(ADMIN)
  subject            String
  reason             String
  mailCount          Int      @default(0)
  /// JSON string[] — recipient userIds / characterIds snapshot (≤50).
  recipientsSnapshot Json     @default("[]")
  /// JSON object — SystemGiftTargetRule snapshot for SEND_GLOBAL (null otherwise).
  targetRuleSnapshot Json?
  /// JSON string[] — ids của mail đã tạo trong transaction.
  mailIdsSnapshot    Json     @default("[]")
  previewOnly        Boolean  @default(false)
  createdAt          DateTime @default(now())

  @@index([adminUserId, createdAt])
  @@index([kind, createdAt])
}

/// Phase 31.0 — System Gift template / compensation row.
///
/// Mỗi row là 1 template để admin / cron "phát" thành Mail rows tới
/// target list. Claim đi qua mail flow thông thường (idempotent qua
/// `Mail.claimedAt`). `targetRuleJson` chứa rule resolve (xem
/// `SystemGiftTargetRule` shared catalog).
///
/// Anti-replay: `SystemGiftClaim` đảm bảo 1 character claim 1 gift
/// chỉ 1 lần (`@@unique([giftKey, characterId])`).
model SystemGift {
  id               String    @id @default(cuid())
  giftKey          String    @unique
  title            String
  body             String
  /// JSON SystemGiftReward shape.
  rewardJson       Json      @default("{}")
  /// JSON SystemGiftTargetRule shape.
  targetRuleJson   Json      @default("{}")
  expiresAt        DateTime?
  createdByAdminId String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([createdAt])
  @@index([expiresAt])
}

/// Phase 31.0 — Idempotency record cho 1 character đã nhận 1 gift.
/// Đảm bảo claim chỉ chạy 1 lần kể cả khi cron retry / race. Phép tạo
/// Mail row chỉ thực hiện nếu insert vào bảng này thành công (unique
/// constraint).
model SystemGiftClaim {
  id          String   @id @default(cuid())
  giftKey     String
  characterId String
  mailId      String?
  claimedAt   DateTime @default(now())

  @@unique([giftKey, characterId])
  @@index([characterId])
  @@index([giftKey])
}

/// Phase 31.0 — Returner state cho 1 character.
///
/// Cập nhật khi character login: tính inactiveDays từ `lastLoginAt`
/// cũ, resolve tier, idempotent trigger 1 lần / cycle (cycleKey =
/// `userId:tier:YYYY-MM-DD`). Lưu `currentTier` để FE biết hiển thị
/// banner returner.
///
/// Anti-replay: `lastCycleKey` unique constraint loose (qua filter
/// service-level). Không cần unique riêng vì 1 character chỉ có 1 row.
model CharacterReturnerState {
  characterId   String    @id
  /// ISO datetime của lần login PREVIOUS (trước login hiện tại). Dùng
  /// để compute inactiveDays.
  prevLoginAt   DateTime?
  /// ISO datetime của lần login hiện tại.
  lastLoginAt   DateTime?
  inactiveDays  Int       @default(0)
  /// SHORT / MEDIUM / LONG hoặc null nếu chưa qualify.
  currentTier   String?
  /// `userId:tier:YYYY-MM-DD` của trigger gần nhất (idempotent).
  lastCycleKey  String?
  /// ISO datetime của lần trigger gần nhất.
  lastTriggerAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([currentTier])
  @@index([lastTriggerAt])
}

/// Phase 31.0 — Mentor profile cho người chơi cao cảnh giới.
///
/// Mỗi user chỉ có 0 hoặc 1 MentorProfile (PK = userId). Tạo profile
/// = "đăng ký làm mentor". `acceptingStudents` cho phép mentor pause
/// nhận học trò.
model MentorProfile {
  mentorUserId       String   @id
  /// Snapshot tên hiển thị tại lúc tạo / update.
  displayName        String?
  /// Snapshot realm tier tại lúc tạo / update (auto sync khi mentor breakthrough).
  realmTier          Int      @default(0)
  intro              String?
  acceptingStudents  Boolean  @default(true)
  /// Counter ACTIVE student — cache để check cap nhanh; service phải
  /// đồng bộ qua transaction khi accept/end.
  activeStudentCount Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([realmTier])
  @@index([acceptingStudents])
}

/// Phase 31.0 — Mentor / Student relation.
///
/// Lifecycle: PENDING → ACTIVE | DECLINED, ACTIVE → ENDED.
/// Một student chỉ có MAX 1 quan hệ ACTIVE tại 1 thời điểm (enforce
/// service-level: query `findFirst` rồi reject `STUDENT_ALREADY_HAS_MENTOR`).
model MentorRelation {
  id                 String    @id @default(cuid())
  mentorUserId       String
  studentUserId      String
  status             String    @default("PENDING")
  message            String?
  mentorDisplayName  String?
  studentDisplayName String?
  createdAt          DateTime  @default(now())
  respondedAt        DateTime?
  endedAt            DateTime?

  @@index([mentorUserId, status, createdAt])
  @@index([studentUserId, status, createdAt])
  @@index([status, createdAt])
}

/// Phase 31.0 — Mail attachment claim ledger (idempotent audit). Phase
/// 31 mail vẫn dùng `Mail.claimedAt` làm CAS chính, nhưng bảng này
/// thêm 1 lớp idempotency riêng cho từng (mailId, characterId) — hữu
/// dụng khi tương lai 1 mail có nhiều attachment claim độc lập. Phase
/// 31 mỗi mail chỉ có 1 claim row.
model MailAttachmentClaim {
  id                 String   @id @default(cuid())
  mailId             String
  characterId        String
  /// JSON snapshot reward đã claim (string-safe BigInt). Audit.
  rewardSnapshotJson Json     @default("{}")
  claimedAt          DateTime @default(now())

  @@unique([mailId, characterId])
  @@index([characterId, claimedAt])
}

/// Phase 35.2 — Mentor Milestone Progress (Sư Đồ Phase 2).
///
/// Soft-ref `mentorRelationId` to `MentorRelation.id` (Phase 31.0) — không tạo FK
/// cascade để mirror cùng pattern soft-ref Phase 31.0/35.1. Lifecycle:
/// LOCKED → AVAILABLE → CLAIMED (per claim role tách qua `MentorRewardClaim`).
model MentorMilestoneProgress {
  id               String    @id @default(cuid())
  mentorRelationId String
  mentorUserId     String
  studentUserId    String
  /// Catalog key — xem `packages/shared/src/mentor-milestone.ts`.
  milestoneKey     String
  /// LOCKED | AVAILABLE | CLAIMED (CLAIMED = đã có ít nhất 1 trong 2 role claim;
  /// mentor/disciple claim độc lập tracked qua `MentorRewardClaim`).
  status           String    @default("LOCKED")
  reachedAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@unique([mentorRelationId, milestoneKey])
  @@index([studentUserId, status])
  @@index([mentorUserId, status])
}

/// Phase 35.2 — Mentor Reward Claim audit. UNIQUE (relationId, milestoneKey, role)
/// chống double-claim. Reward gửi qua mail (mailType = SYSTEM) — `mailId` lưu
/// reference để truy ngược nếu cần audit / refund.
model MentorRewardClaim {
  id                 String   @id @default(cuid())
  mentorRelationId   String
  milestoneKey       String
  claimerUserId      String
  /// 'MENTOR' | 'DISCIPLE'.
  role               String
  /// Mail row tương ứng (soft-ref; có thể null nếu mail tạo fail nhưng claim
  /// row đã insert — service phải atomic-rollback nếu mail fail).
  mailId             String?
  /// Snapshot reward đã grant (string-safe BigInt JSON).
  rewardSnapshotJson Json     @default("{}")
  claimedAt          DateTime @default(now())

  @@unique([mentorRelationId, milestoneKey, role])
  @@index([claimerUserId, claimedAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// Phase 29.0 — PvP Foundation V1
// ─────────────────────────────────────────────────────────────────────────────
//
// Unified PvP layer:
//   - `PvpBattle`: 1 row / trận, mode = DUEL|FRIENDLY_SPARRING|EVENT_PVP|
//     SECT_WAR|TERRITORY_WAR. Mode ARENA tiếp tục dùng `ArenaMatch` riêng.
//   - `PvpDefenseProfile`: saved defense formation độc lập với
//     `ArenaProfile.defenseSnapshotJson` (per-season). Đây là "global"
//     defense load khi nhận challenge ngoài arena.
//   - `PvpAnomalyLog`: anti-cheat anomaly detection (8 type theo
//     spec PHẦN 15). Admin review qua `/admin/pvp/anomalies`.

/// Phase 29.0 — Trận PvP non-arena (DUEL/FRIENDLY/EVENT/SECT_WAR/TERRITORY).
///
/// Mode `ARENA` tiếp tục dùng `ArenaMatch` (Phase 14.1.B) — bảng này chỉ
/// store các mode còn lại để giữ schema modular. Player UI gom cả 2 bảng
/// trong battle log viewer (xem `pvp.controller.ts → GET /pvp/battle-logs`).
///
/// Snapshot không sửa sau resolve (anti-cheat invariant). Admin có thể
/// flag `status=INVALIDATED` (qua `PVP_BATTLE_INVALIDATE` audit) nhưng
/// `roundsJson` / `rewardJson` immutable.
model PvpBattle {
  id                   String     @id @default(cuid())
  /// PvpMode literal (DUEL | FRIENDLY_SPARRING | EVENT_PVP | SECT_WAR | TERRITORY_WAR).
  mode                 String
  attackerCharacterId  String
  attacker             Character  @relation("PvpBattleAttacker", fields: [attackerCharacterId], references: [id], onDelete: Cascade)
  defenderCharacterId  String?
  defender             Character? @relation("PvpBattleDefender", fields: [defenderCharacterId], references: [id], onDelete: SetNull)
  /// PvpBattleStatus (PENDING|RESOLVED|CANCELLED|EXPIRED|INVALIDATED).
  status               String     @default("PENDING")
  /// PvpResult — null khi PENDING.
  result               String?
  /// Snapshot tại thời điểm queue (validatePvpSnapshot enforced).
  attackerSnapshotJson Json
  defenderSnapshotJson Json
  /// Resolve seed for replay verify. Random nhưng deterministic.
  seed                 Int        @default(0)
  /// Round summary array (KHÔNG frame-by-frame, chỉ delta).
  roundsJson           Json
  /// Reward snapshot — chỉ display, không re-grant. Null khi FRIENDLY_SPARRING.
  rewardJson           Json?
  /// Rating change (nếu mode = DUEL có rating). Arena vẫn ở ArenaMatch.
  ratingChangeJson     Json?
  /// Reference key (ví dụ eventKey, sectWarMatchId, territoryKey).
  sourceModuleKey      String?
  /// Đã grant reward chưa? Idempotency check.
  rewardGranted        Boolean    @default(false)
  /// Idempotency token để chặn double-resolve.
  idempotencyKey       String?
  createdAt            DateTime   @default(now())
  resolvedAt           DateTime?

  @@unique([idempotencyKey])
  @@index([attackerCharacterId, mode, createdAt])
  @@index([defenderCharacterId, mode, createdAt])
  @@index([mode, status, createdAt])
  @@index([sourceModuleKey, mode])
}

/// Phase 29.0 — Saved defense formation (global, không phải arena-only).
///
/// 1 character có 1 defense profile (UNIQUE). Khi character bị
/// challenge ngoài arena (DUEL hoặc SECT_WAR/TERRITORY_WAR), server load
/// snapshot này thay vì rebuild từ current equipment/methods/artifacts.
///
/// `label` cho player tự đặt tên (vd "Hỏa Pháp", "Đan Dược Tu"). Snapshot
/// được verify qua `validatePvpDefenseProfile` (snapshotType ∈
/// {DEFENDER, SECT_MEMBER}).
model PvpDefenseProfile {
  id           String    @id @default(cuid())
  characterId  String    @unique
  character    Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  /// Snapshot JSON tuân `validatePvpDefenseProfile`.
  snapshotJson Json
  /// Player-defined label (tối đa 60 ký tự — validator enforce).
  label        String?
  updatedAt    DateTime  @updatedAt
  createdAt    DateTime  @default(now())

  @@index([updatedAt])
}

/// Phase 29.0 — Anti-cheat anomaly detection log.
///
/// 8 anomaly type theo spec PHẦN 15. Mỗi anomaly có severity weight
/// (`PVP_ANOMALY_RISK_WEIGHT`). Admin queue review qua
/// `/admin/pvp/anomalies`. `resolvedBy` = adminUserId nếu admin
/// đã đánh giá; `resolution` ∈ {DISMISSED | CONFIRMED | ESCALATED}.
///
/// `relatedBattleId` reference `PvpBattle.id` hoặc `ArenaMatch.id`
/// (string-based, không FK cứng để gom được nhiều bảng).
model PvpAnomalyLog {
  id              String     @id @default(cuid())
  /// PvpAnomalyType literal.
  anomalyType     String
  /// Severity 0.0–1.0 (PVP_ANOMALY_RISK_WEIGHT lookup).
  severity        Float
  characterId     String?
  character       Character? @relation(fields: [characterId], references: [id], onDelete: SetNull)
  sectId          String?
  sect            Sect?      @relation(fields: [sectId], references: [id], onDelete: SetNull)
  /// PvpBattle.id / ArenaMatch.id / SectWarMatch.id (string, no FK).
  relatedBattleId String?
  /// Reason chi tiết (LLM-friendly text + JSON detail).
  detailJson      Json
  /// Auto-block reward claim nếu severity ≥ 0.8.
  blockedReward   Boolean    @default(false)
  resolvedBy      String?
  resolution      String?
  resolvedAt      DateTime?
  resolveReason   String?
  createdAt       DateTime   @default(now())

  @@index([anomalyType, createdAt])
  @@index([characterId, createdAt])
  @@index([sectId, createdAt])
  @@index([resolution, createdAt])
}

// =========================================================================
// Phase 30.0 — Market V2 / Auction House
// =========================================================================

/// Phase 30.0 — Auction session. Snapshot fields:
/// `currentBid`/`currentBidderId` cập nhật mỗi bid hợp lệ; full bid
/// history ở `MarketBid`. `status` ∈ MARKET_AUCTION_STATUSES.
model MarketAuction {
  id                String      @id @default(cuid())
  sellerCharacterId String
  seller            Character   @relation("MarketAuctionSeller", fields: [sellerCharacterId], references: [id], onDelete: Cascade)
  itemKey           String
  quantity          Int
  /// MarketCurrency literal.
  currency          String
  startPrice        BigInt
  buyoutPrice       BigInt?
  minBidStep        BigInt
  currentBid        BigInt?
  currentBidderId   String?
  currentBidder     Character?  @relation("MarketAuctionBidder", fields: [currentBidderId], references: [id], onDelete: SetNull)
  /// MarketAuctionStatus literal.
  status            String      @default("ACTIVE")
  startsAt          DateTime
  endsAt            DateTime
  finalizedAt       DateTime?
  feeAmount         BigInt      @default(0)
  taxAmount         BigInt      @default(0)
  lockedBy          String?
  lockedReason      String?
  metadataJson      Json        @default("{}")
  bids              MarketBid[]
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  @@index([status, endsAt])
  @@index([sellerCharacterId, status])
  @@index([itemKey, status])
}

/// Phase 30.0 — Single bid. `status` ∈ MARKET_BID_STATUSES.
/// Refund flow: khi bid bị outbid → status=OUTBID, refund vào claim box.
/// Khi auction finalize → winner.status=WON, others=REFUNDED.
model MarketBid {
  id                String        @id @default(cuid())
  auctionId         String
  auction           MarketAuction @relation(fields: [auctionId], references: [id], onDelete: Cascade)
  bidderCharacterId String
  bidder            Character     @relation(fields: [bidderCharacterId], references: [id], onDelete: Cascade)
  bidAmount         BigInt
  currency          String
  status            String        @default("ACTIVE")
  wasBuyout         Boolean       @default(false)
  refundedAt        DateTime?
  createdAt         DateTime      @default(now())

  @@index([auctionId, createdAt])
  @@index([bidderCharacterId, createdAt])
  @@index([status, createdAt])
}

/// Phase 30.0 — Claim box entry. Mỗi entry = 1 reward chờ player nhận
/// (idempotent). `source` ∈ MARKET_CLAIM_BOX_SOURCES. `sourceRefId` =
/// auctionId / listingId / ledger tx id để dedupe.
model MarketClaimBoxEntry {
  id           String    @id @default(cuid())
  characterId  String
  character    Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  source       String
  sourceRefId  String?
  itemKey      String?
  itemQty      Int?
  currency     String?
  amount       BigInt?
  status       String    @default("PENDING")
  expiresAt    DateTime?
  claimedAt    DateTime?
  metadataJson Json      @default("{}")
  createdAt    DateTime  @default(now())

  @@index([characterId, status])
  @@index([source, sourceRefId])
  @@index([status, expiresAt])
}

/// Phase 30.0 — Aggregated price snapshot per itemKey. Updated cron-style.
model MarketPriceSnapshot {
  id          String   @id @default(cuid())
  itemKey     String   @unique
  avgPrice24h BigInt   @default(0)
  avgPrice7d  BigInt   @default(0)
  avgPrice30d BigInt   @default(0)
  minPrice    BigInt   @default(0)
  maxPrice    BigInt   @default(0)
  volume24h   BigInt   @default(0)
  volume7d    BigInt   @default(0)
  updatedAt   DateTime
  createdAt   DateTime @default(now())

  @@index([updatedAt])
}

/// Phase 30.0 — Per-item policy override. KHÔNG sửa catalog code.
/// `tradability` ∈ ITEM_TRADABILITIES.
model MarketItemPolicy {
  id                     String   @id @default(cuid())
  itemKey                String   @unique
  tradability            String
  minPrice               BigInt?
  maxPrice               BigInt?
  maxListingsPerDay      Int?
  maxQtyPerListing       Int?
  taxRatePctOverride     Float?
  listingFeeFlatOverride BigInt?
  reason                 String?
  updatedBy              String?
  updatedAt              DateTime
  createdAt              DateTime @default(now())

  @@index([tradability])
}

/// Phase 30.0 — Personal stall config (1-1 character).
model PersonalStall {
  id               String    @id @default(cuid())
  characterId      String    @unique
  character        Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  stallName        String
  description      String?
  slotLimit        Int       @default(6)
  autoRenewEnabled Boolean   @default(false)
  themeKey         String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

/// Phase 30.0 — Sect treasury bag. Unique per (sectId, itemKey).
model SectTreasuryItem {
  id        String   @id @default(cuid())
  sectId    String
  sect      Sect     @relation(fields: [sectId], references: [id], onDelete: Cascade)
  itemKey   String
  quantity  Int      @default(0)
  lockedQty Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([sectId, itemKey])
  @@index([sectId])
}

/// Phase 30.0 — Sect treasury audit log. action ∈
/// SECT_TREASURY_ACTION_TYPES.
model SectTreasuryLog {
  id               String   @id @default(cuid())
  sectId           String
  sect             Sect     @relation(fields: [sectId], references: [id], onDelete: Cascade)
  actorCharacterId String?
  actorAdminId     String?
  action           String
  itemKey          String?
  quantity         Int?
  reason           String?
  metadataJson     Json     @default("{}")
  createdAt        DateTime @default(now())

  @@index([sectId, createdAt])
  @@index([action, createdAt])
}

/// Phase 30.0 — Sect internal auction. Tách khỏi MarketAuction vì
/// scope sect-only + currency = SECT_CONTRIBUTION/LINH_THACH.
model SectInternalAuction {
  id                   String                   @id @default(cuid())
  sectId               String
  sect                 Sect                     @relation(fields: [sectId], references: [id], onDelete: Cascade)
  itemKey              String
  quantity             Int
  currency             String
  startPrice           BigInt
  minBidStep           BigInt
  currentBid           BigInt?
  currentBidderId      String?
  status               String                   @default("ACTIVE")
  startsAt             DateTime
  endsAt               DateTime
  finalizedAt          DateTime?
  createdByCharacterId String?
  bids                 SectInternalAuctionBid[]
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt

  @@index([sectId, status])
  @@index([status, endsAt])
}

/// Phase 30.0 — Bid của sect internal auction.
model SectInternalAuctionBid {
  id                String              @id @default(cuid())
  sectAuctionId     String
  sectAuction       SectInternalAuction @relation(fields: [sectAuctionId], references: [id], onDelete: Cascade)
  bidderCharacterId String
  bidder            Character           @relation(fields: [bidderCharacterId], references: [id], onDelete: Cascade)
  bidAmount         BigInt
  currency          String
  status            String              @default("ACTIVE")
  createdAt         DateTime            @default(now())

  @@index([sectAuctionId, createdAt])
  @@index([bidderCharacterId, createdAt])
}

/// Phase 30.0 — Market anomaly (V2 broader than Phase 16.4
/// MarketTradeAnomaly). anomalyType ∈ MARKET_ANOMALY_TYPES.
model MarketAnomaly {
  id                String    @id @default(cuid())
  anomalyType       String
  severity          String
  sellerCharacterId String?
  buyerCharacterId  String?
  listingId         String?
  auctionId         String?
  totalValue        BigInt?
  detailJson        Json      @default("{}")
  resolvedBy        String?
  resolvedAt        DateTime?
  resolveReason     String?
  createdAt         DateTime  @default(now())

  @@index([anomalyType, createdAt])
  @@index([severity, resolvedAt])
  @@index([sellerCharacterId])
  @@index([buyerCharacterId])
}

// =========================================================================
// Phase 32.0 — Tu Tiên Bách Khoa / Codex / Bestiary
// =========================================================================

/// Phase 32.0 — Codex entry per item/monster/map/realm/method. Generated
/// bởi `CodexIndexerService` từ catalog hiện có. Admin có thể override
/// description/visibility nhưng KHÔNG nên đổi entryKey/type/refKey.
model CodexEntry {
  id                   String   @id @default(cuid())
  entryKey             String   @unique
  type                 String
  refKey               String
  displayName          String
  description          String?
  iconKey              String?
  visibility           String   @default("PUBLIC")
  tagsJson             Json     @default("[]")
  sourceHintsJson      Json     @default("[]")
  usageHintsJson       Json     @default("[]")
  relatedEntryKeysJson Json     @default("[]")
  realmRequired        String?
  quality              String?
  tier                 Int?
  updatedBy            String?
  updatedAt            DateTime
  createdAt            DateTime @default(now())

  @@index([type])
  @@index([refKey])
  @@index([visibility])
}

/// Phase 32.0 — Character discovery progress. Insert khi player lần
/// đầu chạm entry (kill monster, loot item, …). Unique per
/// (characterId, entryKey) — idempotent.
model CharacterCodexProgress {
  id           String    @id @default(cuid())
  characterId  String
  character    Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  entryKey     String
  discoveredAt DateTime  @default(now())
  context      String?
  metadataJson Json      @default("{}")

  @@unique([characterId, entryKey])
  @@index([characterId])
  @@index([entryKey])
}

/// Phase 32.0 — Codex audit issue. Generated bởi
/// `CodexAuditService` + admin manual.
model CodexAuditIssue {
  id         String    @id @default(cuid())
  issueKey   String    @unique
  entryKey   String
  type       String
  severity   String
  message    String
  resolved   Boolean   @default(false)
  resolvedBy String?
  resolvedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([entryKey])
  @@index([severity, resolved])
}

/// Phase 32.0 — Reindex log. Mỗi lần admin trigger reindex →
/// 1 row với summary.
model CodexReindexLog {
  id              String   @id @default(cuid())
  triggeredBy     String
  entriesUpserted Int      @default(0)
  entriesRemoved  Int      @default(0)
  issuesFound     Int      @default(0)
  summaryJson     Json     @default("{}")
  createdAt       DateTime @default(now())

  @@index([createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// Phase 41.0 — Player Experience QoL Foundation
// ─────────────────────────────────────────────────────────────────────────────
//
// 3 model additive cho:
//   - `PlayerSettings`: settings JSON (font / appearance / compact / …)
//     1-1 với Character. Settings cũ ở `Character.settings` Json giữ nguyên
//     (legacy schema, có thể chứa flag khác). Phase 41 dùng bảng riêng để
//     versioning + index timestamps.
//   - `PlayerFeedback`: trung tâm bug report / balance / UI feedback /
//     lost-item / payment / market / quest / cheat report. KHÔNG auto-ban.
//   - `PlayerReport`: report người-chơi-báo-người-chơi foundation; admin
//     review thủ công. KHÔNG auto-ban.

/// Phase 41.0 — Player settings (1-1 với Character).
///
/// `settingsJson` lưu shape `PlayerSettings` (shared catalog). Default
/// trả về khi row chưa tồn tại — service lazy-create khi PATCH lần đầu.
model PlayerSettings {
  characterId  String    @id
  character    Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  settingsJson Json      @default("{}")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([updatedAt])
}

/// Phase 41.0 — Player feedback / bug report center.
///
/// KHÔNG dùng cho gameplay action (combat report). Chỉ phục vụ support
/// channel (BUG / BALANCE / UI / LOST_ITEM / PAYMENT / MARKET / PLAYER /
/// CHEAT / QUEST_STUCK / OTHER). `targetCharacterId` chỉ tham chiếu;
/// KHÔNG có auto-ban side-effect.
model PlayerFeedback {
  id                  String     @id @default(cuid())
  reporterCharacterId String
  reporter            Character  @relation("PlayerFeedbackReporter", fields: [reporterCharacterId], references: [id], onDelete: Cascade)
  type                String
  title               String
  description         String
  severity            String     @default("MEDIUM")
  status              String     @default("NEW")
  relatedFeature      String?
  relatedEntityType   String?
  relatedEntityId     String?
  targetCharacterId   String?
  targetCharacter     Character? @relation("PlayerFeedbackTarget", fields: [targetCharacterId], references: [id], onDelete: SetNull)
  adminNote           String?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt
  resolvedAt          DateTime?

  @@index([reporterCharacterId, createdAt])
  @@index([status, createdAt])
  @@index([type, status, createdAt])
  @@index([targetCharacterId, createdAt])
}

/// Phase 41.0 — Player report (player → player) foundation.
///
/// Có status `NEW → REVIEWING → ACTION_TAKEN | DISMISSED | DUPLICATE`.
/// Không auto-ban; chỉ track để admin/MOD review. Anti-spam soft cap qua
/// service layer (xem `PLAYER_REPORT_LIMITS`).
model PlayerReport {
  id                  String    @id @default(cuid())
  reporterCharacterId String
  reporter            Character @relation("PlayerReportReporter", fields: [reporterCharacterId], references: [id], onDelete: Cascade)
  targetCharacterId   String
  targetCharacter     Character @relation("PlayerReportTarget", fields: [targetCharacterId], references: [id], onDelete: Cascade)
  reportType          String
  status              String    @default("NEW")
  description         String
  evidenceJson        Json?
  adminNote           String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  resolvedAt          DateTime?

  @@index([reporterCharacterId, createdAt])
  @@index([targetCharacterId, createdAt])
  @@index([status, createdAt])
  @@index([reportType, status, createdAt])
}

// ─── Phase 33.1 — Story V2 Runtime (Phase 33 catalog) ─────────────────────────
// Additive, separate tables from Phase 12 `QuestProgress`. Catalog vẫn ở
// `packages/shared/src/story-quest-expansion.ts` + `story-quest-dialogues.ts`.

/// Phase 33.1 — Per-character per-chapter progress for Phase 33 story chapters
/// (`ch09`..`ch27`). Status enum stored as String (mirror QuestProgress.status
/// pattern): LOCKED | AVAILABLE | IN_PROGRESS | COMPLETED.
///
/// Lazy-created khi character reach required realm cho chapter — service tự
/// insert AVAILABLE row. Transition AVAILABLE→IN_PROGRESS khi player accept
/// quest đầu tiên trong chapter; IN_PROGRESS→COMPLETED khi tất cả MAIN quest
/// COMPLETED (mainQuestsCompletedCount === mainQuestsTotal cho chapter).
model CharacterStoryV2ChapterProgress {
  id                       String    @id @default(cuid())
  characterId              String
  character                Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  chapKey                  String
  /// LOCKED | AVAILABLE | IN_PROGRESS | COMPLETED.
  status                   String    @default("AVAILABLE")
  mainQuestsCompletedCount Int       @default(0)
  unlockedAt               DateTime?
  completedAt              DateTime?
  /// Array story flags player đã bật trong chapter này (subset của
  /// `phase33StoryFlagsFromQuests()`). JSON serialized.
  storyFlags               Json      @default("[]")
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  @@unique([characterId, chapKey])
  @@index([characterId, status])
}

/// Phase 33.1 — Per-character per-quest progress cho Phase 33 catalog
/// (`STORY_QUEST_EXPANSION`). Tách bạch hoàn toàn với Phase 12 `QuestProgress`
/// (Phase 12 dùng catalog `QUESTS`).
///
/// Status flow: LOCKED → AVAILABLE → ACCEPTED → COMPLETED → CLAIMED.
/// stepProgress Json map `{ <stepId>: <currentCount> }`. Step kind talk /
/// explore / choice / flag_set increment qua `progressQuest()`; kill / collect
/// defer Phase 33.3 World Objective Deep Wire (PR D).
model CharacterStoryV2QuestProgress {
  id           String    @id @default(cuid())
  characterId  String
  character    Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  questKey     String
  /// Denormalized for index — same as `phase33QuestByKey(questKey).chapKey`.
  chapKey      String
  /// LOCKED | AVAILABLE | ACCEPTED | COMPLETED | CLAIMED.
  status       String    @default("AVAILABLE")
  /// Map `{ <stepId>: <currentCount> }`. Default `{}`.
  stepProgress Json      @default("{}")
  acceptedAt   DateTime?
  completedAt  DateTime?
  claimedAt    DateTime?
  /// Phase 33.4 — Daily/weekly reset window. Null for non-repeatable quests.
  windowStart  DateTime?
  windowEnd    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([characterId, questKey])
  @@index([characterId, chapKey, status])
  @@index([status, completedAt])
  /// Phase 33.4 — Index cho reset scheduler query: find CLAIMED + windowEnd <= now.
  @@index([status, windowEnd])
}

/// Phase 33.1 — Idempotent claim audit ledger. Insert duy nhất 1 row khi
/// claim transaction commit thành công. Race-loser KHÔNG insert (CAS guard
/// trên QuestProgress.claimedAt fail trước khi reach insert ledger).
///
/// Mirror `LiveOpsEventRewardClaim` pattern (one-time per character per key).
/// Đây là audit row — currency/item/exp/affinity grants thực tế đã đi qua
/// `CurrencyLedger` / `ItemLedger` / `CharacterNpcAffinity` rows riêng.
model CharacterStoryV2RewardClaim {
  id               String    @id @default(cuid())
  characterId      String
  character        Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  questKey         String
  linhThachGranted BigInt    @default(0)
  tienNgocGranted  Int       @default(0)
  expGranted       BigInt    @default(0)
  congHienGranted  Int       @default(0)
  /// JSON `[{itemKey, qty}]`.
  itemsGranted     Json      @default("[]")
  /// JSON `[{npcKey, delta}]`.
  affinityGranted  Json      @default("[]")
  claimedAt        DateTime  @default(now())

  @@unique([characterId, questKey])
  @@index([characterId, claimedAt])
}

/// Phase 34.0 — 7-Day Onboarding Day-level Progress.
///
/// Một row mỗi (characterId, dayNumber). Lazy-create AVAILABLE row khi
/// character lần đầu mở `/onboarding-quest`. Status flow:
///
///   LOCKED → AVAILABLE → IN_PROGRESS → COMPLETED
///
/// Day 1 luôn AVAILABLE. Day N (N≥2) AVAILABLE khi tất cả task của Day
/// N-1 đã ở status `COMPLETED` hoặc `CLAIMED`.
model CharacterOnboardingProgress {
  id          String    @id @default(cuid())
  characterId String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  dayNumber   Int
  /// LOCKED | AVAILABLE | IN_PROGRESS | COMPLETED.
  status      String    @default("LOCKED")
  unlockedAt  DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([characterId, dayNumber])
  @@index([characterId, status])
}

/// Phase 34.0 — 7-Day Onboarding Task-level Progress.
///
/// Một row mỗi (characterId, taskKey). Lazy-create AVAILABLE row khi
/// `GET /onboarding-quest/v1/progress` được gọi và day cha đang AVAILABLE
/// hoặc IN_PROGRESS. Status flow:
///
///   LOCKED → AVAILABLE → COMPLETED → CLAIMED
///
/// Idempotency: complete/claim CAS guard qua `updateMany({status:'...'}) `.
/// Re-call sau khi đã CLAIMED trả về current state, KHÔNG cộng reward.
model CharacterOnboardingTaskProgress {
  id               String    @id @default(cuid())
  characterId      String
  character        Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  taskKey          String
  /// Denormalized for index — same as `onboardingTaskByKey(taskKey).dayNumber`.
  dayNumber        Int
  /// LOCKED | AVAILABLE | COMPLETED | CLAIMED.
  status           String    @default("AVAILABLE")
  completedAt      DateTime?
  claimedAt        DateTime?
  /// Cached linh thach granted on claim (for audit; mirror
  /// `OnboardingTaskRewardDef.linhThach`).
  linhThachGranted Int       @default(0)
  /// Cached exp granted on claim.
  expGranted       Int       @default(0)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@unique([characterId, taskKey])
  @@index([characterId, dayNumber, status])
}

/// Phase 34.1 — Daily Random Encounter / Kỳ Ngộ runtime row.
///
/// One row per (characterId, dateKey). `dateKey` is `YYYY-MM-DD` in
/// `MISSION_RESET_TZ` (default Asia/Ho_Chi_Minh). Lazy-create on first
/// `GET /encounters/v1/today`. Status flow:
///
///   AVAILABLE → ACCEPTED → COMPLETED → CLAIMED (terminal)
///                     ↘ SKIPPED (terminal)
///
/// `encounterKey` is rolled deterministically from `(characterId, dateKey)` so
/// re-reading the same day returns the same encounter. `choiceKey` optional
/// (only set when encounter has multi-choice branches). `payloadJson` stores
/// arbitrary metadata (e.g. reroll seed, rolled reward profile).
model CharacterDailyEncounter {
  id               String    @id @default(cuid())
  characterId      String
  character        Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  encounterKey     String
  /// Server-controlled rarity bucket — common | uncommon | rare | hidden.
  rarity           String    @default("common")
  /// `YYYY-MM-DD` in `MISSION_RESET_TZ`.
  dateKey          String
  /// AVAILABLE | ACCEPTED | COMPLETED | CLAIMED | SKIPPED.
  status           String    @default("AVAILABLE")
  choiceKey        String?
  /// Cached linh thach / exp granted on claim (for audit).
  linhThachGranted Int       @default(0)
  expGranted       Int       @default(0)
  /// Optional metadata: rolled reward profile, journal hint, etc.
  payloadJson      Json      @default("{}")
  acceptedAt       DateTime?
  completedAt      DateTime?
  claimedAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@unique([characterId, dateKey])
  @@index([characterId, status])
  @@index([dateKey, status])
}

/// Phase 34.2 — Secret Realm / Bí Cảnh runtime run row.
///
/// One row per (characterId, secretRealmKey, startedAt) — multiple historical
/// runs allowed. Active run gated by `realmKey` cooldown +
/// `requiredRealmOrder` (enforced in `SecretRealmService.enter`).
///
/// Status flow:
///   ENTERED → CLEARED → CLAIMED (terminal)
///        ↘ EXPIRED (background cleanup, not implemented v1)
model CharacterSecretRealmRun {
  id                    String    @id @default(cuid())
  characterId           String
  character             Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  secretRealmKey        String
  /// ENTERED | CLEARED | CLAIMED | EXPIRED.
  status                String    @default("ENTERED")
  startedAt             DateTime  @default(now())
  clearedAt             DateTime?
  claimedAt             DateTime?
  expiresAt             DateTime?
  /// Map objectiveKey → currentCount (e.g. `{clear_rooms:2,collect:1}`).
  objectiveProgressJson Json      @default("{}")
  /// Cached linh thach / exp granted on claim.
  linhThachGranted      Int       @default(0)
  expGranted            Int       @default(0)
  /// SHA256 hash of rolled reward profile (for idempotency vs replay).
  rewardHash            String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([characterId, secretRealmKey, status])
  @@index([secretRealmKey, status])
}

/// Phase QOL-2 — Loadout Preset PvE/PvP/Boss.
///
/// Mỗi preset là snapshot lựa chọn của 3 nhóm equip:
///   - `equipmentSlotJson` — `Record<EquipSlot, inventoryItemId>` cho gear.
///   - `skillSlotJson` — `string[]` skillKey active (cap = 4 theo equip rule
///     hiện hành ở `CharacterSkill.isEquipped`).
///   - `artifactSlotJson` — `Record<ArtifactEquipSlot, characterArtifactId>`
///     cho Pháp Bảo V2.
///
/// `mode` ∈ {`PVE`, `PVP`, `BOSS`, `CUSTOM`} — hỗ trợ set-default mỗi mode
/// qua `isDefaultForPve`, `isDefaultForPvp`, `isDefaultForBoss`. Khi
/// set-default mode X cho preset A, server tự bỏ default cờ trên các preset
/// khác cùng character cùng cờ.
///
/// `apply(presetId)` atomic: validate toàn bộ ownership + slot trước khi
/// rewrite `InventoryItem.equippedSlot` / `CharacterSkill.isEquipped` /
/// `CharacterArtifactV2.equippedSlot` trong cùng `$transaction`. Item
/// `locked` vẫn equip được (chỉ chặn `use`). Item missing → reject toàn bộ
/// apply, trả warning.
///
/// Backref: `Character.loadoutPresets` (FK Cascade khi xoá character).
model CharacterLoadoutPreset {
  id                String    @id @default(cuid())
  characterId       String
  character         Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  /// Tên preset do user chọn (1..40 ký tự, unique per character).
  name              String
  /// `LoadoutPresetMode` ∈ {`PVE`, `PVP`, `BOSS`, `CUSTOM`}.
  mode              String
  /// `Record<EquipSlot, string>` — keys giới hạn `EquipSlot` enum.
  equipmentSlotJson Json      @default("{}")
  /// `string[]` skillKey active (cap 4); null = không thay đổi skill khi apply.
  skillSlotJson     Json?
  /// `Record<string, string>` artifact slot → characterArtifactId; null =
  /// không thay đổi pháp bảo khi apply.
  artifactSlotJson  Json?
  isDefaultForPve   Boolean   @default(false)
  isDefaultForPvp   Boolean   @default(false)
  isDefaultForBoss  Boolean   @default(false)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@unique([characterId, name])
  @@index([characterId])
  @@index([characterId, mode])
  @@index([characterId, isDefaultForPve])
  @@index([characterId, isDefaultForPvp])
  @@index([characterId, isDefaultForBoss])
}

// ─────────────────────────────────────────────────────────────────────────
// Phase 35.0 — Pet / Linh Thú Full System
// ─────────────────────────────────────────────────────────────────────────
//
// Ownership-side: `CharacterPet` (1 row mỗi instance), `CharacterPetShard`
// (kho shard per pet), `CharacterPetBoxPityCounter` (per box+pool), and
// `PetBoxOpenLog` (audit per open). Catalog (`petKey`/`boxKey`/`poolKey`/
// `rateVersion`) lưu ở shared catalog (`packages/shared/src/pets.ts` +
// `pet-boxes.ts`). Mọi grant/consume phải đi qua InventoryService /
// CurrencyService — KHÔNG direct mutate.
//
// **Snapshot fields** (`rarity`, `quality`, `element`, `sourceType`)
// snapshot tại lúc obtain. Catalog có thể đổi (rate version) mà không phá
// instance hiện hữu.
model CharacterPet {
  id              String    @id @default(cuid())
  characterId     String
  character       Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  petKey          String
  customName      String?
  level           Int       @default(1)
  exp             Int       @default(0)
  star            Int       @default(1)
  /// Snapshot quality tại lúc obtain (`PHAM` | `LINH` | `HUYEN` | `DIA` | `THIEN` | `THAN`).
  quality         String
  /// Snapshot rarity (`COMMON` | … | `MYTHIC`).
  rarity          String
  /// Snapshot element (Ngũ Hành + ext).
  element         String
  evolutionStage  Int       @default(0)
  isLocked        Boolean   @default(false)
  isEquipped      Boolean   @default(false)
  equippedSlot    Int?
  /// Skill levels Json: `{ [skillKey]: level }`.
  skillLevelsJson Json      @default("{}")
  /// Source tại lúc obtain: BOX | EVENT | DUNGEON | BOSS | ACHIEVEMENT | …
  sourceType      String
  obtainedAt      DateTime  @default(now())
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([characterId])
  @@index([petKey])
  @@index([characterId, isEquipped])
  @@index([characterId, quality])
}

/// Shard kho per (character, pet). Server consume khi star-up.
model CharacterPetShard {
  id          String    @id @default(cuid())
  characterId String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  petKey      String
  amount      Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([characterId, petKey])
  @@index([characterId])
}

/// Pity counter per (character, box, pool). Server tăng/reset khi mở.
model CharacterPetBoxPityCounter {
  id                  String    @id @default(cuid())
  characterId         String
  character           Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  boxKey              String
  poolKey             String
  totalOpens          Int       @default(0)
  opensSinceRare      Int       @default(0)
  opensSinceEpic      Int       @default(0)
  opensSinceLegendary Int       @default(0)
  opensSinceMythic    Int       @default(0)
  lastResetAt         DateTime?
  updatedAt           DateTime  @updatedAt
  createdAt           DateTime  @default(now())

  @@unique([characterId, boxKey, poolKey])
  @@index([characterId])
}

/// Audit log mỗi lần mở hộp. Idempotent qua `(characterId, boxKey,
/// requestId)` nếu service cung cấp requestId.
model PetBoxOpenLog {
  id              String    @id @default(cuid())
  characterId     String
  character       Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  boxKey          String
  poolKey         String
  /// `LINH_THACH` | `TIEN_NGOC` | `EVENT_TOKEN` | `TICKET`.
  costType        String
  costAmount      BigInt    @default(0)
  /// `PET` | `SHARD` | `MATERIAL` | `TICKET_REFUND`.
  resultType      String
  resultKey       String
  resultAmount    Int       @default(1)
  resultRarity    String
  resultQuality   String
  pityTriggered   Boolean   @default(false)
  pityRuleVersion String?
  rateVersion     Int       @default(1)
  requestId       String?
  createdAt       DateTime  @default(now())

  @@unique([characterId, boxKey, requestId])
  @@index([characterId, createdAt])
  @@index([boxKey, createdAt])
}

/// Phase PWA-1 — Web Push subscription endpoint.
///
/// 1 row / browser-device (endpoint là unique). Một user có thể
/// subscribe nhiều device; service cap `PER_USER_SUBSCRIPTION_MAX` ở
/// layer trên. `enabled=false` khi user unsubscribe hoặc push gateway
/// trả về 404/410 (subscription invalid).
///
/// Privacy:
///   - `endpoint` chứa device-specific ID từ FCM/Mozilla/Apple push
///     gateway — KHÔNG log / KHÔNG expose qua public API ngoại trừ
///     chính user / admin.
///   - `userAgent` đã sanitize control char + cap 256 chars.
///
/// Cleanup:
///   - 410 Gone / 404 Not Found ⇒ service set `enabled=false`.
///   - `failureCount >= FAILURE_HARD_DELETE_THRESHOLD` ⇒ admin/cron
///     hard-delete (best-effort).
model WebPushSubscription {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Push gateway endpoint URL (FCM / Mozilla AutoPush / Apple WebPush).
  endpoint     String    @unique
  /// ECDH P-256 public key (base64url).
  p256dh       String
  /// Auth secret (base64url).
  auth         String
  userAgent    String?
  enabled      Boolean   @default(true)
  failureCount Int       @default(0)
  /// Last successful push send (server side). Null = never.
  lastUsedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([userId, enabled])
  @@index([enabled, updatedAt])
}

/// Phase PWA-1 — Per-user notification preferences (1-1 User).
///
/// Lazy upsert: row tạo ngay khi user mở settings hoặc subscribe lần
/// đầu. Defaults trong `DEFAULT_WEB_PUSH_PREFERENCES` (boss/stamina/mail
/// ON, daily reminder OFF — opt-in).
///
/// `quietHoursStart`/`End` là `HH:mm` 24h (UTC theo design ban đầu —
/// client truyền timezone IANA + service quy đổi trước khi check
/// `isInQuietHours`). KHÔNG block BOSS_SPAWN trong quiet hours (game
/// critical).
///
/// Cooldown / dedupe key store ở `WebPushSendLog` (model bên dưới);
/// không persist trực tiếp ở đây để pref row gọn.
model UserPushPreferences {
  userId               String   @id
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bossSpawnEnabled     Boolean  @default(true)
  staminaFullEnabled   Boolean  @default(true)
  mailEnabled          Boolean  @default(true)
  /// Default OFF — opt-in: user phải bật rõ ràng.
  dailyReminderEnabled Boolean  @default(false)
  quietHoursStart      String?
  quietHoursEnd        String?
  timezone             String?
  updatedAt            DateTime @updatedAt
}

/// Phase PWA-1 — Push send log (per type / per user) cho cooldown
/// + dedupe + audit.
///
/// 1 row / user / type ⇒ unique. Service upsert mỗi lần send thành
/// công (status `OK`) hoặc dry-run; lookup `lastSentAt` để
/// `shouldSendPushNotification` check cooldown.
///
/// Retention: rows nhẹ (1 row / user / 4 types = max 4 row / user),
/// không cần cleanup proactive.
model WebPushSendLog {
  id         String   @id @default(cuid())
  userId     String
  /// Literal `WebPushNotificationType`:
  ///   BOSS_SPAWN / STAMINA_FULL / MAIL_NEW / DAILY_REMINDER
  type       String
  lastSentAt DateTime @default(now())
  /// Optional dedupe key (vd `boss-${bossId}-${spawnAt}`) — nếu
  /// caller cung cấp, service so sánh trước khi send tiếp.
  dedupeKey  String?
  /// `OK` / `DRY_RUN` / `BLOCKED_DISABLED` / `BLOCKED_COOLDOWN` /
  /// `BLOCKED_QUIET_HOURS` / `ERROR_GATEWAY`.
  lastStatus String   @default("OK")
  updatedAt  DateTime @updatedAt

  @@unique([userId, type])
  @@index([userId, lastSentAt(sort: Desc)])
}
