DATABASE_URL=postgresql://mtt:mtt@localhost:5432/mtt
REDIS_URL=redis://localhost:6379
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000
SESSION_COOKIE_DOMAIN=localhost
PORT=3000
NODE_ENV=development
# Bootstrap admin đầu tiên — đặt 2 biến này rồi chạy `pnpm --filter @xuantoi/api bootstrap`.
# Script idempotent: chạy lại không tạo duplicate, không đổi password admin đã có.
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=change-me-bootstrap-pass
# Timezone cho mission reset (DAILY 00:00 / WEEKLY thứ Hai 00:00 theo zone này).
# Mặc định Asia/Ho_Chi_Minh (UTC+07, không DST). Đặt UTC nếu muốn reset theo UTC.
MISSION_RESET_TZ=Asia/Ho_Chi_Minh

# Phase 16.5 — Daily Reward Cap. Timezone tính `dayBucket` (YYYY-MM-DD) cho
# anti-abuse cap layer của 3 nguồn reward (CULTIVATION/DUNGEON/MISSION).
# Mặc định Asia/Ho_Chi_Minh — đồng bộ với `MISSION_RESET_TZ`. Override để
# dev/test có boundary reproducible (vd. UTC).
DAILY_REWARD_CAP_TZ=Asia/Ho_Chi_Minh

# Phí giao dịch sàn (chợ đạo cụ). Số thực [0, 0.5]; mặc định 0.05 (5%).
# Đặt MARKET_FEE_PCT=0 để tắt phí trong closed beta.
MARKET_FEE_PCT=0.05

# Phase 15.4 — Feature Flag DB-backed cache TTL (giây).
# Range [5, 300]; mặc định 30 — admin tắt flag → mọi pod thấy trong ≤ 30s.
# Đặt thấp (5s) cho debug nhanh; đặt cao (300s) cho production high-traffic
# nếu chấp nhận trễ apply. Cache 2-tier: L1 in-memory + L2 Redis (key
# `feature-flag:<KEY>`). Redis lỗi → fallback L1 + log warn (không crash).
# FEATURE_FLAG_CACHE_TTL_SEC=30

# SMTP (forgot/reset-password mail). Trong dev: chạy `pnpm infra:up` để bật
# Mailhog trên cổng 1025 (SMTP) + 8025 (UI http://localhost:8025).
# - Để `MAIL_TRANSPORT=console` (mặc định khi không có SMTP_HOST) → log mail body
#   ra stdout, không gửi thật. Phù hợp CI/test.
# - Đặt `MAIL_TRANSPORT=smtp` + `SMTP_HOST=localhost` để gửi qua Mailhog dev.
SMTP_HOST=
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
# Quoted vì chứa khoảng trắng + ký tự < > — `bash source .env` sẽ fail nếu để raw.
SMTP_FROM="Xuân Tôi <noreply@xuantoi.local>"
MAIL_TRANSPORT=console
# URL frontend public — dùng để build link reset-password trong email.
WEB_PUBLIC_URL=http://localhost:5173

# Phase M7 — Production Content Security Policy (CSP)
# ────────────────────────────────────────────────────────────────────
# Production CSP đọc env opt-in để mở **chỉ khi cần** — KHÔNG mở wildcard.
# Khi mọi env M7 trống → fallback policy `'self'` (an toàn, backward-compat).
#
# Validate (xem `apps/api/src/security/csp-config.ts`):
#  - Chỉ chấp nhận origin scheme `https://` (CDN/API) hoặc `wss://` / `https://` (WS).
#  - Reject `'unsafe-inline'`, `'unsafe-eval'`, `*`, `https://*` glob, `data:`
#    ngoài directive img/font/worker. Origin invalid → bị filter + log.
#
# CDN (script/style/img/font/worker/manifest/media-src):
# WEB_PUBLIC_CDN_ORIGIN=https://cdn.xuantoi.io
# WEB_ASSET_CDN_ORIGINS=https://static.xuantoi.io,https://r2.xuantoi.io
#
# API + WebSocket connect-src:
# API_PUBLIC_ORIGIN=https://api.xuantoi.io
# WS_PUBLIC_ORIGIN=wss://ws.xuantoi.io
#
# Extra opt-in directives (csv):
# CSP_EXTRA_CONNECT_SRC=https://sentry.io,wss://push.xuantoi.io
# CSP_EXTRA_IMG_SRC=https://gravatar.com
# CSP_EXTRA_SCRIPT_SRC='strict-dynamic',https://js-cdn.example.com
# CSP_EXTRA_STYLE_SRC=https://fonts.googleapis.com
# CSP_EXTRA_FRAME_SRC=https://payment.example.com         # override frame-src 'none'
#
# Rollout mode — report-only header (KHÔNG enforce, chỉ log violations):
# CSP_REPORT_ONLY=0
# CSP_REPORT_URI=https://sentry.io/api/<project>/security/?sentry_key=<key>

# Smart admin economy alerts — `GET /admin/economy/alerts?staleHours=N`.
# Clamp range cho query param `staleHours`. Default 24h, range [1..720] (30 ngày).
# Ops override nếu muốn soft-launch với longer stale tolerance (vd 48h) hoặc
# audit dài (vd 2160h = 90 ngày). Xem `docs/ADMIN_GUIDE.md §11.3`.
# ECONOMY_ALERTS_DEFAULT_STALE_HOURS=24
# ECONOMY_ALERTS_MIN_STALE_HOURS=1
# ECONOMY_ALERTS_MAX_STALE_HOURS=720

# Phase 17.3 — Observability (Sentry + Pino structured logs)
# ────────────────────────────────────────────────────────────────────
# Pino logger level. Production khuyến nghị `info`. Set `debug` để
# trace request flow ở staging.
# LOG_LEVEL=info

# Sentry backend error tracking. Tắt mặc định ở dev/test. Production
# bật bằng cách:
#   1. Set SENTRY_DSN_API = DSN từ Sentry project (KHÔNG commit DSN thật).
#   2. Set SENTRY_ENABLED=true.
#   3. Optional: SENTRY_TRACES_SAMPLE_RATE (0..1, vd 0.1 = 10%).
SENTRY_ENABLED=false
SENTRY_DSN_API=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0
# SENTRY_RELEASE=git-sha-here

# Phase 17.4 — Backup/Restore automation
# ────────────────────────────────────────────────────────────────────
# Backup output dir (mặc định ./backups khi chạy local).
# Production khuyến nghị set absolute path ngoài repo (vd /var/backups/xuantoi).
# BACKUP_DIR=./backups
#
# Auto-prune backup file `xuantoi-*.sql.gz` cũ hơn N ngày sau khi backup
# thành công. `0` = disabled. Ops khuyến nghị `7` cho closed beta.
# BACKUP_RETENTION_DAYS=0
#
# Restore safety guards (xem `scripts/restore-db.sh` + `docs/RUNBOOK.md`):
#   - CONFIRM_RESTORE=YES        # ép bypass interactive prompt (cron/CI)
#   - ALLOW_PRODUCTION_RESTORE=  # mặc định empty; phải set YES tường minh
#                                # ở production (NODE_ENV=production) trước
#                                # khi script chịu drop/restore.
#   - RUN_PRISMA_MIGRATE=1       # chạy `prisma migrate deploy` ngay sau restore.

# Phase 17.2 — Offsite S3 backup + Weekly restore verify
# ────────────────────────────────────────────────────────────────────
# `scripts/backup-to-s3.sh` upload file `backups/xuantoi-*.sql.gz` (do
# `backup-db.sh` tạo) lên S3-compatible bucket. `scripts/restore-verify-weekly.sh`
# weekly tải file mới nhất → restore vào temp DB → verify schema/critical table.
# Cả 2 share env vars (xem `apps/api/src/ops/backup-s3-config.ts`).
#
# Required (cho upload + offsite verify):
#   - BACKUP_S3_ENDPOINT          # vd https://s3.us-east-1.amazonaws.com hoặc https://minio.local:9000
#   - BACKUP_S3_BUCKET            # tên bucket
#   - BACKUP_S3_ACCESS_KEY_ID
#   - BACKUP_S3_SECRET_ACCESS_KEY
#
# Optional:
#   - BACKUP_S3_REGION                  default us-east-1
#   - BACKUP_S3_PREFIX                  default xuantoi/backups/ (path inside bucket)
#   - BACKUP_S3_FORCE_PATH_STYLE        default 1 (MinIO/R2 cần; AWS S3 đặt 0)
#   - BACKUP_S3_SSE                     server-side encryption: empty / AES256 / aws:kms
#   - BACKUP_S3_PRUNE                   default 0; set 1 để upload script tự xoá
#                                       offsite backup cũ hơn BACKUP_RETENTION_DAYS.
#
# Weekly verify temp DB:
#   - BACKUP_VERIFY_TMP_DB              default xuantoi_verify (CREATE/DROP DATABASE).
#                                       Chỉ chấp nhận [A-Za-z_][A-Za-z0-9_]* để chống injection.
#   - BACKUP_VERIFY_TMP_RETAIN          default 0; set 1 để giữ temp DB sau verify (debug).
#   - BACKUP_VERIFY_LOCAL               override S3 — verify file backup local cụ thể.
#
# DRY_RUN=1 cả 2 script in plan + exit 0, KHÔNG cần credential thật.
# BACKUP_S3_ENDPOINT=
# BACKUP_S3_REGION=us-east-1
# BACKUP_S3_BUCKET=
# BACKUP_S3_PREFIX=xuantoi/backups/
# BACKUP_S3_ACCESS_KEY_ID=
# BACKUP_S3_SECRET_ACCESS_KEY=
# BACKUP_S3_FORCE_PATH_STYLE=1
# BACKUP_S3_SSE=
# BACKUP_S3_PRUNE=0
# BACKUP_VERIFY_TMP_DB=xuantoi_verify
# BACKUP_VERIFY_TMP_RETAIN=0

# Phase PWA-1 — Web Push Notifications.
# VAPID keys: generate via `npx web-push generate-vapid-keys --json`.
# KHÔNG commit VAPID_PRIVATE_KEY thật. Set ở deploy secret store.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:ops@example.com
# Gate cho toàn bộ send pipeline. Mặc định `false` ở prod cho đến khi
# VAPID configured. Set `true` để bật send (vẫn cần subscription user).
PUSH_ENABLED=false
# `true` ⇒ chỉ log payload, KHÔNG gọi push gateway thật. Dùng cho local dev.
PUSH_DRY_RUN=true
