VITE_API_BASE=/api
# Bỏ trống ở dev → FE dùng window.location.origin và Vite proxy /ws → API.
# Khi deploy production, set origin tuyệt đối (KHÔNG kèm path /ws), ví dụ:
#   VITE_WS_URL=https://api.example.com
VITE_WS_URL=

# Phase 17.3 — Sentry frontend error tracking
# ────────────────────────────────────────────────────────────────────
# Disabled mặc định. Production bật:
#   1. VITE_SENTRY_DSN_WEB = DSN frontend project (KHÔNG commit DSN thật).
#   2. VITE_SENTRY_ENABLED=true.
#   3. Optional: VITE_SENTRY_TRACES_SAMPLE_RATE (0..1).
VITE_SENTRY_ENABLED=false
VITE_SENTRY_DSN_WEB=
VITE_SENTRY_ENVIRONMENT=development
VITE_SENTRY_TRACES_SAMPLE_RATE=0
# VITE_SENTRY_RELEASE=git-sha-here
